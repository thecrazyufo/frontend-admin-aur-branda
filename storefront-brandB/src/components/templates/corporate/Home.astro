---
import ProductCard from "@/components/common/ProductCard";

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName = settings?.name || "CorpTech Solutions";
const siteTagline = settings?.tagline || "Enterprise-Grade Software for Modern Business";
const siteDescription = settings?.description || "Secure, scalable, and reliable tools trusted by Fortune 500 companies.";
const siteBadges = settings?.trustBadges || [];
---
<div class="bg-slate-50 text-slate-800 font-sans min-h-screen">
  <!-- Professional Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 flex flex-col lg:flex-row items-center gap-12">
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded bg-blue-50 text-blue-700 text-sm font-semibold mb-6 border border-blue-100">
          ISO 27001 Certified Solutions
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 tracking-tight mb-6 leading-tight">
          {siteTagline}
        </h1>
        <p class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl mx-auto lg:mx-0">
          {siteDescription}
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded shadow-sm transition-colors w-full sm:w-auto text-center">
            Request a Demo
          </a>
          <a href="/products" class="bg-white hover:bg-slate-50 text-slate-700 font-semibold py-3 px-8 rounded border border-slate-300 shadow-sm transition-colors w-full sm:w-auto text-center">
            View Solutions
          </a>
        </div>
      </div>
      <div class="flex-1 w-full max-w-lg lg:max-w-none">
        <!-- Abstract corporate illustration representation -->
        <div class="aspect-[4/3] bg-slate-100 rounded-lg border border-slate-200 shadow-inner flex items-center justify-center p-8">
          <div class="w-full h-full border border-dashed border-slate-300 rounded flex items-center justify-center text-slate-400">
            [Enterprise Dashboard Visualization]
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-slate-900 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-6">Trusted by industry leaders worldwide</p>
      <div class="flex flex-wrap justify-center gap-8 opacity-70 grayscale">
        {siteBadges.map(b => (
          <div class="flex items-center gap-2 text-white">
            <span class="text-2xl">{b.emoji}</span>
            <span class="font-bold text-lg">{b.title}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Structured Solutions Grid -->
  <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 border-l-4 border-blue-600 pl-6">
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Enterprise Solutions</h2>
      <p class="text-lg text-slate-600">Comprehensive toolsets designed for scale and security.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featured.map((product) => (
        <div class="bg-white border border-slate-200 rounded shadow-sm hover:shadow-md transition-shadow flex flex-col">
          <div class="p-6 border-b border-slate-100 flex items-center gap-4">
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded flex items-center justify-center text-xl">
              {product.icon || "📊"}
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-900">{product.name}</h3>
              <p class="text-sm text-slate-500">License: ${product.price}/mo</p>
            </div>
          </div>
          <div class="p-6 flex-grow">
            <p class="text-slate-600 text-sm leading-relaxed">{product.description}</p>
          </div>
          <div class="p-6 pt-0 mt-auto">
            <a href={`/products/${product.id}`} class="text-blue-600 font-semibold text-sm hover:text-blue-800 flex items-center gap-1">
              Learn more <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
</div>
