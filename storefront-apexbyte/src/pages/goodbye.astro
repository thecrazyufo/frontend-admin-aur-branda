---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "Prism Migration";

// Try to fetch custom content, fallback to default premium welcome content if empty
const hasCustomContent = !!settings?.legalPages?.["goodbye"];
const htmlContent = settings?.legalPages?.["goodbye"];
---

<BaseLayout
  title={`Uninstallation Completed — ${siteName}`}
  description="The software has been uninstalled. We are sorry to see you go."
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center py-20 bg-white relative overflow-hidden tech-grid">
    <!-- Background accents -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute -top-[10%] left-[50%] -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-apex-600)]/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="container-custom max-w-3xl mx-auto px-4 relative z-10">
      {hasCustomContent ? (
        <div 
          class="bg-[var(--color-surface-2)]/30 backdrop-blur-xl border border-[var(--color-border)] p-8 md:p-12 rounded-3xl shadow-2xl prose prose-invert max-w-none prose-headings:text-[var(--color-text-primary)] prose-p:text-[var(--color-text-muted)] prose-a:text-[var(--color-apex-600)] hover:prose-a:underline"
          set:html={htmlContent}
        />
      ) : (
        <div class="bg-[var(--color-surface-2)]/30 backdrop-blur-xl border border-[var(--color-border)] p-8 md:p-12 rounded-3xl shadow-2xl text-center space-y-8">
          <!-- Trash or Goodbye SVG -->
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 text-red-500 mb-2 animate-pulse">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
            </svg>
          </div>

          <div class="space-y-3">
            <h1 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text-primary)] tracking-tight">
              Uninstallation Completed
            </h1>
            <p class="text-[var(--color-text-secondary)] text-sm md:text-base max-w-md mx-auto">
              We are sorry to see you go. <span class="text-[var(--color-apex-600)] font-bold">{siteName}</span> has been completely removed from your device.
            </p>
          </div>

          <!-- Feedback Callout -->
          <div class="bg-[var(--color-apex-50)]/40 p-6 rounded-2xl border border-[var(--color-border)] max-w-lg mx-auto text-left space-y-4">
            <h3 class="text-[var(--color-text-primary)] font-semibold text-sm">Help us improve!</h3>
            <p class="text-[var(--color-text-secondary)] text-xs leading-relaxed">
              We are constantly working to build a better tool. If you experienced any issues or have feedback, please let us know. Your suggestions directly shape future releases.
            </p>
            <a 
              href="/contact" 
              class="inline-flex items-center gap-1.5 text-xs text-[var(--color-apex-600)] font-semibold hover:underline"
            >
              Share Feedback 
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Quick Actions -->
          <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-4">
            <a 
              href="/" 
              class="w-full sm:w-auto px-6 py-3 bg-[var(--color-apex-600)] hover:bg-[var(--color-apex-700)] text-black font-semibold rounded-lg text-sm transition-all duration-200 transform hover:scale-[1.02]"
            >
              Reinstall Software
            </a>
            <a 
              href="/products" 
              class="w-full sm:w-auto px-6 py-3 bg-[var(--color-surface-2)] border border-[var(--color-border)] hover:border-stone-800 text-[var(--color-text-muted)] font-semibold rounded-lg text-sm transition-all duration-200"
            >
              Explore Other Products
            </a>
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
