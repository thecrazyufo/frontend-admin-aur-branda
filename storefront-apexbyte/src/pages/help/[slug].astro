---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { HelpAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import Breadcrumb from "@/components/layout/Breadcrumb";
import { ArrowLeft, ThumbsUp, ThumbsDown } from "lucide-react";
import { parseMarkdownToHtml } from "@/lib/utils";

const { slug } = Astro.params;

let article = null;

try {
  if (slug) {
    article = await HelpAPI.getBySlug(slug);
  }
} catch (e) {
  console.error("Error loading help article:", e);
}

if (!article) {
  return new Response("Help Article Not Found", { status: 404 });
}
---

<BaseLayout
  title={`${article.title} — ${settings?.name || ""}`}
  description={article.excerpt}
>
  <Breadcrumb items={[{ label: "Help Center", href: "/help" }, { label: article.title }]} />
  <div class="bg-gray-50 min-h-screen">
    <article class="container-custom py-12 max-w-3xl">
      <a href="/help" class="inline-flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700 mb-8 font-medium">
        <ArrowLeft size={15} />
        Back to Help Center
      </a>
      <h1 class="font-bold text-gray-900 mb-2">{article.title}</h1>
      <p class="text-gray-500 text-sm mb-8">{article.excerpt}</p>

      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <div class="text-gray-600 leading-relaxed text-sm" set:html={parseMarkdownToHtml(article.content || "")} />
      </div>

      {/* Helpful? */}
      <div class="mt-8 bg-white rounded-2xl border border-gray-100 p-6 text-center">
        <p class="font-semibold text-gray-900 mb-4">Was this article helpful?</p>
        <div class="flex items-center justify-center gap-4 flex-wrap">
          <button id="btn-helpful" class="btn btn-outline text-sm py-2 px-5 text-green-600 border-green-200 hover:bg-green-50 flex items-center gap-1.5">
            <ThumbsUp size={15} />
            Yes (<span id="count-helpful">{article.helpful || 0}</span>)
          </button>
          <button id="btn-nothelpful" class="btn btn-outline text-sm py-2 px-5 text-red-500 border-red-100 hover:bg-red-50 flex items-center gap-1.5">
            <ThumbsDown size={15} />
            No (<span id="count-nothelpful">{article.notHelpful || 0}</span>)
          </button>
        </div>
      </div>
    </article>
  </div>

  <script is:inline define:vars={{ articleId: article.id, publicApiUrl: import.meta.env.PUBLIC_API_URL || "http://localhost:8080/api" }}>
    const helpfulBtn = document.getElementById("btn-helpful");
    const notHelpfulBtn = document.getElementById("btn-nothelpful");
    const helpfulCount = document.getElementById("count-helpful");
    const notHelpfulCount = document.getElementById("count-nothelpful");

    helpfulBtn?.addEventListener("click", async () => {
      try {
        const res = await fetch(`${publicApiUrl}/help/${articleId}/helpful`, { method: "POST" });
        if (res.ok) {
          const data = await res.json();
          if (helpfulCount) helpfulCount.textContent = data.helpful;
          helpfulBtn.disabled = true;
          if (notHelpfulBtn) notHelpfulBtn.disabled = true;
          helpfulBtn.style.opacity = "0.5";
          helpfulBtn.style.cursor = "not-allowed";
        }
      } catch (err) {
        console.error("Failed to submit helpful feedback", err);
      }
    });

    notHelpfulBtn?.addEventListener("click", async () => {
      try {
        const res = await fetch(`${publicApiUrl}/help/${articleId}/nothelpful`, { method: "POST" });
        if (res.ok) {
          const data = await res.json();
          if (notHelpfulCount) notHelpfulCount.textContent = data.notHelpful;
          helpfulBtn.disabled = true;
          if (notHelpfulBtn) notHelpfulBtn.disabled = true;
          notHelpfulBtn.style.opacity = "0.5";
          notHelpfulBtn.style.cursor = "not-allowed";
        }
      } catch (err) {
        console.error("Failed to submit not helpful feedback", err);
      }
    });
  </script>
</BaseLayout>
