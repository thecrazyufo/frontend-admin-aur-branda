---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SettingsAPI } from "@/services/api";

const { page } = Astro.params;

const validPages: Record<string, string> = {
  privacy: "Privacy Policy",
  terms: "Terms of Service",
  refund: "Refund Policy",
  license: "License Agreement",
};

if (!page || !validPages[page]) {
  return Astro.redirect("/404");
}

const settings = await SettingsAPI.get().catch(() => null);
const pageTitle = validPages[page];
const siteName = settings?.name || "";
const htmlContent = settings?.legalPages?.[page] || `<p>This page is currently being updated. Please check back later or <a href="/contact">contact us</a> for more information.</p>`;

export function getStaticPaths() {
  return [
    { params: { page: "privacy" } },
    { params: { page: "terms" } },
    { params: { page: "refund" } },
    { params: { page: "license" } },
  ];
}
---

<BaseLayout
  title={`${pageTitle} — ${siteName}`}
  description={`${pageTitle} for ${siteName}. Read our policies carefully.`}
>
  <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
    <div class="container-custom max-w-4xl">
      <div class="mb-10 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
          {pageTitle}
        </h1>
        <p class="text-gray-500 text-sm">
          Last updated: {new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </p>
      </div>

      <div
        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 md:p-12 prose prose-lg max-w-none
               prose-headings:text-gray-900 prose-p:text-gray-600 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
               prose-li:text-gray-600 prose-strong:text-gray-800"
        set:html={htmlContent}
      />

      <div class="mt-8 text-center">
        <p class="text-sm text-gray-400">
          If you have questions about this policy, please
          <a href="/contact" class="text-blue-600 hover:underline ml-1">contact our support team</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
