---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI, BrandAPI } from "@/services/api";
import ApexByteHome from "@/components/templates/apexbyte/Home.astro";

// Server-side data fetch (Astro SSR — zero JS shipped for this)
let products    = [];
let categories  = [];
let settings    = null;
let brandConfig = null;

try {
  [products, categories, settings, brandConfig] = await Promise.all([
    ProductAPI.getAll(),
    CategoryAPI.getAll(),
    SettingsAPI.get().catch(() => null),
    BrandAPI.getCurrentBrand().catch(() => null),
  ]);
} catch (e) {
  // Graceful fallback when backend is unavailable
}

const featured = products.filter((p: any) => p.enabled !== false).slice(0, 6);

const testimonials = products
  .flatMap((p: any) =>
    (p.reviews || []).map((r: any) => ({
      author:  r.author,
      role:    r.role    || "IT Professional",
      company: r.company || "Verified User",
      rating:  r.rating  || 5,
      content: r.content,
    }))
  )
  .slice(0, 6);

const siteName        = settings?.name        || "ApexByte Soft";
const siteTagline     = settings?.tagline     || "Precision Software for Modern IT Teams";
const siteDescription = settings?.description || "Enterprise-grade migration and data management tools trusted by IT professionals worldwide.";

const templateProps = { products, categories, settings, featured, testimonials };
---

<BaseLayout
  title={`${siteName} — ${siteTagline}`}
  description={siteDescription}
>
  <ApexByteHome {...templateProps} />
</BaseLayout>
