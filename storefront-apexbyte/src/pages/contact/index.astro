---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Mail, Phone, MapPin, Clock } from "lucide-react";
import ContactForm from "@/components/common/ContactForm";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

const siteName = settings?.name || "";
const siteDescription = settings?.description || "";
const sitePhone = settings?.phone || "";
const siteEmail = settings?.email || "";
const siteAddress = settings?.address || "";
---

<BaseLayout
  title={`Contact Us — ${siteName}`}
  description="Get in touch with our support team. We're available 24/7 to help with any questions about our software tools."
>
  <div>
    <div class="bg-[var(--color-apex-800)] py-14 text-center relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="container-custom relative z-10">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full bg-white/10 border border-white/20" style="color: var(--color-apex-200)">Contact</span>
        <h1 class="font-extrabold mb-3" style="color: #ffffff">We're Here to Help</h1>
        <p class="max-w-lg mx-auto" style="color: var(--color-apex-300)">
          Contact our expert support team. We typically respond within 2 hours.
        </p>
      </div>
    </div>

    <section class="section" style="background: var(--color-surface-2)">
      <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          {/* Contact Info */}
          <div class="space-y-6">
            <div>
              <h2 class="font-bold text-xl mb-6" style="color: var(--color-text-primary)">Contact Information</h2>
              <div class="space-y-3">
                {[
                  { icon: "Phone", label: "Phone", value: sitePhone, href: `tel:${sitePhone}` },
                  { icon: "Mail", label: "Email", value: siteEmail, href: `mailto:${siteEmail}` },
                  { icon: "MapPin", label: "Address", value: siteAddress },
                  { icon: "Clock", label: "Hours", value: "Mon–Fri: 9AM–6PM PST\nWeekends: 10AM–4PM PST" },
                ].map((item) => (
                  <div class="flex items-start gap-4 p-4 bg-white rounded-[var(--radius-lg)] border" style="border-color: var(--color-border)">
                    <div class="w-10 h-10 rounded-[var(--radius-md)] flex items-center justify-center shrink-0" style="background: var(--color-apex-50); color: var(--color-apex-600)">
                      {item.icon === "Phone" && <Phone size={18} />}
                      {item.icon === "Mail" && <Mail size={18} />}
                      {item.icon === "MapPin" && <MapPin size={18} />}
                      {item.icon === "Clock" && <Clock size={18} />}
                    </div>
                    <div>
                      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">{item.label}</p>
                      {item.href ? (
                        <a href={item.href} class="text-sm text-gray-700 hover:text-blue-600 font-medium">{item.value}</a>
                      ) : (
                        <p class="text-sm text-gray-700 whitespace-pre-line leading-relaxed">{item.value}</p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Contact Form Island */}
          <div class="lg:col-span-2">
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
