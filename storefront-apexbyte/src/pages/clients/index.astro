---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/common/SectionHeader";
import { Building, ShieldCheck, CheckCircle2, ArrowRight, Users, Award, Globe, Heart } from "lucide-react";
import { SettingsAPI, SocialProofAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "Prism Migration";

// Load dynamic clients page configurations
const clientsConfig = settings?.clientsPage || {
  heroTitle: "Trusted by Leading Organizations",
  heroSubtitle: "We help companies of all sizes migrate their enterprise data seamlessly, securely, and with zero downtime.",
  stats: [
    { value: "150+", label: "Companies Trust Us" },
    { value: "50+", label: "Countries Served" },
    { value: "10B+", label: "Items Migrated" },
    { value: "99.9%", label: "Success Rate" }
  ],
  ctaTitle: "Join Our Growing List of Clients",
  ctaText: "Ready to migrate your database, mailboxes, or cloud storage? Start your risk-free trial today or contact our integration team.",
  ctaButtonText: "Contact Sales",
  ctaButtonLink: "/contact",
  metaTitle: "Our Clients — Enterprise Data Migration Success Stories",
  metaDescription: "See how leading organizations use Prism Migration tools to translate, convert, and sync mailbox databases.",
  metaKeywords: "clients, customers, case studies, enterprise, success stories"
};

// Fetch dynamic client logos and testimonials from backend
const logos = await SocialProofAPI.getLogos().catch(() => []);
const testimonials = await SocialProofAPI.getTestimonials().catch(() => []);

// Generate Organization Logo Schema Markup
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Trusted Brands & Clients",
  "numberOfItems": logos.length,
  "itemListElement": logos.map((logo: any, idx: number) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "item": {
      "@type": "Organization",
      "name": logo.companyName,
      "logo": logo.logoUrl,
      "description": logo.description || `Trusted enterprise client of ${siteName}`
    }
  }))
};
---

<BaseLayout
  title={clientsConfig.metaTitle || `Our Clients — ${siteName}`}
  description={clientsConfig.metaDescription || `Discover how leading organizations trust ${siteName} for data integrity.`}
  keywords={clientsConfig.metaKeywords}
>
  <!-- ItemList structured data for search engine rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="bg-white min-h-screen text-zinc-100 font-sans">
    {/* Hero Section */}
    <section class="relative py-24 text-center border-b border-[var(--color-border)] overflow-hidden">
      <!-- Glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[var(--color-apex-600)]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10 max-w-4xl mx-auto px-4">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[var(--color-apex-600)] bg-[var(--color-apex-600)]/15 border border-[var(--color-apex-600)]/25">
          Case Studies & Trust
        </span>
        <h1 class="text-[var(--color-text-primary)] font-extrabold text-4xl md:text-6xl tracking-tight mb-6 leading-tight">
          {clientsConfig.heroTitle}
        </h1>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
          {clientsConfig.heroSubtitle}
        </p>
      </div>
    </section>

    {/* Dynamic Client Logos Grid Section */}
    <section class="py-20 border-b border-[var(--color-border)] bg-[var(--color-apex-50)]/20">
      <div class="container-custom max-w-6xl mx-auto px-4">
        <SectionHeader eyebrow="Partners" title="Companies That Trust Us" centered class="mb-12" />

        {logos.length === 0 ? (
          <div class="text-center py-12 text-zinc-500 text-sm border border-dashed border-stone-800 rounded-2xl">
            Our corporate client roster is dynamically updating.
          </div>
        ) : (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {logos.map((logo: any) => (
              <div class="bg-[var(--color-surface-2)]/35 border border-[var(--color-border)] backdrop-blur rounded-2xl p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-stone-800 group hover:scale-[1.03]">
                {logo.logoUrl ? (
                  <img
                    src={logo.logoUrl}
                    alt={`${logo.companyName} logo`}
                    class="h-10 md:h-12 w-auto max-w-[80%] object-contain filter brightness-90 contrast-125 opacity-75 group-hover:opacity-100 transition-opacity duration-300 mb-3"
                    onError="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                ) : null}
                <div class="w-12 h-12 rounded-xl bg-[var(--color-surface-2)]/80 items-center justify-center text-[var(--color-text-secondary)] border border-[var(--color-border)] group-hover:border-[var(--color-apex-600)]/30 group-hover:text-[var(--color-apex-600)] hidden mb-3">
                  <Building size={20} />
                </div>
                <h3 class="text-[var(--color-text-primary)] font-semibold text-sm group-hover:text-[var(--color-apex-600)] transition-colors">{logo.companyName}</h3>
                {logo.description && (
                  <p class="text-[11px] text-[var(--color-text-secondary)] mt-1 line-clamp-2 max-w-[90%]">{logo.description}</p>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    {/* Dynamic Testimonials / Case Studies Section */}
    <section class="py-20 border-b border-[var(--color-border)]">
      <div class="container-custom max-w-6xl mx-auto px-4">
        <SectionHeader eyebrow="Success Stories" title="Enterprise Case Studies" centered class="mb-12" />

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {logos.filter((l: any) => l.caseStudy).map((client: any) => (
            <div class="bg-[var(--color-surface-2)]/25 border border-[var(--color-border)] rounded-2xl p-8 flex flex-col justify-between hover:border-stone-800 transition-all duration-300">
              <div class="space-y-4">
                <span class="inline-block text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded bg-[var(--color-apex-600)]/10 text-[var(--color-apex-600)] border border-[var(--color-apex-600)]/15">
                  Case Study
                </span>
                <h3 class="text-[var(--color-text-primary)] font-bold text-lg">{client.companyName}</h3>
                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed italic border-l-2 border-[var(--color-apex-600)] pl-3">
                  "{client.description}"
                </p>
                <p class="text-[var(--color-text-secondary)] text-xs leading-relaxed">
                  {client.caseStudy}
                </p>
              </div>
              <div class="flex items-center gap-2 text-xs font-semibold text-[var(--color-apex-600)] pt-6 group cursor-pointer hover:underline">
                <span>View Full Case Study</span>
                <ArrowRight size={14} class="transition-transform group-hover:translate-x-1" />
              </div>
            </div>
          ))}

          {/* Testimonials fallback/integration if logos don't have case studies */}
          {logos.filter((l: any) => l.caseStudy).length === 0 && (
            <div class="col-span-3 grid grid-cols-1 md:grid-cols-2 gap-6">
              {testimonials.map((t: any) => (
                <div class="bg-[var(--color-surface-2)]/25 border border-[var(--color-border)] rounded-2xl p-6 hover:border-stone-800 transition-all duration-300">
                  <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                      {t.avatarUrl ? (
                        <img src={t.avatarUrl} alt={t.authorName} class="w-10 h-10 rounded-full object-cover border border-stone-800" />
                      ) : (
                        <div class="w-10 h-10 rounded-full bg-[var(--color-surface-2)] flex items-center justify-center text-xs font-semibold text-[var(--color-text-secondary)] border border-[var(--color-border)]">
                          {t.authorName?.charAt(0)}
                        </div>
                      )}
                      <div>
                        <h4 class="text-[var(--color-text-primary)] text-xs font-bold">{t.authorName}</h4>
                        <p class="text-[10px] text-[var(--color-text-secondary)] font-medium">{t.authorTitle} at {t.company}</p>
                      </div>
                    </div>
                    <div class="flex text-yellow-500 text-[10px]">
                      {Array.from({ length: t.rating || 5 }).map(() => (
                        <span>★</span>
                      ))}
                    </div>
                  </div>
                  <p class="text-[var(--color-text-muted)] text-xs leading-relaxed italic">
                    "{t.content}"
                  </p>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    {/* Metric / Stats Cards */}
    <section class="py-20 border-b border-[var(--color-border)] bg-[var(--color-apex-50)]/20">
      <div class="container-custom max-w-5xl mx-auto px-4">
        <SectionHeader eyebrow="Metrics" title="Our Growth & Presence" centered class="mb-12" />

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {(clientsConfig.stats || []).map((s: any) => (
            <div class="bg-[var(--color-surface-2)]/35 border border-[var(--color-border)]/60 backdrop-blur rounded-2xl p-6 text-center transition-all duration-300 hover:border-stone-800">
              <h3 class="text-[var(--color-text-primary)] font-extrabold text-3xl md:text-4xl mb-2 tracking-tight text-[var(--color-apex-600)]">
                {s.value}
              </h3>
              <p class="text-[var(--color-text-secondary)] text-xs font-semibold uppercase tracking-wider">
                {s.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Call to Action Section */}
    <section class="relative py-24 text-center overflow-hidden">
      <!-- Glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[350px] h-[100px] bg-[var(--color-apex-600)]/5 blur-[70px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10 max-w-3xl mx-auto px-4">
        <h2 class="text-[var(--color-text-primary)] font-extrabold text-3xl md:text-4xl tracking-tight mb-4">
          {clientsConfig.ctaTitle}
        </h2>
        <p class="text-[var(--color-text-muted)] text-xs md:text-sm max-w-lg mx-auto mb-8 leading-relaxed">
          {clientsConfig.ctaText}
        </p>
        <div class="flex items-center justify-center gap-4">
          <a
            href={clientsConfig.ctaButtonLink}
            class="inline-flex items-center justify-center text-xs font-bold text-[#0A0A0A] bg-[var(--color-apex-600)] hover:bg-[var(--color-apex-600)]/90 px-6 py-3 rounded-full transition-all duration-200 active:scale-95 shadow-lg shadow-[#EAB308]/10"
          >
            {clientsConfig.ctaButtonText}
            <ArrowRight size={14} class="ml-2" />
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
