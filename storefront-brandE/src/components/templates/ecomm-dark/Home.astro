---
import ProductCard from "@/components/common/ProductCard";

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName = settings?.name || "EcommDark";
const siteTagline = settings?.tagline || "High Performance Software.";
const siteDescription = settings?.description || "Get the tools you need today. Instant digital delivery.";
---
<div class="bg-zinc-950 text-zinc-100 font-sans min-h-screen">
  <!-- Aggressive Hero -->
  <section class="border-b border-red-900/30 bg-gradient-to-b from-zinc-900 to-zinc-950">
    <div class="max-w-7xl mx-auto px-4 py-16 text-center">
      <div class="inline-block bg-red-600 text-white text-xs font-black uppercase tracking-widest px-3 py-1 mb-6 animate-pulse">
        ⚡ FLASH SALE: 20% OFF ALL LICENSES
      </div>
      <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-4 text-white">
        {siteTagline}
      </h1>
      <p class="text-xl text-zinc-400 mb-8 max-w-2xl mx-auto">
        {siteDescription}
      </p>
      
      <!-- Fake countdown for urgency -->
      <div class="flex justify-center gap-4 mb-10">
        <div class="bg-zinc-900 border border-zinc-800 p-3 w-20 rounded">
          <div class="text-2xl font-black text-red-500">04</div>
          <div class="text-[10px] text-zinc-500 uppercase font-bold">Hours</div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 p-3 w-20 rounded">
          <div class="text-2xl font-black text-red-500">45</div>
          <div class="text-[10px] text-zinc-500 uppercase font-bold">Mins</div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 p-3 w-20 rounded">
          <div class="text-2xl font-black text-red-500">12</div>
          <div class="text-[10px] text-zinc-500 uppercase font-bold">Secs</div>
        </div>
      </div>

      <a href="/products" class="inline-block bg-red-600 hover:bg-red-700 text-white font-black text-lg py-4 px-12 uppercase tracking-wider transition-colors w-full sm:w-auto">
        Shop Now
      </a>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8 border-b border-zinc-800 pb-4">
      <h2 class="text-2xl font-black uppercase tracking-wider text-white">Trending Software</h2>
      <a href="/products" class="text-red-500 hover:text-red-400 text-sm font-bold uppercase tracking-widest">View All</a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {featured.map((product) => (
        <div class="bg-zinc-900 border border-zinc-800 hover:border-red-500/50 transition-colors p-4 flex flex-col relative group">
          <div class="absolute top-2 left-2 bg-red-600 text-white text-[10px] font-black uppercase px-2 py-0.5 z-10">
            Hot
          </div>
          <div class="aspect-square bg-zinc-950 mb-4 flex items-center justify-center text-5xl">
            {product.icon || "💻"}
          </div>
          <h3 class="text-lg font-bold text-white mb-1 leading-tight">{product.name}</h3>
          <div class="flex items-center gap-2 mb-4">
            <span class="text-amber-500 text-xs">★★★★★</span>
            <span class="text-zinc-600 text-[10px]">(128)</span>
          </div>
          <div class="mt-auto">
            <div class="text-2xl font-black text-white mb-3">${product.price}</div>
            <a href={`/products/${product.slug}`} class="block text-center w-full bg-zinc-800 hover:bg-red-600 text-white font-bold py-2 uppercase text-sm transition-colors">
              Add to Cart
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Trust Section -->
  <section class="bg-zinc-900 border-t border-zinc-800 py-12">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-3xl mb-2">⚡</div>
        <h4 class="font-black text-white uppercase tracking-wider text-sm mb-1">Instant Delivery</h4>
        <p class="text-zinc-500 text-xs">License keys emailed immediately</p>
      </div>
      <div>
        <div class="text-3xl mb-2">🛡️</div>
        <h4 class="font-black text-white uppercase tracking-wider text-sm mb-1">Secure Checkout</h4>
        <p class="text-zinc-500 text-xs">256-bit SSL encryption</p>
      </div>
      <div>
        <div class="text-3xl mb-2">🔄</div>
        <h4 class="font-black text-white uppercase tracking-wider text-sm mb-1">Money Back</h4>
        <p class="text-zinc-500 text-xs">30-day guarantee</p>
      </div>
      <div>
        <div class="text-3xl mb-2">💬</div>
        <h4 class="font-black text-white uppercase tracking-wider text-sm mb-1">24/7 Support</h4>
        <p class="text-zinc-500 text-xs">Always here to help</p>
      </div>
    </div>
  </section>
</div>
