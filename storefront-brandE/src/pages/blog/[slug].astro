---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BlogAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { formatDate, parseMarkdownToHtml } from "@/lib/utils";
import Breadcrumb from "@/components/layout/Breadcrumb";
import { Clock, ArrowLeft } from "lucide-react";

const { slug } = Astro.params;

let post = null;

try {
  if (slug) {
    post = await BlogAPI.getBySlug(slug);
  }
} catch (e) {
  console.error("Error loading blog post:", e);
}

if (!post) {
  return new Response("Blog Post Not Found", { status: 404 });
}
---

<BaseLayout
  title={`${post.seo.title} — ${settings?.name || ""}`}
  description={post.seo.description}
>
  <Breadcrumb items={[{ label: "Blog", href: "/blog" }, { label: post.title }]} />
  <div class="bg-gray-50 min-h-screen">
    <article class="container-custom py-12 max-w-3xl">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700 mb-8 font-medium">
        <ArrowLeft size={15} />
        Back to Blog
      </a>

      {/* Header */}
      <div class="mb-8">
        <h1 class="font-bold text-gray-900 mb-4">{post.title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-xs">
              {post.author.name.charAt(0)}
            </div>
            <div>
              <span class="font-medium text-gray-700">{post.author.name}</span>
              <span class="text-gray-400 ml-1">— {post.author.role}</span>
            </div>
          </div>
          <span>•</span>
          <span>{formatDate(post.publishedAt)}</span>
          <span>•</span>
          <span class="flex items-center gap-1"><Clock size={13} /> {post.readTime} min read</span>
        </div>
      </div>

      {/* Content */}
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <div class="prose prose-gray max-w-none">
          <p class="text-lg text-gray-600 mb-6 font-medium leading-relaxed">{post.excerpt}</p>
          <div class="text-gray-600 leading-relaxed text-sm" set:html={parseMarkdownToHtml(post.content)} />
        </div>
      </div>

      <div class="mt-8">
        <a href="/blog" class="btn btn-outline text-sm py-2.5 px-5 inline-flex items-center gap-2">
          <ArrowLeft size={15} />
          Back to all articles
        </a>
      </div>
    </article>
  </div>
</BaseLayout>
