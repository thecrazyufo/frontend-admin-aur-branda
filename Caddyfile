# ─────────────────────────────────────────────────────────────────────────────
# Caddy Reverse Proxy & SSL Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Admin Frontend Dashboard
admin.{$DOMAIN} {
    reverse_proxy tenant_frontend_admin:3000
    encode gzip
}

# Storefront Brand A
prismmigration.{$DOMAIN} {
    reverse_proxy brandA:4321
    encode gzip
}

# Backend Spring Boot API
api.{$DOMAIN} {
    reverse_proxy tenant-backend:8080
    encode gzip
}
