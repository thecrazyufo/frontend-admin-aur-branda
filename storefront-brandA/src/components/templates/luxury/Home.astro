---
import type { Product } from "@/types/product";
import type { Category } from "@/services/api";

interface Testimonial {
  author: string;
  role: string;
  company: string;
  rating: number;
  content: string;
}

const { categories, settings, featured, testimonials } = Astro.props;

const siteTagline = settings?.tagline || "Enterprise Mailbox & Database Migrators. Built to Run Locally.";
const siteDescription = settings?.description || "Preserve folder structures, validate integrity with double checksums, and stream files at maximum connection speed. 100% private, on-premise execution.";
const siteStats = settings?.stats || [];

const iconMap: Record<string, string> = {
  mail: "✉️", shield: "🛡️", "refresh-cw": "🔄", cloud: "☁️", "hard-drive": "💾", download: "⬇️",
};

const categoryIconMap: Record<string, string> = {
  "email-migration": "✉️",
  "backup": "💾",
  "file-converter": "🔄",
  "cloud-migration": "☁️",
  "mailbox-recovery": "🛡️",
  "data-export": "📤",
};
---

<!-- Sleek SaaS Hero Section -->
<section class="relative overflow-hidden bg-stone-50/60 py-10 md:py-16 border-b border-stone-200">
  <!-- Subtle Amber Backlight Glows -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="gold-ring-bg"></div>
    <div class="gold-ring-bg-outer"></div>
  </div>

  <div class="container-custom relative z-10 max-w-5xl mx-auto px-4">
    <!-- Fine Structural Border Wrapper -->
    <div class="relative border border-stone-200 p-6 md:p-10 bg-white/75 backdrop-blur-sm grid-crosshair grid-crosshair-tl grid-crosshair-tr grid-crosshair-bl grid-crosshair-br rounded-xl shadow-sm">
      
      <div class="max-w-3xl mx-auto text-center space-y-4">
        <div class="inline-flex items-center gap-2 text-[9px] tracking-[0.15em] text-[#C3A575] uppercase font-semibold bg-[#C3A575]/10 px-2.5 py-0.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-[#C3A575] animate-pulse"></span>
          <span>Est. 2026</span>
          <span class="text-[8px]">•</span>
          <span>Zero Byte Compromise</span>
        </div>

        <h1 class="text-stone-900 text-2xl sm:text-3xl md:text-5xl font-black leading-tight tracking-tight">
          {siteTagline}
        </h1>

        <p class="text-xs sm:text-sm md:text-base text-stone-600 max-w-xl mx-auto leading-relaxed">
          {siteDescription}
        </p>

        <!-- Strong Core Benefits List -->
        <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-[11px] sm:text-xs text-stone-600 pt-1 font-medium max-w-xl mx-auto">
          <div class="flex items-center gap-1">
            <span class="text-[#C3A575] font-bold">✓</span> 100% Private & Local Run
          </div>
          <div class="flex items-center gap-1">
            <span class="text-[#C3A575] font-bold">✓</span> Byte-Perfect Checksum Verification
          </div>
          <div class="flex items-center gap-1">
            <span class="text-[#C3A575] font-bold">✓</span> Lifetime License Keys (No Subscriptions)
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-3">
          <a href="/products" class="btn btn-primary w-full sm:w-[170px] text-xs font-semibold py-2">
            Discover Utilities
          </a>
          <a href="/download" class="btn btn-outline w-full sm:w-[170px] text-xs font-semibold py-2">
            Free Trial Installer
          </a>
        </div>
      </div>
    </div>

    <!-- Minimal Horizontal Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-8 mt-8 border-t border-stone-200/60 max-w-3xl mx-auto">
      {siteStats.slice(0, 4).map((stat: any) => (
        <div class="text-center space-y-0.5">
          <div class="text-xl md:text-2xl font-extrabold text-stone-900">{stat.value}</div>
          <div class="text-[9px] uppercase tracking-wider text-stone-500 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Section I: Architectural Principles -->
<section class="bg-white py-10 md:py-12 border-b border-stone-200">
  <div class="container-custom max-w-5xl mx-auto px-4">
    <div class="text-center mb-8">
      <span class="text-[10px] tracking-wider text-[#C3A575] uppercase font-bold block">Integrity first</span>
      <h2 class="text-xl md:text-2xl font-bold text-stone-900 mt-1">Architectural Principles</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="space-y-1.5 relative pt-4 border-t border-stone-100">
        <span class="text-[9px] font-mono font-semibold text-[#C3A575] tracking-widest block">01 / SOVEREIGNTY</span>
        <h3 class="text-xs sm:text-sm font-bold text-stone-900 pt-0.5">Completely Private Run</h3>
        <p class="text-xs text-stone-500 leading-relaxed">
          Your credentials and databases remain inside your security perimeter. The package compiles and runs locally on your servers, eliminating middle-man cloud risk.
        </p>
      </div>
      <div class="space-y-1.5 relative pt-4 border-t border-stone-100">
        <span class="text-[9px] font-mono font-semibold text-[#C3A575] tracking-widest block">02 / FIDELITY</span>
        <h3 class="text-xs sm:text-sm font-bold text-stone-900 pt-0.5">Byte-Perfect Delivery</h3>
        <p class="text-xs text-stone-500 leading-relaxed">
          Every document mapping is double-checksum validated. Read, write, and folder mapping structures are preserved with absolute structural fidelity.
        </p>
      </div>
      <div class="space-y-1.5 relative pt-4 border-t border-stone-100">
        <span class="text-[9px] font-mono font-semibold text-[#C3A575] tracking-widest block">03 / ASYNCHRONY</span>
        <h3 class="text-xs sm:text-sm font-bold text-stone-900 pt-0.5">Engineered Velocity</h3>
        <p class="text-xs text-stone-500 leading-relaxed">
          Utilizes advanced multi-threaded channels to queue and stream files asynchronously, safely maximizing connection bandwidth while protecting host APIs.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Section II: Pristine Software Collection (Grid Showcase) -->
<section class="bg-stone-50/30 py-10 md:py-12 border-b border-stone-200">
  <div class="container-custom max-w-5xl mx-auto px-4">
    <div class="text-center mb-8">
      <span class="text-[10px] tracking-wider text-[#C3A575] uppercase font-bold block">Production grade</span>
      <h2 class="text-xl md:text-2xl font-bold text-stone-900 mt-1">Pristine Software Collection</h2>
    </div>

    {featured.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {featured.map((product: Product) => {
          const lowestPaidPrice = product.pricing?.find((p: any) => p.price > 0)?.price || 49.00;
          return (
            <div class="bg-white border border-stone-200 rounded-lg p-4 sm:p-5 shadow-sm hover:shadow-md hover:border-[#C3A575]/40 transition-all flex flex-col justify-between relative overflow-hidden group">
              <!-- Subtle top accent line on hover -->
              <div class="absolute top-0 inset-x-0 h-[2px] bg-[#C3A575] scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

              <div>
                <!-- Top Meta Row -->
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-1.5">
                    <span class="text-lg">{categoryIconMap[product.category] || "📦"}</span>
                    <span class="text-[9px] tracking-wider uppercase font-semibold text-[#C3A575] bg-[#C3A575]/10 px-1.5 py-0.5 rounded">
                      {product.category.replace('-', ' ')}
                    </span>
                  </div>
                  <span class="text-[9px] font-mono text-stone-400">
                    v{product.version || "1.0.0"}
                  </span>
                </div>

                <!-- Product Title -->
                <h3 class="text-sm sm:text-base font-bold text-stone-900 mb-0.5 group-hover:text-[#C3A575] transition-colors">
                  <a href={`/products/${product.slug}`} class="text-inherit hover:underline">
                    {product.name}
                  </a>
                </h3>
                
                <p class="text-[11px] sm:text-xs text-stone-500 leading-relaxed mb-3 line-clamp-2">
                  {product.shortDescription || product.description}
                </p>

                <!-- Technical Spec Table (Compact) -->
                <div class="border-y border-stone-100 py-2 mb-3">
                  <div class="grid grid-cols-2 gap-y-1.5 text-[10px]">
                    <div class="text-stone-400">Target Platform</div>
                    <div class="text-stone-700 text-right font-medium truncate max-w-[130px] ml-auto">{product.platforms?.join(', ') || "Universal Desktop"}</div>

                    <div class="text-stone-400">Encryption</div>
                    <div class="text-stone-700 text-right font-medium">TLS 1.3 / AES-256</div>

                    <div class="text-stone-400">Formats Supported</div>
                    <div class="text-stone-700 text-right font-medium truncate max-w-[130px] ml-auto" title={product.supportedFormats?.join(', ')}>
                      {product.supportedFormats?.slice(0, 3).join(', ') || "PST, EML, MSG"}
                    </div>
                  </div>
                </div>

                <!-- Key Features List -->
                <div class="mb-4">
                  <div class="text-[9px] font-mono uppercase tracking-wider text-stone-400 mb-1.5">Engine Features</div>
                  <ul class="space-y-1 text-[11px] text-stone-600">
                    {product.features?.slice(0, 2).map((feat: string) => (
                      <li class="flex items-center gap-1.5">
                        <span class="text-[#C3A575] text-[9px]">✓</span>
                        <span class="truncate">{feat}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Pricing and Actions Footer -->
              <div class="border-t border-stone-100 pt-3 mt-auto flex items-center justify-between">
                <div>
                  <div class="text-[8px] uppercase tracking-wider text-stone-400">Starting Price</div>
                  <div class="text-base font-bold text-stone-900">${lowestPaidPrice.toFixed(2)}</div>
                </div>
                <div class="flex items-center gap-1.5">
                  <a href={`/download?product=${product.slug}`} class="btn btn-outline py-1.5 px-2.5 text-[11px] min-h-[30px] flex items-center justify-center font-semibold">
                    Trial
                  </a>
                  <a href={`/checkout?product=${product.slug}&tier=Standard`} class="btn btn-primary py-1.5 px-2.5 text-[11px] min-h-[30px] flex items-center justify-center font-semibold">
                    Buy Key
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-12 text-stone-500 font-medium text-xs italic">
        <p>Featured utilities loading... Please verify database backend status.</p>
      </div>
    )}
  </div>
</section>

<!-- Section III: High-Visibility Pricing & Tiers -->
{featured.length > 0 && (
  <section class="bg-white py-10 md:py-12 border-b border-stone-200">
    <div class="container-custom max-w-5xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[10px] tracking-wider text-[#C3A575] uppercase font-bold block">Flexible Licensing</span>
        <h2 class="text-xl md:text-2xl font-bold text-stone-900 mt-1">Direct Licensing Plans</h2>
        <p class="text-xs text-stone-500 mt-1">Select the ideal tier for {featured[0].name}. One-time purchase, lifetime validity.</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        {featured[0].pricing?.map((tier: any) => (
          <div class={`bg-white border rounded-lg p-4 sm:p-5 flex flex-col justify-between relative ${tier.popular ? 'border-[#C3A575] shadow-sm ring-1 ring-[#C3A575]/25' : 'border-stone-200'}`}>
            {tier.popular && (
              <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-[#C3A575] text-stone-950 text-[9px] uppercase tracking-wider font-extrabold px-2 py-0.5 rounded">
                Popular
              </span>
            )}
            <div>
              <div class="text-xs font-bold text-stone-950 mb-0.5">{tier.name}</div>
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-xl sm:text-2xl font-black text-stone-900">${tier.price}</span>
                {tier.originalPrice && <span class="text-[11px] text-stone-400 line-through">${tier.originalPrice}</span>}
                <span class="text-[9px] text-stone-500 capitalize">/ {tier.period}</span>
              </div>
              
              <ul class="space-y-1 mb-5 text-[11px] text-stone-600 border-t border-stone-100 pt-3">
                {tier.features?.map((f: string) => (
                  <li class="flex items-center gap-1.5">
                    <span class="text-[#C3A575] font-semibold text-[9px]">✓</span>
                    <span class="truncate">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <a
              href={tier.price === 0 ? `/download?product=${featured[0].slug}` : `/checkout?product=${featured[0].slug}&tier=${encodeURIComponent(tier.name)}`}
              class={`btn w-full text-center text-xs py-1.5 font-semibold ${tier.popular ? 'btn-primary bg-[#0C0A09]' : 'btn-outline'}`}
            >
              {tier.cta || (tier.price === 0 ? "Download Trial" : "Acquire License")}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Section IV: Category Suites -->
{categories.length > 0 && (
  <section class="bg-stone-50/10 py-10 border-b border-stone-200">
    <div class="container-custom max-w-5xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[10px] tracking-wider text-[#C3A575] uppercase font-bold block">Classifications</span>
        <h2 class="text-xl font-bold text-stone-900 mt-1">Curated Suites</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {categories.map((cat: Category) => (
          <a
            href={`/products?category=${cat.id}`}
            class="group bg-white border border-stone-200 p-4 sm:p-5 rounded-lg transition-all duration-300 hover:border-[#C3A575] hover:shadow-sm flex flex-col justify-between min-h-[140px] relative overflow-hidden"
          >
            <div class="flex justify-between items-start mb-2.5">
              <span class="text-xl text-stone-500 group-hover:scale-110 transition-transform">{iconMap[cat.icon] || "📦"}</span>
              <span class="text-[9px] uppercase tracking-wider text-stone-500 bg-stone-100 px-1.5 py-0.5 rounded font-mono font-medium">
                {cat.count} files
              </span>
            </div>
            
            <div class="space-y-0.5">
              <h3 class="text-xs sm:text-sm font-bold text-stone-900 group-hover:text-[#C3A575] transition-colors">
                {cat.label}
              </h3>
              <p class="text-[11px] text-stone-500 leading-relaxed line-clamp-2">
                {cat.description}
              </p>
            </div>
            
            <div class="flex items-center gap-1 text-[9px] uppercase tracking-wider font-semibold text-[#C3A575] pt-2.5 mt-2.5 border-t border-stone-100">
              Discover suite →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Section V: Guest Reviews (Endorsements) -->
<section class="bg-white py-10 border-b border-stone-200">
  <div class="container-custom max-w-5xl mx-auto px-4">
    <div class="text-center mb-8">
      <span class="text-[10px] tracking-wider text-[#C3A575] uppercase font-bold block">Verified Log</span>
      <h2 class="text-xl font-bold text-stone-900 mt-1">Endorsements</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {testimonials.map((t: Testimonial) => (
        <div class="bg-stone-50/20 border border-stone-200 p-5 rounded-lg relative flex flex-col justify-between min-h-[180px] shadow-sm">
          <div>
            <span class="text-3xl font-serif text-[#C3A575]/20 block -mt-2 -ml-1 select-none">“</span>
            <p class="text-[11px] leading-relaxed text-stone-600 italic mb-3">
              {t.content}
            </p>
          </div>
          <div class="flex items-center gap-2 pt-3 border-t border-stone-100">
            <div class="w-6.5 h-6.5 rounded-full bg-stone-900 flex items-center justify-center text-white text-[10px] font-bold">
              {t.author.charAt(0)}
            </div>
            <div>
              <div class="text-[11px] font-bold text-stone-900 leading-none">{t.author}</div>
              <div class="text-[8px] uppercase tracking-wider text-stone-400 mt-0.5 leading-none">{t.role}, {t.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Acquisition Portal CTA -->
<section class="bg-stone-900 py-12 relative overflow-hidden border-t border-[#C3A575]/20">
  <!-- Subtle Amber Backlight -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[150px] bg-[#C3A575]/10 blur-[80px] rounded-full"></div>
  </div>

  <div class="container-custom relative z-10 text-center max-w-3xl mx-auto px-4">
    <!-- Fine inner border trim -->
    <div class="border border-stone-800 p-6 md:p-10 relative bg-stone-950/40 backdrop-blur rounded-xl">
      <div class="absolute top-2 left-2 text-[#C3A575]/20 text-[10px] font-mono">+</div>
      <div class="absolute top-2 right-2 text-[#C3A575]/20 text-[10px] font-mono">+</div>
      <div class="absolute bottom-2 left-2 text-[#C3A575]/20 text-[10px] font-mono">+</div>
      <div class="absolute bottom-2 right-2 text-[#C3A575]/20 text-[10px] font-mono">+</div>

      <span class="text-[9px] tracking-widest text-[#C3A575] uppercase font-bold block mb-2">Acquisition Portal</span>
      <h2 class="text-xl md:text-2xl text-stone-50 font-bold mb-3 leading-tight">
        Acquire On-Premises Infrastructure
      </h2>
      <p class="text-[11px] text-stone-400 leading-relaxed max-w-md mx-auto mb-6">
        Evaluate your environments locally without financial commitment. Acquire standard or enterprise license keys when production deployment requirements arise.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/download" class="btn btn-accent w-full sm:w-[150px] text-xs font-semibold py-2">
          Download Trial
        </a>
        <a href="/products" class="btn btn-ghost-white w-full sm:w-[150px] text-xs font-semibold py-2">
          Browse Collection
        </a>
      </div>
    </div>
  </div>
</section>
