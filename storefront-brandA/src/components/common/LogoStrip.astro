---
interface Props {
  logos: Array<{ companyName: string; logoUrl: string }>;
}

const { logos = [] } = Astro.props;
---

{logos.length > 0 && (
  <div class="py-12 border-y border-[--color-hairline] bg-[--color-surface] overflow-hidden relative flex flex-col items-center">
    <p class="text-sm font-medium text-zinc-500 mb-6 uppercase tracking-widest">Trusted by Innovative Teams Worldwide</p>
    
    <div class="flex w-full overflow-hidden relative">
      <div class="flex w-max animate-marquee space-x-16 px-8 items-center opacity-70 hover:opacity-100 transition-opacity">
        {logos.map((logo) => (
          <img src={logo.logoUrl} alt={logo.companyName} class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" />
        ))}
        {/* Duplicate for seamless looping */}
        {logos.map((logo) => (
          <img src={logo.logoUrl} alt={logo.companyName} class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" />
        ))}
      </div>
    </div>
  </div>
)}

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
</style>
