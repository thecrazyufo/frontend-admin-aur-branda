---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SettingsAPI, ProductAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "Prism Migration";

// Parse product slug from URL search parameters
const productSlug = Astro.url.searchParams.get("product");
let product = null;
if (productSlug) {
  product = await ProductAPI.getBySlug(productSlug).catch(() => null);
}

// Try to fetch custom content, fallback to default premium welcome content if empty
const hasCustomContent = !!settings?.legalPages?.["thank-you-install"];
const htmlContent = settings?.legalPages?.["thank-you-install"];
---

<BaseLayout
  title={`Thank You for Installing — ${siteName}`}
  description="Your software installation was completed successfully. Get started with your data migration journey today."
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center py-20 bg-[#0B0F1A] relative overflow-hidden tech-grid">
    <!-- Background accents -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute -top-[10%] left-[50%] -translate-x-1/2 w-[600px] h-[300px] bg-[#6366F1]/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="container-custom max-w-3xl mx-auto px-4 relative z-10">
      {hasCustomContent ? (
        <div 
          class="bg-[#1E2937]/30 backdrop-blur-xl border border-[#334155] p-8 md:p-12 rounded-3xl shadow-2xl prose prose-invert max-w-none prose-headings:text-white prose-p:text-[#E2E8F0] prose-a:text-[#6366F1] hover:prose-a:underline"
          set:html={htmlContent}
        />
      ) : (
        <div class="bg-[#1E2937]/30 backdrop-blur-xl border border-[#334155] p-8 md:p-12 rounded-3xl shadow-2xl text-center space-y-8">
          <!-- Animated Checkmark SVG -->
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#6366F1]/10 border border-[#6366F1]/20 text-[#6366F1] mb-2 animate-pulse">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>

          <div class="space-y-3">
            <h1 class="text-3xl md:text-3xl font-extrabold text-white tracking-tight">
              {product ? `${product.name} Installed!` : "Installation Completed!"}
            </h1>
            <p class="text-[#94A3B8] text-sm md:text-base max-w-md mx-auto">
              Thank you for choosing <span class="text-[#6366F1] font-bold">{product ? product.name : siteName}</span>. Your application has been successfully installed and is ready for use.
            </p>
          </div>

          <!-- Getting Started Steps -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-left pt-6 max-w-2xl mx-auto">
            <div class="p-5 bg-[#0B0F1A]/40 rounded-xl border border-[#334155] space-y-2">
              <span class="text-xs font-bold text-[#6366F1] uppercase tracking-wider">Step 1</span>
              <h3 class="text-white font-semibold text-sm">Launch Tool</h3>
              <p class="text-stone-500 text-xs leading-relaxed">Open the software application from your desktop or applications folder.</p>
            </div>
            <div class="p-5 bg-[#0B0F1A]/40 rounded-xl border border-[#334155] space-y-2">
              <span class="text-xs font-bold text-[#6366F1] uppercase tracking-wider">Step 2</span>
              <h3 class="text-white font-semibold text-sm">Activate License</h3>
              <p class="text-stone-500 text-xs leading-relaxed">Enter your license key received via email to activate premium features.</p>
            </div>
            <div class="p-5 bg-[#0B0F1A]/40 rounded-xl border border-[#334155] space-y-2">
              <span class="text-xs font-bold text-[#6366F1] uppercase tracking-wider">Step 3</span>
              <h3 class="text-white font-semibold text-sm">Start Migrating</h3>
              <p class="text-stone-500 text-xs leading-relaxed">Follow the step-by-step wizard interface to begin your data transfer.</p>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-6">
            <a 
              href={product ? `/products/${product.slug}/guide` : "/help"} 
              class="w-full sm:w-auto px-6 py-3 bg-[#6366F1] hover:bg-[#4F46E5] text-black font-semibold rounded-lg text-sm transition-all duration-200 transform hover:scale-[1.02]"
            >
              {product ? `How to Use ${product.name}` : "Get Started Guide"}
            </a>
            <a 
              href="/contact" 
              class="w-full sm:w-auto px-6 py-3 bg-[#1E2937] border border-[#334155] hover:border-stone-700 text-white font-semibold rounded-lg text-sm transition-all duration-200"
            >
              Contact Support
            </a>
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
