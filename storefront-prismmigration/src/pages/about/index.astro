---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/common/SectionHeader";
import { Users, Globe, Award, TrendingUp } from "lucide-react";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

const siteStats = settings?.stats?.map((s: any, idx: number) => ({
  value: s.value,
  label: s.label,
  icon: ["TrendingUp", "Globe", "Award", "Users"][idx] || "TrendingUp"
})) || [
  { value: "1M+", label: "Total Downloads", icon: "TrendingUp" },
  { value: "150+", label: "Countries", icon: "Globe" },
  { value: "15+", label: "Years Experience", icon: "Award" },
  { value: "50K+", label: "Enterprise Clients", icon: "Users" },
];

const team = settings?.teamMembers || [
  { name: "Michael Ross", role: "CEO & Co-Founder", bio: "15+ years in enterprise data migration. Former Microsoft engineer.", initials: "MR" },
  { name: "Jessica Chen", role: "CTO & Co-Founder", bio: "Expert in distributed systems and data integrity algorithms.", initials: "JC" },
  { name: "David Kumar", role: "Head of Product", bio: "Passionate about building tools that solve real IT problems.", initials: "DK" },
  { name: "Sarah Williams", role: "Head of Support", bio: "Dedicated to ensuring every customer succeeds with our tools.", initials: "SW" },
];

const siteName = settings?.name || "";
const siteDescription = settings?.description || "";
---

<BaseLayout
  title={`About Us — ${siteName}`}
  description={`Learn about ${siteName}, our mission, leadership team, and why over 1 million IT professionals worldwide trust our data migration and file conversion tools.`}
>
  <div>
    {/* Hero */}
    <section class="bg-[#0F172A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#14B8A6]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[#14B8A6] bg-[#14B8A6]/15 border border-[#14B8A6]/25">About Us</span>
        <h1 class="text-white font-extrabold text-[#E2E8F0]xl md:text-[#94A3B8]xl tracking-tight mb-4 max-w-3xl mx-auto leading-tight">
          Trusted by IT Professionals Across the Globe
        </h1>
        <p class="text-[#E2E8F0] max-w-xl mx-auto text-xs leading-relaxed">
          We build the world's most reliable email migration and data management software — because your data is priceless.
        </p>
      </div>
    </section>

    {/* Stats */}
    <section class="py-20 bg-[#0F172A] border-b border-[#334155]">
      <div class="container-custom">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {siteStats.map((stat) => (
            <div class="text-center p-6 rounded-xl bg-[#1E2937]/30 border border-[#334155] backdrop-blur">
              <div class="flex justify-center text-[#14B8A6] mb-3 text-[#E2E8F0]xl">
                {stat.icon === "TrendingUp" && <TrendingUp size={24} />}
                {stat.icon === "Globe" && <Globe size={24} />}
                {stat.icon === "Award" && <Award size={24} />}
                {stat.icon === "Users" && <Users size={24} />}
              </div>
              <div class="text-[#E2E8F0]xl font-extrabold text-white mb-1">{stat.value}</div>
              <div class="text-xs text-[#94A3B8] font-semibold uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Mission */}
    <section class="py-20 bg-[#0F172A] border-b border-[#334155]">
      <div class="container-custom max-w-3xl text-center">
        <SectionHeader eyebrow="Our Mission" title="Data Migration Should Be Simple, Safe & Reliable" centered class="mb-8" />
        <p class="text-xs text-[#E2E8F0] leading-relaxed mb-6">
          Founded in 2010, {siteName} started with a simple mission: help IT professionals migrate data without the fear of data loss.
          What began as a single file converter has grown into a comprehensive suite of tools used by IT teams worldwide.
        </p>
        <p class="text-xs text-[#E2E8F0] leading-relaxed">
          Every tool we build goes through rigorous testing with millions of emails before release. We don't ship until we're confident
          that your data will be 100% intact on the other side.
        </p>
      </div>
    </section>

    {/* Team */}
    <section class="py-20 bg-[#0F172A]">
      <div class="container-custom">
        <SectionHeader eyebrow="Team" title="Meet Our Leadership" centered class="mb-12" />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {team.map((member) => (
            <div class="text-center bg-[#1E2937]/30 backdrop-blur rounded-xl p-6 border border-[#334155] hover:border-[#14B8A6]/30 transition-all duration-300">
              <div class="w-16 h-16 rounded-xl bg-[#0F172A] border border-[#334155] flex items-center justify-center text-[#14B8A6] text-lg font-bold mx-auto mb-4 shadow-md">
                {member.initials}
              </div>
              <h3 class="font-bold text-white mb-1">{member.name}</h3>
              <p class="text-xs text-[#14B8A6] font-semibold mb-2">{member.role}</p>
              <p class="text-xs text-[#94A3B8] leading-relaxed">{member.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
