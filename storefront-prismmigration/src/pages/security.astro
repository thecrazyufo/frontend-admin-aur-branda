---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/common/SectionHeader";
import { Shield, Lock, FileKey, CheckCircle2 } from "lucide-react";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

const trustBadges = settings?.trustBadges || [
  { emoji: "🔐", title: "256-bit Encryption", desc: "All data is encrypted in transit and at rest.", color: "text-blue-600 bg-blue-50" },
  { emoji: "🛡️", title: "GDPR Compliant", desc: "Strict adherence to global data privacy laws.", color: "text-emerald-600 bg-emerald-50" },
  { emoji: "⚡", title: "Zero Data Retention", desc: "We never store your migrated files post-transfer.", color: "text-purple-600 bg-purple-50" },
  { emoji: "🏢", title: "SOC 2 Type II", desc: "Audited security controls for enterprise trust.", color: "text-indigo-600 bg-indigo-50" },
];

const siteName = settings?.name || "Our Platform";
---

<BaseLayout
  title={`Security Center — ${siteName}`}
  description={`Learn how ${siteName} secures your enterprise data, protects your privacy, and maintains compliance with global standards.`}
>
  <div>
    {/* Hero */}
    <section class="bg-[#0B0F1A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] blur-[90px] rounded-full" style="background: rgba(0,200,160,0.05);"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest mb-6 px-3 py-1.5 rounded-full text-emerald-300 bg-emerald-950/40 border border-emerald-500/20 backdrop-blur-md">
          <Shield size={14} /> Enterprise-Grade Security
        </span>
        <h1 class="text-white font-extrabold mb-6 max-w-4xl mx-auto leading-tight text-3xl md:text-4xl tracking-tight">
          Your Data Privacy is Our Highest Priority.
        </h1>
        <p class="text-[#E2E8F0] max-w-2xl mx-auto text-xs leading-relaxed">
          We engineer our software with a zero-trust architecture, ensuring that your migrations, conversions, and recoveries happen entirely under your control.
        </p>
      </div>
    </section>

    {/* Trust Badges Grid */}
    <section class="py-20 bg-[#0B0F1A] border-b border-[#334155] relative -mt-8">
      <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          {trustBadges.map((badge: any) => (
            <!-- Certificate Panel (security page signature) -->
            <div class="relative overflow-hidden rounded-xl p-5 border flex flex-col transition-all duration-300" style="border-color: var(--circuit-line); background: var(--slate-surface); border-left: 3px solid var(--signal-teal);" onmouseover="this.style.borderColor='rgba(0,200,160,0.4)'" onmouseout="this.style.borderColor='var(--circuit-line)'">
              <!-- STATUS: VERIFIED tag -->
              <div class="flex items-center justify-between mb-3">
                <span class="text-3xl">{badge.emoji}</span>
                <span style="font-family: var(--font-mono); font-size: 0.55rem; color: var(--signal-teal); letter-spacing: 0.06em; background: rgba(0,200,160,0.08); padding: 2px 6px; border-radius: 3px; border: 1px solid rgba(0,200,160,0.2);">STATUS: VERIFIED</span>
              </div>
              <h3 style="color: var(--type-light); font-weight: 700; font-size: 0.8rem; margin-bottom: 6px;">{badge.title}</h3>
              <p style="color: var(--type-muted); font-size: 0.7rem; line-height: 1.5;">{badge.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Core Commitments */}
    <section class="py-20 bg-[#0B0F1A] border-b border-[#334155]">
      <div class="container-custom max-w-4xl">
        <SectionHeader 
          title="Our Core Commitments" 
          subtitle="How we protect your business from data breaches and compliance risks."
          align="center"
        />

        <div class="space-y-12 mt-16">
          {/* Commitment 1 */}
          <div class="flex gap-6 md:gap-8 flex-col md:flex-row">
            <div class="shrink-0">
              <div class="w-14 h-14 rounded-xl flex items-center justify-center border shadow-inner" style="background: rgba(0,200,160,0.08); color: var(--signal-teal); border-color: rgba(0,200,160,0.2);">
                <Lock size={28} />
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-3">End-to-End Encryption</h3>
              <p class="text-xs text-[#E2E8F0] leading-relaxed mb-4">
                Whether you are migrating Microsoft Exchange databases or converting local PST files, all temporary data caches are encrypted using AES-256 military-grade encryption. Network transmissions are strictly enforced over TLS 1.3 to prevent man-in-the-middle attacks.
              </p>
              <ul class="space-y-2">
                <li class="flex items-center gap-2 text-xs font-semibold text-[#E2E8F0]">
                  <CheckCircle2 size={16} class="text-emerald-500" /> AES-256 Storage Encryption
                </li>
                <li class="flex items-center gap-2 text-xs font-semibold text-[#E2E8F0]">
                  <CheckCircle2 size={16} class="text-emerald-500" /> TLS 1.3 Transport Security
                </li>
              </ul>
            </div>
          </div>

          {/* Commitment 2 */}
          <div class="flex gap-6 md:gap-8 flex-col md:flex-row">
            <div class="shrink-0">
              <div class="w-14 h-14 rounded-xl flex items-center justify-center border shadow-inner" style="background: rgba(0,200,160,0.08); color: var(--signal-teal); border-color: rgba(0,200,160,0.2);">
                <FileKey size={28} />
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-3">On-Premise Privacy Engine</h3>
              <p class="text-xs text-[#E2E8F0] leading-relaxed mb-4">
                Unlike cloud-only solutions that upload your sensitive emails to third-party servers, our desktop software processes all data directly on your local machine or dedicated server. Your data never leaves your environment.
              </p>
              <ul class="space-y-2">
                <li class="flex items-center gap-2 text-xs font-semibold text-[#E2E8F0]">
                  <CheckCircle2 size={16} class="text-emerald-500" /> 100% Local Processing Options
                </li>
                <li class="flex items-center gap-2 text-xs font-semibold text-[#E2E8F0]">
                  <CheckCircle2 size={16} class="text-emerald-500" /> No Telemetry Data Harvesting
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-20 bg-[#0B0F1A] text-center">
      <div class="container-custom max-w-3xl">
        <h2 class="text-3xl font-bold text-white mb-6">Need a custom DPA or SOC 2 Report?</h2>
        <p class="text-[#E2E8F0] mb-8 text-xs leading-relaxed">
          Our enterprise compliance team is ready to assist your procurement department with custom Data Processing Agreements and security questionnaires.
        </p>
        <a href="/contact" class="bg-[#6366F1] hover:bg-[#4F46E5] text-white font-extrabold text-xs py-3 px-6 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(99, 102, 241,0.25)]">
          Contact Compliance Team
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
