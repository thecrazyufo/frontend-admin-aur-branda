---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI } from "@/services/api";
import SectionHeader from "@/components/common/SectionHeader";
import { generateFAQSchema } from "@/lib/seo";
import { Check, CreditCard, HelpCircle, ShieldCheck } from "lucide-react";

const settings = await SettingsAPI.get().catch(() => null);

const dynamicFaqs = settings?.pricingFaqs || [
  { question: "How does licensing work?", answer: "We offer flexible licensing tiers tailored for different needs. Each license tier specifies its own validity period and features on the product page." },
  { question: "Is there a free trial?", answer: "Yes! Every product has a free trial that lets you migrate/convert up to 50 items to verify functionality." },
  { question: "What is your refund policy?", answer: "We offer a 30-day money-back guarantee if the software does not perform as described." },
  { question: "How are updates delivered?", answer: "You will receive updates during the active period of your license. Lifetime licenses receive lifetime updates." },
];

let groupedProducts = [];
let errorLoading = false;

try {
  const [productsList, categoriesList] = await Promise.all([
    ProductAPI.getAll(),
    CategoryAPI.getAll(),
  ]);

  const enabledProducts = productsList.filter(p => p.enabled !== false);

  groupedProducts = categoriesList.map(cat => {
    const productsInCategory = enabledProducts.filter(p => p.category === cat.id);
    return {
      category: cat,
      products: productsInCategory
    };
  }).filter(group => group.products.length > 0);
} catch (e) {
  console.error("Error loading products for pricing:", e);
  errorLoading = true;
}

const getLowestPaidPlan = (product: any) => {
  if (!product.pricing || product.pricing.length === 0) return null;
  const paidTiers = product.pricing.filter((t: any) => t.price > 0);
  if (paidTiers.length === 0) return null;
  return paidTiers.reduce((lowest: any, current: any) => current.price < lowest.price ? current : lowest, paidTiers[0]);
};
---

<BaseLayout
  title={`Pricing Catalog — ${settings?.name || ""}`}
  description="Transparent pricing directory for all our software tools. Free trials, standard, and enterprise licensing plans available."
>
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQSchema(dynamicFaqs))} />

  {/* Header */}
  <section class="bg-[#F8FAFC] py-16 text-center tech-grid border-b border-[#E2E8F0] relative overflow-hidden">
    <!-- Ambient refraction glow background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#F97316]/5 blur-[90px] rounded-full"></div>
    </div>

    <div class="container-custom relative z-10">
      <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-[#F97316] bg-[#F97316]/15 border border-[#F97316]/25 px-3 py-1 rounded mb-4">
        Pricing Directory
      </span>
      <h1 class="text-white font-extrabold text-[#0F172A]xl md:text-[#0F172A]xl tracking-tight mb-4">Flexible Licensing Options</h1>
      <p class="text-[#E5E5E5] max-w-xl mx-auto leading-relaxed text-xs">
        Select a tool from our catalog to view its specific pricing tiers, user allocations, and support periods.
      </p>
    </div>
  </section>

  {/* Pricing Directory Catalog */}
  <section class="bg-[#F8FAFC] py-16 relative min-h-[400px]">
    <div class="container-custom">
      {errorLoading ? (
        <div class="text-center py-20 bg-white/10 rounded-2xl border border-[#E2E8F0] p-8">
          <p class="text-[#0F172A] text-sm">Unable to load pricing catalog. Please verify that your system backend is online.</p>
        </div>
      ) : groupedProducts.length > 0 ? (
        <div class="space-y-16 max-w-5xl mx-auto">
          {groupedProducts.map(group => (
            <div>
              <h2 class="text-xs font-bold text-white uppercase tracking-wider mb-6 border-b border-[#E2E8F0] pb-3 flex items-center gap-2">
                <span class="text-[#F97316]">{group.category.label}</span>
                <span class="text-[10px] text-[#475569] font-mono font-semibold">({group.products.length} {group.products.length !== 1 ? 'tools' : 'tool'})</span>
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {group.products.map(p => {
                  const plan = getLowestPaidPlan(p);
                  return (
                    <div class="bg-white/20 backdrop-blur rounded-xl border border-[#E2E8F0] p-5 hover:border-[#F97316]/20 transition-all duration-300 flex flex-col justify-between shadow-lg">
                      <div>
                        <h3 class="font-bold text-white text-sm mb-1.5 tracking-tight">{p.name}</h3>
                        <p class="text-[11px] text-[#475569] leading-relaxed mb-4 line-clamp-2">{p.shortDescription}</p>
                      </div>
                      
                      <div class="flex items-center justify-between mt-4 pt-4 border-t border-[#E2E8F0]/40">
                        <div>
                          {plan ? (
                            <>
                              <span class="text-[9px] text-[#475569] uppercase tracking-wider font-semibold block">Starts at</span>
                              <div class="flex items-baseline gap-0.5">
                                <span class="text-base font-extrabold text-white">${plan.price}</span>
                                <span class="text-[9px] text-[#475569] font-mono font-medium">/{plan.period}</span>
                              </div>
                            </>
                          ) : (
                            <span class="text-[#475569] text-[11px] font-semibold">Free / Contact Us</span>
                          )}
                        </div>
                        <a href={`/products/${p.slug}`} class="bg-[#F97316]/10 hover:bg-[#F97316]/20 text-[#F97316] border border-[#F97316]/20 text-[10px] font-extrabold uppercase tracking-wider py-2 px-3.5 rounded transition-all duration-300">
                          View Tiers
                        </a>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-white/10 rounded-2xl border border-[#E2E8F0] p-8 max-w-lg mx-auto">
          <p class="text-[#0F172A] text-sm">No products found in the catalog index.</p>
        </div>
      )}

      {/* Guarantees Strip */}
      <div class="mt-20 flex flex-wrap items-center justify-center gap-8 py-6 border-t border-[#E2E8F0] text-[11px] text-[#0F172A] font-mono">
        <div class="flex items-center gap-2">
          <ShieldCheck size={14} class="text-[#F97316]" />
          30-Day Money-Back Guarantee
        </div>
        <div class="flex items-center gap-2">
          <CreditCard size={14} class="text-[#F97316]" />
          Secure Payment Processing
        </div>
        <div class="flex items-center gap-2">
          <HelpCircle size={14} class="text-[#F97316]" />
          Free Setup Assistance
        </div>
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="bg-[#F8FAFC] py-16 border-t border-[#E2E8F0] tech-grid">
    <div class="container-custom max-w-3xl">
      <SectionHeader eyebrow="FAQ" title="Licensing FAQ" centered class="mb-10" />

      <div class="space-y-4">
        {dynamicFaqs.map((faq) => (
          <div class="bg-white/30 backdrop-blur rounded-xl border border-[#E2E8F0] p-6 shadow-2xl hover:border-[#F97316]/30 transition-colors">
            <h3 class="font-bold text-white text-sm mb-2">{faq.question}</h3>
            <p class="text-xs text-[#E5E5E5] leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
