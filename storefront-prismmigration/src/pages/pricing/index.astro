---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, SettingsAPI } from "@/services/api";
import PricingCard from "@/components/common/PricingCard";
import SectionHeader from "@/components/common/SectionHeader";
import { generateFAQSchema } from "@/lib/seo";
import { Check, X } from "lucide-react";

const settings = await SettingsAPI.get().catch(() => null);

const dynamicFaqs = settings?.pricingFaqs || [
  { question: "Do I need a subscription?", answer: "No. All our tools use a one-time payment model. Pay once, use forever." },
  { question: "Is there a free trial?", answer: "Yes! Every product has a free trial that lets you migrate/convert up to 50 items." },
  { question: "What if I'm not satisfied?", answer: "We offer a 30-day money-back guarantee. No questions asked." },
  { question: "Do I get free updates?", answer: "Standard plans include 1 year of free updates. Enterprise/Business plans include lifetime updates." },
];

const dynamicComparison = settings?.pricingComparison || [
  { feature: "Email Migration", trial: "50 emails", standard: "Unlimited", enterprise: "Unlimited" },
  { feature: "Contacts & Calendar", trial: true, standard: true, enterprise: true },
  { feature: "Folder Structure", trial: true, standard: true, enterprise: true },
  { feature: "Batch Migration", trial: false, standard: false, enterprise: true },
  { feature: "Delta Migration", trial: false, standard: true, enterprise: true },
  { feature: "Number of Licenses", trial: "1", standard: "1", enterprise: "25" },
  { feature: "Free Updates", trial: false, standard: "1 Year", enterprise: "Lifetime" },
  { feature: "Technical Support", trial: "Email", standard: "Priority Email", enterprise: "24/7 Phone & Chat" },
  { feature: "Price", trial: "Free", standard: "$49", enterprise: "$199" },
];

let flagship = null;

try {
  const productsList = await ProductAPI.getAll();
  if (productsList.length > 0) {
    flagship = productsList[0];
  }
} catch (e) {
  console.error("Error loading products for pricing:", e);
}
---

<BaseLayout
  title={`Pricing Plans — ${settings?.name || ""}`}
  description="Transparent pricing for all our software tools. Free trial available. One-time payment, lifetime license. 30-day money-back guarantee."
>
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQSchema(dynamicFaqs))} />

  {/* Header */}
  <section class="bg-[#0A0A0A] py-16 text-center tech-grid border-b border-stone-900 relative overflow-hidden">
    <!-- Ambient refraction glow background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#EAB308]/5 blur-[90px] rounded-full"></div>
    </div>

    <div class="container-custom relative z-10">
      <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-[#EAB308] bg-[#EAB308]/15 border border-[#EAB308]/25 px-3 py-1 rounded mb-4">
        Simple Pricing
      </span>
      <h1 class="text-white font-extrabold text-3xl md:text-4xl tracking-tight mb-4">One-Time Purchase. Lifetime Validity.</h1>
      <p class="text-[#E5E5E5] max-w-xl mx-auto leading-relaxed text-xs">
        No subscriptions. No hidden fees. Choose your plan and own the software.
        All plans include free technical support.
      </p>
    </div>
  </section>

  {/* Flagship Pricing */}
  {flagship && (
    <section class="bg-[#0A0A0A] py-16 tech-grid relative">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="text-[10px] tracking-wider text-[#EAB308] uppercase font-bold block">Enterprise Licensing</span>
          <h2 class="text-xl md:text-2xl font-bold text-white mt-1">Direct Licensing Plans</h2>
          <p class="text-xs text-stone-400 mt-1">Acquire on-premises keys for high-velocity database and folder migration.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto items-stretch">
          {(flagship.pricing || []).map((tier) => (
            <PricingCard tier={tier} productSlug={flagship.slug} />
          ))}
        </div>

        {/* Guarantees */}
        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-xs text-stone-300 font-mono">
          {["30-Day Money-Back Guarantee", "No Subscription Required", "Free Technical Support", "Secure Payment"].map((g) => (
            <div class="flex items-center gap-2">
              <Check size={14} class="text-[#EAB308]" />
              {g}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Feature Comparison Table */}
  <section class="bg-[#0A0A0A] py-16 border-t border-stone-900 tech-grid">
    <div class="container-custom">
      <div class="text-center mb-10">
        <span class="text-[10px] tracking-wider text-[#EAB308] uppercase font-bold block">Compare Tiers</span>
        <h2 class="text-xl font-bold text-white mt-1">Plan Comparison Matrix</h2>
      </div>

      <div class="overflow-x-auto max-w-4xl mx-auto rounded-xl border border-stone-900 bg-stone-900/10 backdrop-blur shadow-2xl">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="border-b border-stone-900 bg-stone-950/40">
              <th class="text-left py-4 px-6 font-semibold text-white w-1/2">Feature</th>
              <th class="py-4 px-4 font-semibold text-stone-300 text-center">Free Trial</th>
              <th class="py-4 px-4 font-semibold text-[#EAB308] bg-[#EAB308]/5 text-center">Standard</th>
              <th class="py-4 px-4 font-semibold text-stone-300 text-center">Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {dynamicComparison.map((row, i) => (
              <tr class={`border-b border-stone-900/60 ${i % 2 === 0 ? "bg-stone-900/10" : ""}`}>
                <td class="py-4 px-6 font-medium text-white">{row.feature}</td>
                <td class="py-4 px-4 text-center text-stone-300">
                  {typeof row.trial === "boolean"
                    ? row.trial ? <Check size={15} class="text-emerald-500 mx-auto" /> : <X size={15} class="text-stone-600 mx-auto" />
                    : row.trial}
                </td>
                <td class="py-4 px-4 text-center text-[#EAB308] bg-[#EAB308]/5 font-semibold">
                  {typeof row.standard === "boolean"
                    ? row.standard ? <Check size={15} class="text-[#EAB308] mx-auto" /> : <X size={15} class="text-stone-600 mx-auto" />
                    : row.standard}
                </td>
                <td class="py-4 px-4 text-center text-stone-300">
                  {typeof row.enterprise === "boolean"
                    ? row.enterprise ? <Check size={15} class="text-emerald-500 mx-auto" /> : <X size={15} class="text-stone-600 mx-auto" />
                    : row.enterprise}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* Pricing FAQ */}
  <section class="bg-[#0A0A0A] py-16 border-t border-stone-900 tech-grid">
    <div class="container-custom max-w-3xl">
      <div class="text-center mb-10">
        <span class="text-[10px] tracking-wider text-[#EAB308] uppercase font-bold block">FAQ</span>
        <h2 class="text-xl font-bold text-white mt-1">Licensing FAQ</h2>
      </div>

      <div class="space-y-4">
        {dynamicFaqs.map((faq) => (
          <div class="bg-stone-900/30 backdrop-blur rounded-xl border border-stone-900 p-6 shadow-2xl hover:border-[#EAB308]/30 transition-colors">
            <h3 class="font-bold text-white text-sm mb-2">{faq.question}</h3>
            <p class="text-xs text-[#E5E5E5] leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
