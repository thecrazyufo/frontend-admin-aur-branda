---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI, BrandAPI } from "@/services/api";
import SectionHeader from "@/components/common/SectionHeader";
import { generateFAQSchema } from "@/lib/seo";
import { Check, CreditCard, HelpCircle, ShieldCheck } from "lucide-react";

let settings = null;
let brandConfig = null;
let productsList = [];
let categoriesList = [];
let errorLoading = false;

try {
  [settings, brandConfig, productsList, categoriesList] = await Promise.all([
    SettingsAPI.get().catch(() => null),
    BrandAPI.getCurrentBrand().catch(() => null),
    ProductAPI.getAll().catch(() => []),
    CategoryAPI.getAll().catch(() => []),
  ]);
} catch (e) {
  console.error("Error loading products for pricing:", e);
  errorLoading = true;
}

const dynamicFaqs = settings?.pricingFaqs || [
  { question: "How does licensing work?", answer: "We offer flexible licensing tiers tailored for different needs. Each license tier specifies its own validity period and features on the product page." },
  { question: "Is there a free trial?", answer: "Yes! Every product has a free trial that lets you migrate/convert up to 50 items to verify functionality." },
  { question: "What is your refund policy?", answer: "We offer a 30-day money-back guarantee if the software does not perform as described." },
  { question: "How are updates delivered?", answer: "You will receive updates during the active period of your license. Lifetime licenses receive lifetime updates." },
];

const enabledProducts = productsList.filter(p => p.enabled !== false);

const groupedProducts = categoriesList.map(cat => {
  const productsInCategory = enabledProducts.filter(p => p.category === cat.id);
  return {
    category: cat,
    products: productsInCategory
  };
}).filter(group => group.products.length > 0);

const getLowestPaidPlan = (product: any) => {
  if (!product.pricing || product.pricing.length === 0) return null;
  const paidTiers = product.pricing.filter((t: any) => t.price > 0);
  if (paidTiers.length === 0) return null;
  return paidTiers.reduce((lowest: any, current: any) => current.price < lowest.price ? current : lowest, paidTiers[0]);
};
---

<BaseLayout
  title={`Pricing Catalog — ${settings?.name || ""}`}
  description="Transparent pricing directory for all our software tools. Free trials, standard, and enterprise licensing plans available."
  settings={settings}
  brandConfig={brandConfig}
  products={productsList}
>
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQSchema(dynamicFaqs))} />

  {/* Header */}
  <section class="bg-[#0B0F1A] py-16 text-center tech-grid border-b relative overflow-hidden" style="border-color: var(--circuit-line); background: var(--ink-void);">
    <!-- Ambient refraction glow background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] blur-[90px] rounded-full" style="background: rgba(0,200,160,0.05);"></div>
    </div>

    <div class="container-custom relative z-10">
      <span class="inline-block text-[10px] font-bold uppercase tracking-widest border px-3 py-1 rounded mb-4" style="color: var(--signal-teal); background: rgba(0,200,160,0.08); border-color: rgba(0,200,160,0.25); font-family: var(--font-mono);">
        Pricing Directory
      </span>
      <h1 class="text-white font-extrabold text-3xl md:text-3xl tracking-tight mb-4" style="font-family: var(--font-display);">Flexible Licensing Options</h1>
      <p class="max-w-xl mx-auto leading-relaxed text-xs" style="color: var(--type-muted);">
        Select a tool from our catalog to view its specific pricing tiers, user allocations, and support periods.
      </p>
    </div>
  </section>

  {/* Pricing Directory Catalog */}
  <section class="py-16 relative min-h-[400px]" style="background: var(--ink-void);">
    <div class="container-custom">
      {errorLoading ? (
        <div class="text-center py-20 rounded-2xl border p-8" style="background: var(--slate-surface); border-color: var(--circuit-line);">
          <p class="text-sm" style="color: var(--type-muted);">Unable to load pricing catalog. Please verify that your system backend is online.</p>
        </div>
      ) : groupedProducts.length > 0 ? (
        <div class="space-y-16 max-w-5xl mx-auto">
          {groupedProducts.map(group => (
            <div>
              <h2 class="text-xs font-bold text-white uppercase tracking-wider mb-6 border-b pb-3 flex items-center gap-2" style="border-color: var(--circuit-line);">
                <span style="color: var(--signal-teal); font-family: var(--font-mono);">{group.category.label}</span>
                <span class="text-[10px] font-mono font-semibold" style="color: var(--type-faint);">({group.products.length} {group.products.length !== 1 ? 'tools' : 'tool'})</span>
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {group.products.map(p => {
                  const plan = getLowestPaidPlan(p);
                  return (
                    <div class="rounded-xl border p-5 transition-all duration-300 flex flex-col justify-between" style="background: var(--slate-surface); border-color: var(--circuit-line);">
                      <div>
                        <h3 class="font-bold text-white text-sm mb-1.5 tracking-tight" style="font-family: var(--font-body);">{p.name}</h3>
                        <p class="text-[11px] leading-relaxed mb-4 line-clamp-2" style="color: var(--type-muted);">{p.shortDescription}</p>
                      </div>
                      
                      <div class="flex items-center justify-between mt-4 pt-4 border-t" style="border-color: rgba(255,255,255,0.06);">
                        <div>
                          {plan ? (
                            <>
                              <span class="text-[9px] uppercase tracking-wider font-semibold block" style="color: var(--type-faint);">Starts at</span>
                              <div class="flex items-baseline gap-0.5">
                                <span class="text-base font-extrabold text-white" style="font-family: var(--font-mono);">${plan.price}</span>
                                <span class="text-[9px] font-mono font-medium" style="color: var(--type-faint);">/ {plan.period}</span>
                              </div>
                            </>
                          ) : (
                            <span class="text-[11px] font-semibold" style="color: var(--type-faint);">Free / Contact Us</span>
                          )}
                        </div>
                        <a href={`/products/${p.slug}`} class="cta-pulse-wrap text-[10px] font-extrabold uppercase tracking-wider py-2 px-3.5 rounded transition-all duration-300 border" style="background: rgba(0,200,160,0.06); color: var(--signal-teal); border-color: rgba(0,200,160,0.25); font-family: var(--font-mono);">
                          View Tiers
                        </a>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 rounded-2xl border p-8 max-w-lg mx-auto" style="background: var(--slate-surface); border-color: var(--circuit-line);">
          <p class="text-sm leading-relaxed" style="color: var(--type-muted);">Fetching license tiers from catalog... If this persists, view individual tools to see pricing.</p>
        </div>
      )}

      {/* Guarantees Strip */}
      <div class="mt-20 flex flex-wrap items-center justify-center gap-8 py-6 border-t text-[11px] font-mono" style="border-color: var(--circuit-line); color: var(--type-muted);">
        <div class="flex items-center gap-2">
          <ShieldCheck size={14} class="text-[var(--signal-teal)]" />
          30-Day Money-Back Guarantee
        </div>
        <div class="flex items-center gap-2">
          <CreditCard size={14} class="text-[var(--signal-teal)]" />
          Secure Payment Processing
        </div>
        <div class="flex items-center gap-2">
          <HelpCircle size={14} class="text-[var(--signal-teal)]" />
          Free Setup Assistance
        </div>
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="py-16 border-t tech-grid" style="background: var(--ink-void); border-color: var(--circuit-line);">
    <div class="container-custom max-w-3xl">
      <SectionHeader eyebrow="FAQ" title="Licensing FAQ" centered class="mb-10" />

      <div class="space-y-4">
        {dynamicFaqs.map((faq) => (
          <div class="backdrop-blur rounded-xl border p-6 transition-colors" style="background: var(--slate-surface); border-color: var(--circuit-line);">
            <h3 class="font-bold text-white text-sm mb-2">{faq.question}</h3>
            <p class="text-xs leading-relaxed" style="color: var(--type-muted);">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
