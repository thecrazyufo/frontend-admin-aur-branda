---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchResultsPage from "@/components/common/SearchResultsPage";
import { siteConfig } from "@/config/site";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || siteConfig.name;
---

<BaseLayout
  title={`Search — ${siteName}`}
  description="Search for products, documentation, blogs, and guides."
>
  <div class="min-h-screen bg-gray-50">
    <div class="hero-gradient py-12 text-center">
      <div class="container-custom">
        <h1 class="text-white font-bold mb-3 font-bold">Search</h1>
      </div>
    </div>
    <SearchResultsPage client:load />
  </div>
</BaseLayout>
