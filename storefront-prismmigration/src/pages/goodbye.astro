---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SettingsAPI, ProductAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "Prism Migration";

// Parse product slug from query parameters
const productSlug = Astro.url.searchParams.get("product");
let product = null;
if (productSlug) {
  product = await ProductAPI.getBySlug(productSlug).catch(() => null);
}

// Try to fetch custom content, fallback to default premium welcome content if empty
const hasCustomContent = !!settings?.legalPages?.["goodbye"];
const htmlContent = settings?.legalPages?.["goodbye"];
---

<BaseLayout
  title={`Uninstallation Completed — ${siteName}`}
  description="The software has been uninstalled. We are sorry to see you go."
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center py-20 bg-[#0B0F1A] relative overflow-hidden tech-grid">
    <!-- Background accents -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute -top-[10%] left-[50%] -translate-x-1/2 w-[600px] h-[300px] bg-[#6366F1]/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="container-custom max-w-3xl mx-auto px-4 relative z-10">
      {hasCustomContent ? (
        <div 
          class="bg-[#1E2937]/30 backdrop-blur-xl border border-[#334155] p-8 md:p-12 rounded-3xl shadow-2xl prose prose-invert max-w-none prose-headings:text-white prose-p:text-[#E2E8F0] prose-a:text-[#6366F1] hover:prose-a:underline"
          set:html={htmlContent}
        />
      ) : (
        <div class="bg-[#1E2937]/30 backdrop-blur-xl border border-[#334155] p-8 md:p-12 rounded-3xl shadow-2xl text-center space-y-8">
          <!-- Trash or Goodbye SVG -->
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 text-red-500 mb-2 animate-pulse">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
            </svg>
          </div>

          <div class="space-y-3">
            <h1 class="text-3xl md:text-3xl font-extrabold text-white tracking-tight">
              Uninstallation Completed
            </h1>
            <p class="text-[#94A3B8] text-sm md:text-base max-w-md mx-auto">
              We are sorry to see you go. <span class="text-[#6366F1] font-bold">{siteName}</span> has been completely removed from your device.
            </p>
          </div>

          <!-- Interactive Feedback Survey -->
          <div id="survey-container" class="bg-[#1E2937]/20 backdrop-blur-md p-6 rounded-2xl border border-[#334155] max-w-lg mx-auto text-left space-y-6">
            <div id="survey-form-block" class="space-y-4">
              <div>
                <h3 class="text-white font-bold text-sm">Help us improve!</h3>
                <p class="text-[#94A3B8] text-xs mt-1">Why did you uninstall the application?</p>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="reason-options">
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Difficult to use / UI issues">
                  Difficult to use / UI issues
                </button>
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Encountered technical errors / bugs">
                  Encountered errors / bugs
                </button>
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Missing features needed">
                  Missing features needed
                </button>
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Found a better alternative">
                  Found better alternative
                </button>
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Temporary use completed">
                  Temporary use completed
                </button>
                <button type="button" class="survey-option-btn text-left text-[11px] p-2.5 rounded-lg border border-[#334155] bg-[#0B0F1A]/40 hover:border-[#6366F1] hover:bg-[#6366F1]/5 text-[#E2E8F0] font-medium transition-all duration-200 cursor-pointer" data-reason="Pricing is too high">
                  Pricing is too high
                </button>
              </div>

              <div class="space-y-1.5">
                <label class="text-[10px] font-bold text-stone-500 uppercase tracking-wider block">Additional Comments (Optional)</label>
                <textarea id="survey-comments" rows="3" placeholder="How can we make it better for you?" class="w-full px-3 py-2 bg-[#0B0F1A]/80 border border-[#334155] rounded-lg text-white focus:border-[#6366F1] focus:ring-1 focus:ring-[#6366F1]/40 focus:outline-none transition-colors text-xs resize-none"></textarea>
              </div>

              <button id="btn-submit-survey" class="w-full py-2.5 bg-[#6366F1] hover:bg-[#4F46E5] text-black text-xs font-bold rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(99,102,241,0.15)] cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                Submit Feedback
              </button>
            </div>

            <div id="survey-success-block" class="hidden text-center py-6 space-y-3 animate-fade-in">
              <div class="w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 flex items-center justify-center mx-auto">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <h4 class="text-white font-bold text-sm">Feedback Received!</h4>
              <p class="text-stone-500 text-[11px] leading-relaxed max-w-xs mx-auto">Thank you for sharing your thoughts. Your responses will help us build a better tool.</p>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-4">
            <a 
              href="/" 
              class="w-full sm:w-auto px-6 py-3 bg-[#6366F1] hover:bg-[#4F46E5] text-black font-semibold rounded-lg text-sm transition-all duration-200 transform hover:scale-[1.02]"
            >
              Reinstall Software
            </a>
            <a 
              href="/products" 
              class="w-full sm:w-auto px-6 py-3 bg-[#1E2937] border border-[#334155] hover:border-[#334155] text-[#E2E8F0] font-semibold rounded-lg text-sm transition-all duration-200"
            >
              Explore Other Products
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <script is:inline define:vars={{ productSlug: product ? product.name : productSlug || "Unknown Product", publicApiUrl: import.meta.env.PUBLIC_API_URL || "http://localhost:8080/api" }}>
    let selectedReason = "";
    const options = document.querySelectorAll(".survey-option-btn");
    const commentsInput = document.getElementById("survey-comments");
    const submitBtn = document.getElementById("btn-submit-survey");
    const formBlock = document.getElementById("survey-form-block");
    const successBlock = document.getElementById("survey-success-block");

    options.forEach(btn => {
      btn.addEventListener("click", () => {
        // Reset active state on all buttons
        options.forEach(b => {
          b.classList.remove("border-[#6366F1]", "bg-[#6366F1]/5");
          b.classList.add("border-[#334155]", "bg-[#0B0F1A]/40");
        });

        // Set active state on clicked button
        btn.classList.remove("border-[#334155]", "bg-[#0B0F1A]/40");
        btn.classList.add("border-[#6366F1]", "bg-[#6366F1]/5");
        selectedReason = btn.getAttribute("data-reason") || "";
      });
    });

    submitBtn?.addEventListener("click", async () => {
      if (!selectedReason) {
        alert("Please select a reason before submitting.");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting...";

      const comments = commentsInput?.value || "";
      const body = {
        name: "Uninstalled User",
        email: "no-reply@uninstalled.com",
        subject: `[UNINSTALL_FEEDBACK] [${productSlug}]`,
        message: `Uninstall Reason: ${selectedReason}\n\nAdditional Comments: ${comments}`
      };

      try {
        const res = await fetch(`${publicApiUrl}/support/contact`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body)
        });

        if (res.ok) {
          formBlock?.classList.add("hidden");
          successBlock?.classList.remove("hidden");
        } else {
          throw new Error("Failed to submit");
        }
      } catch (err) {
        console.error("Survey submission error:", err);
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit Feedback";
        alert("Failed to submit feedback. Please try again.");
      }
    });
  </script>
</BaseLayout>
