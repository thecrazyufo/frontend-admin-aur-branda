---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { HelpAPI } from "@/services/api";
import { HELP_CATEGORY_LABELS } from "@/types/common";
import SectionHeader from "@/components/common/SectionHeader";
import { BookOpen, ArrowRight, ThumbsUp } from "lucide-react";
import { siteConfig } from "@/config/site";

let articles = [];

try {
  articles = await HelpAPI.getAll();
} catch (e) {
  console.error("Error loading help articles:", e);
}
---

<BaseLayout
  title={`Help Center & Documentation — ${siteConfig.name}`}
  description="Step-by-step guides, tutorials, and documentation for all DataMigrate Pro software tools."
>
  <div class="min-h-screen bg-gray-50">
    {/* Header */}
    <div class="hero-gradient py-14 text-center">
      <div class="container-custom">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full text-blue-300 bg-white/10">Help Center</span>
        <h1 class="text-white font-bold mb-3 font-bold">How can we help you?</h1>
        <p class="text-gray-300 max-w-lg mx-auto">
          Find step-by-step guides, tutorials, and documentation for all our tools.
        </p>
      </div>
    </div>

    <div class="container-custom py-12">
      <SectionHeader eyebrow="Articles" title="Help Documentation" class="mb-8" />
      
      {articles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {articles.map((article) => (
            <a href={`/help/${article.slug}`} class="group bg-white rounded-2xl border border-gray-100 shadow-sm p-6 card-hover block">
              <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
                <BookOpen size={18} class="text-blue-600" />
              </div>
              <span class="badge badge-blue mb-3 inline-block">{HELP_CATEGORY_LABELS[article.category]}</span>
              <h3 class="font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">{article.title}</h3>
              <p class="text-sm text-gray-500 mb-4 line-clamp-2 leading-relaxed">{article.excerpt}</p>
              <div class="flex items-center justify-between text-xs text-gray-400">
                {article.helpful !== undefined && (
                  <span class="flex items-center gap-1">
                    <ThumbsUp size={11} class="text-green-400" />
                    {article.helpful} found helpful
                  </span>
                )}
                <span class="flex items-center gap-1 text-blue-500 font-medium group-hover:gap-2 transition-all">
                  Read <ArrowRight size={12} />
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <p class="text-gray-400 text-lg">No articles found.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
