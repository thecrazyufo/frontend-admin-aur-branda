---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { HelpAPI } from "@/services/api";
import Breadcrumb from "@/components/layout/Breadcrumb";
import { ArrowLeft, ThumbsUp, ThumbsDown } from "lucide-react";
import { siteConfig } from "@/config/site";

const { slug } = Astro.params;

let article = null;

try {
  if (slug) {
    article = await HelpAPI.getBySlug(slug);
  }
} catch (e) {
  console.error("Error loading help article:", e);
}

if (!article) {
  return new Response("Help Article Not Found", { status: 404 });
}
---

<BaseLayout
  title={`${article.title} — ${siteConfig.name}`}
  description={article.excerpt}
>
  <Breadcrumb items={[{ label: "Help Center", href: "/help" }, { label: article.title }]} />
  <div class="bg-gray-50 min-h-screen">
    <article class="container-custom py-12 max-w-3xl">
      <a href="/help" class="inline-flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700 mb-8 font-medium">
        <ArrowLeft size={15} />
        Back to Help Center
      </a>
      <h1 class="font-bold text-gray-900 mb-2">{article.title}</h1>
      <p class="text-gray-500 text-sm mb-8">{article.excerpt}</p>

      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <div class="whitespace-pre-line text-gray-600 leading-relaxed text-sm">
          {(article.content || "").trim().split("\n").map((line) => {
            if (line.startsWith("## ")) return <h2 class="text-xl font-bold text-gray-900 mt-8 mb-3">{line.replace("## ", "")}</h2>;
            if (line.startsWith("### ")) return <h3 class="text-base font-bold text-gray-900 mt-5 mb-2">{line.replace("### ", "")}</h3>;
            if (line.match(/^\d+\./)) return <p class="ml-4 my-1 text-gray-600">{line}</p>;
            if (line.startsWith("- ")) return <p class="ml-4 my-1 text-gray-600">• {line.replace("- ", "")}</p>;
            if (!line.trim()) return <br />;
            return <p class="my-2 text-gray-600">{line}</p>;
          })}
        </div>
      </div>

      {/* Helpful? */}
      <div class="mt-8 bg-white rounded-2xl border border-gray-100 p-6 text-center">
        <p class="font-semibold text-gray-900 mb-4">Was this article helpful?</p>
        <div class="flex items-center justify-center gap-4 flex-wrap">
          <button class="btn btn-outline text-sm py-2 px-5 text-green-600 border-green-200 hover:bg-green-50 flex items-center gap-1.5">
            <ThumbsUp size={15} />
            Yes ({article.helpful || 0})
          </button>
          <button class="btn btn-outline text-sm py-2 px-5 text-red-500 border-red-100 hover:bg-red-50 flex items-center gap-1.5">
            <ThumbsDown size={15} />
            No ({article.notHelpful || 0})
          </button>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
