---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI } from "@/services/api";
import ProductCard from "@/components/common/ProductCard";
import SectionHeader from "@/components/common/SectionHeader";

import type { Product } from "@/types/product";
import type { Category } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

// Get query parameters from URL
const category = Astro.url.searchParams.get("category") || undefined;
const q = Astro.url.searchParams.get("q") || undefined;

let products: Product[] = [];
let categoriesList: Category[] = [];
let allProducts: Product[] = [];

try {
  const [ps, cs, aps] = await Promise.all([
    ProductAPI.getAll(category, q),
    CategoryAPI.getAll(),
    ProductAPI.getAll(),
  ]);
  products = ps.filter(p => p.enabled !== false);
  allProducts = aps.filter(p => p.enabled !== false);
  categoriesList = cs.map(cat => ({
    ...cat,
    count: allProducts.filter(p => p.category === cat.id).length
  }));
} catch (e) {
  console.error("Error loading products:", e);
}

const activeCategory = categoriesList.find((c) => c.id === category);
const filteredCount = products.length;
---

<BaseLayout
  title={activeCategory ? `${activeCategory.label} Tools — ${settings?.name || ""}` : `All Software Products — ${settings?.name || ""}`}
  description={activeCategory ? activeCategory.description : "Browse our complete collection of email migration, backup, file converter, and cloud migration tools."}
>
  <div class="min-h-screen bg-[#F8FAFC] text-white">
    {/* Header */}
    <div class="bg-[#F8FAFC] border-b border-[#E2E8F0] py-16 tech-grid relative overflow-hidden">
      <!-- Subtle Ambient Glow -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[350px] h-[150px] bg-[#F97316]/10 blur-[80px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <div class="max-w-2xl">
          <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-[#F97316] mb-2">Products</span>
          <h1 class="text-[#0F172A]xl font-extrabold text-white tracking-tight mb-2">
            {activeCategory ? activeCategory.label : "Pristine Software Collection"}
          </h1>
          <p class="text-xs text-[#E5E5E5] leading-relaxed">
            {activeCategory ? activeCategory.description : "Find the right enterprise-grade utility for lightning-fast database and mailbox migration."}
          </p>
        </div>
      </div>
    </div>

    <div class="container-custom py-12">
      <div class="flex flex-col lg:flex-row gap-8">
        {/* Sidebar Filters */}
        <aside class="w-full lg:w-64 shrink-0">
          <div class="bg-white/30 backdrop-blur rounded-xl border border-[#E2E8F0] p-5 sticky top-20 shadow-2xl">
            <h3 class="font-bold text-white text-xs uppercase tracking-wider mb-4 border-b border-[#E2E8F0] pb-2">Categories</h3>
            <ul class="space-y-1">
              <li>
                <a
                  href="/products"
                  class={`flex items-center justify-between px-3 py-2.5 rounded-lg text-xs font-semibold transition-all duration-300 ${
                    !category
                      ? "bg-[#F97316]/10 text-[#F97316] border border-[#F97316]/20 font-bold"
                      : "text-[#0F172A] hover:text-white hover:bg-white/40 border border-transparent"
                  }`}
                >
                  All Products
                  <span class="text-[10px] text-[#0F172A] bg-stone-800 border border-[#CBD5E1] px-1.5 py-0.5 rounded-md font-mono">
                    {allProducts.length}
                  </span>
                </a>
              </li>
              {categoriesList.map((cat) => (
                <li>
                  <a
                    href={`/products?category=${cat.id}`}
                    class={`flex items-center justify-between px-3 py-2.5 rounded-lg text-xs font-semibold transition-all duration-300 ${
                      category === cat.id
                        ? "bg-[#F97316]/10 text-[#F97316] border border-[#F97316]/20 font-bold"
                        : "text-[#0F172A] hover:text-white hover:bg-white/40 border border-transparent"
                    }`}
                  >
                    {cat.label}
                    <span class="text-[10px] text-[#0F172A] bg-stone-800 border border-[#CBD5E1] px-1.5 py-0.5 rounded-md font-mono">
                      {cat.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        {/* Product Grid */}
        <div class="flex-1">
          <div class="flex items-center justify-between mb-6">
            <p class="text-xs text-[#475569] font-mono">
              {filteredCount} UTILI{filteredCount !== 1 ? "TIES" : "TY"} RESOLVED
            </p>
          </div>

          {filteredCount > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          ) : (
            <div class="text-center py-20 bg-white/10 backdrop-blur rounded-2xl border border-[#E2E8F0] p-8 shadow-2xl">
              <p class="text-[#0F172A] text-sm">No migration utilities matching this query were found in database index.</p>
              <a href="/products" class="inline-block mt-4 bg-[#F97316] hover:bg-[#EA580C] text-white font-extrabold text-xs py-2 px-4 rounded transition-colors shadow-[0_0_15px_rgba(249, 115, 22,0.2)]">Clear Filters</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
