---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ArrowLeft } from "lucide-react";
---

<BaseLayout title="Page Not Found (404) — Prism Migration" description="The page you are looking for does not exist.">
  <div class="bg-[#0B0F1A] min-h-[80vh] flex items-center justify-center relative overflow-hidden px-4">
    <!-- Ambient refraction glow background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-[#6366F1]/5 blur-[120px] rounded-full"></div>
    </div>

    <div class="relative z-10 text-center max-w-md mx-auto space-y-6">
      <span class="inline-block text-[11px] font-bold uppercase tracking-widest px-3.5 py-2 rounded-full text-[#6366F1] bg-[#6366F1]/10 border border-[#6366F1]/20 animate-pulse">
        Error 404
      </span>
      <h1 class="text-white font-extrabold text-3xl md:text-4xl tracking-tight leading-tight">
        Lost in Migration?
      </h1>
      <p class="text-[#94A3B8] text-xs md:text-sm leading-relaxed max-w-sm mx-auto">
        The destination page you are looking for has either been moved, deleted, or never existed in our directory database.
      </p>
      <div class="pt-4">
        <a
          href="/"
          class="inline-flex items-center justify-center text-xs font-bold text-white bg-[#1E2937] border border-[#334155] hover:border-stone-700 px-6 py-3 rounded-full transition-all duration-200 active:scale-95 shadow-md"
        >
          <ArrowLeft size={14} class="mr-2" />
          Return to Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
