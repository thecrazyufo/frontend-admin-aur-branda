---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, SettingsAPI } from "@/services/api";
import SectionHeader from "@/components/common/SectionHeader";
import { Download, Monitor, CheckCircle, RefreshCw, X } from "lucide-react";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "";

let productsList = [];

try {
  productsList = await ProductAPI.getAll();
} catch (e) {
  console.error("Error loading products for downloads:", e);
}

// Check for auto-download parameters
const url = new URL(Astro.request.url);
const targetSlug = url.searchParams.get("product");
const autoProduct = targetSlug ? productsList.find(p => p.slug === targetSlug) : null;
---

<BaseLayout
  title={`Download Center — Free Trial Downloads | ${siteName}`}
  description={`Download free trials of all ${siteName} tools. No credit card required. Try before you buy.`}
  noindex={true}
>
  <div>
    <section class="bg-[#0B0F1A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#6366F1]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[#6366F1] bg-[#6366F1]/15 border border-[#6366F1]/25">Download Center</span>
        <h1 class="text-white font-extrabold text-3xl md:text-3xl tracking-tight mb-4">Download Free Trials</h1>
        <p class="text-[#E2E8F0] max-w-xl mx-auto leading-relaxed text-xs">
          Try any tool free. No credit card required. Migrate/convert up to 50 items in trial mode to verify it works for you.
        </p>
        <div class="flex items-center justify-center gap-6 mt-6 text-[11px] text-[#94A3B8] font-mono flex-wrap">
          {["No Credit Card", "Instant Download", "100% Safe & Secure", "Windows Compatible"].map((t) => (
            <div class="flex items-center gap-1.5">
              <CheckCircle size={13} class="text-[#6366F1]" />
              {t}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Auto Download Modal overlay */}
    {autoProduct && (
      <div id="download-overlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div class="bg-[#1E2937] rounded-2xl p-8 max-w-md w-full shadow-2xl relative border border-[#334155] text-center animate-in fade-in zoom-in duration-200">
          <button 
            onclick="document.getElementById('download-overlay').style.display='none'"
            class="absolute top-4 right-4 text-stone-500 hover:text-white p-2 hover:bg-stone-850 rounded-full cursor-pointer transition-colors"
            aria-label="Close modal"
          >
            <X size={18} />
          </button>
          
          <div id="modal-initial-state">
            <div class="w-16 h-16 rounded-full bg-[#6366F1]/10 border border-[#6366F1]/25 flex items-center justify-center mx-auto mb-4 text-[#6366F1]">
              <Download size={32} />
            </div>
            
            <h2 class="text-xl font-bold text-white mb-2">Download Free Trial</h2>
            <p class="text-xs text-[#E2E8F0] mb-6">
              Enter your email to download your free trial of <strong class="text-white">{autoProduct.name}</strong>.
            </p>
            
            <form id="lead-form" class="space-y-4">
              <div class="text-left">
                <label for="lead-email" class="block text-[10px] font-bold text-[#94A3B8] mb-1.5 uppercase tracking-wider">Business Email Address</label>
                <input 
                  type="email" 
                  id="lead-email" 
                  required 
                  placeholder="name@company.com" 
                  class="w-full px-4 py-3 rounded-lg border border-[#334155] text-xs focus:outline-none focus:ring-2 focus:ring-[#6366F1]/40 focus:border-transparent transition-all text-white bg-[#0B0F1A]/80"
                />
              </div>
              
              <button 
                type="submit" 
                id="submit-btn" 
                class="w-full text-center bg-[#6366F1] hover:bg-[#4F46E5] text-black text-xs font-bold py-3 px-6 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(99, 102, 241,0.25)] hover:shadow-[0_0_20px_rgba(99, 102, 241,0.4)] cursor-pointer"
              >
                Request Download
              </button>
            </form>
            
            <div id="error-message" class="text-red-500 text-xs mt-3 hidden"></div>
          </div>

          <div id="modal-success-state" class="hidden">
            <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/25 flex items-center justify-center mx-auto mb-4 text-emerald-500">
              <CheckCircle size={32} />
            </div>
            
            <h2 class="text-xl font-bold text-white mb-2">Starting Your Download...</h2>
            <p class="text-xs text-[#E2E8F0] mb-6">
              Downloading the setup package for <strong class="text-white">{autoProduct.name}</strong>.
            </p>
            
            <div class="bg-[#0B0F1A] rounded-xl p-4 text-xs text-[#94A3B8] text-left space-y-2 mb-6 border border-[#334155]">
              <p class="font-semibold text-white">Next Steps:</p>
              <ol class="list-decimal list-inside space-y-1">
                <li>Open the downloaded installer file.</li>
                <li>Follow the instructions on the screen to install.</li>
                <li>Run the application in free trial mode or enter your license key to activate the full version.</li>
              </ol>
            </div>

            <a 
              id="manual-download-link"
              href="#" 
              class="inline-block w-full text-center bg-[#6366F1] hover:bg-[#4F46E5] text-black text-xs font-bold py-2.5 px-6 rounded-lg transition-all duration-300"
            >
              Click here if download doesn't start
            </a>
          </div>
        </div>

        <script is:inline define:vars={{ productSlug: autoProduct.slug, publicApiUrl: import.meta.env.PUBLIC_API_URL || "http://localhost:8080/api" }}>
          const form = document.getElementById("lead-form");
          const emailInput = document.getElementById("lead-email");
          const submitBtn = document.getElementById("submit-btn");
          const errorMsg = document.getElementById("error-message");
          const initialState = document.getElementById("modal-initial-state");
          const successState = document.getElementById("modal-success-state");
          const manualLink = document.getElementById("manual-download-link");

          form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const email = emailInput?.value;
            if (!email) return;

            submitBtn.disabled = true;
            submitBtn.textContent = "Processing...";
            errorMsg.classList.add("hidden");

            try {
              const res = await fetch(`${publicApiUrl}/download/trial`, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json"
                },
                body: JSON.stringify({ email, productSlug })
              });

              if (res.ok) {
                const data = await res.json();
                
                // Show success state
                initialState.classList.add("hidden");
                successState.classList.remove("hidden");
                manualLink.href = data.downloadUrl;

                // Trigger download
                const link = document.createElement("a");
                link.href = data.downloadUrl;
                link.download = "";
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
              } else {
                const errData = await res.json().catch(() => ({}));
                errorMsg.textContent = errData.message || "Failed to initiate download. Please check your email and try again.";
                errorMsg.classList.remove("hidden");
                submitBtn.disabled = false;
                submitBtn.textContent = "Request Download";
              }
            } catch (err) {
              console.error("Error submitting lead:", err);
              errorMsg.textContent = "Network error. Please try again later.";
              errorMsg.classList.remove("hidden");
              submitBtn.disabled = false;
              submitBtn.textContent = "Request Download";
            }
          });
        </script>
      </div>
    )}

    <section class="py-20 bg-[#0B0F1A] border-t border-[#334155]">
      <div class="container-custom">
        <SectionHeader eyebrow="Downloads" title="All Available Tools" class="mb-12 text-center" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {productsList.map((product) => (
            <div class="bg-[#1E2937]/10 backdrop-blur border border-[#334155] hover:border-[#6366F1]/30 rounded-xl p-6 flex items-start justify-between gap-6 shadow-2xl transition-all duration-300">
              <div class="flex items-start gap-4 flex-1">
                <div class="w-12 h-12 rounded-xl bg-[#0B0F1A] border border-[#334155] flex items-center justify-center shadow-md shrink-0">
                  <Download size={20} class="text-[#6366F1]" />
                </div>
                <div>
                  <h3 class="font-bold text-white mb-1 text-sm">{product.name}</h3>
                  <p class="text-xs text-[#E2E8F0] mb-3 line-clamp-2 leading-relaxed">{product.shortDescription}</p>
                  <div class="flex items-center gap-3 text-[10px] text-[#94A3B8] font-mono flex-wrap">
                    <span class="flex items-center gap-1"><Monitor size={11} /> Windows</span>
                    <span>v{product.version}</span>
                    <span>{product.downloads} downloads</span>
                  </div>
                </div>
              </div>
              <div class="flex flex-col gap-2 shrink-0">
                <a
                  href={`/download?product=${product.slug}`}
                  class="bg-[#6366F1] hover:bg-[#4F46E5] text-black py-2 px-4 rounded-lg text-xs font-bold transition-all duration-300 flex items-center justify-center gap-1"
                >
                  <Download size={14} />
                  Download
                </a>
                <a href={`/products/${product.slug}`} class="text-xs text-center text-[#6366F1] hover:underline">
                  Learn more →
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
