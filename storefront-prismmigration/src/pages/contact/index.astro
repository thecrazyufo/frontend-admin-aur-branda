---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Mail, Phone, MapPin, Clock } from "lucide-react";
import ContactForm from "@/components/common/ContactForm";
import { siteConfig } from "@/config/site";
import { SettingsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

const siteName = settings?.name || siteConfig.name;
const siteDescription = settings?.description || siteConfig.description;
const sitePhone = settings?.phone || siteConfig.phone;
const siteEmail = settings?.email || siteConfig.email;
const siteAddress = settings?.address || siteConfig.address;
---

<BaseLayout
  title={`Contact Us — ${siteName}`}
  description="Get in touch with our support team. We're available 24/7 to help with any questions about our software tools."
>
  <div>
    <div class="hero-gradient py-14 text-center">
      <div class="container-custom">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full text-blue-300 bg-white/10">Contact</span>
        <h1 class="text-white font-bold mb-3 font-bold">We're Here to Help</h1>
        <p class="text-gray-300 max-w-lg mx-auto">
          Contact our expert support team. We typically respond within 2 hours.
        </p>
      </div>
    </div>

    <section class="section bg-gray-50">
      <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          {/* Contact Info */}
          <div class="space-y-6">
            <div>
              <h2 class="font-bold text-gray-900 text-xl mb-6">Contact Information</h2>
              <div class="space-y-4">
                {[
                  { icon: "Phone", label: "Phone", value: sitePhone, href: `tel:${sitePhone}` },
                  { icon: "Mail", label: "Email", value: siteEmail, href: `mailto:${siteEmail}` },
                  { icon: "MapPin", label: "Address", value: siteAddress },
                  { icon: "Clock", label: "Hours", value: "Mon–Fri: 9AM–6PM PST\nWeekends: 10AM–4PM PST" },
                ].map((item) => (
                  <div class="flex items-start gap-4 p-4 bg-white rounded-xl border border-gray-100">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                      {item.icon === "Phone" && <Phone size={18} />}
                      {item.icon === "Mail" && <Mail size={18} />}
                      {item.icon === "MapPin" && <MapPin size={18} />}
                      {item.icon === "Clock" && <Clock size={18} />}
                    </div>
                    <div>
                      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">{item.label}</p>
                      {item.href ? (
                        <a href={item.href} class="text-sm text-gray-700 hover:text-blue-600 font-medium">{item.value}</a>
                      ) : (
                        <p class="text-sm text-gray-700 whitespace-pre-line leading-relaxed">{item.value}</p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Contact Form Island */}
          <div class="lg:col-span-2">
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
