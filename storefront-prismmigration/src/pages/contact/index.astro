---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Mail, Phone, MapPin, Clock, MessageSquare } from "lucide-react";
import ContactForm from "@/components/common/ContactForm";
import { SettingsAPI } from "@/services/api";
import { generateOrganizationSchema } from "@/lib/seo";

const settings = await SettingsAPI.get().catch(() => null);

const siteName = settings?.name || "";
const siteDescription = settings?.description || "";
const sitePhone = settings?.phone || "";
const siteEmail = settings?.email || "";
const siteAddress = settings?.address || "";
const siteUrl = (settings?.url || "").replace(/\/$/, "");
const siteSocials = Object.values(settings?.socials || {}).filter((v): v is string => typeof v === "string" && v.startsWith("http"));
---

<BaseLayout
  title={`Contact Us — ${siteName}`}
  description="Get in touch with our support team. We're available 24/7 to help with any questions about our software tools."
>
  <script type="application/ld+json"
    set:html={JSON.stringify(generateOrganizationSchema({
      name: siteName,
      url: siteUrl,
      email: siteEmail || undefined,
      phone: sitePhone || undefined,
      address: siteAddress || undefined,
      description: siteDescription || undefined,
      logo: settings?.theme?.logoUrl || undefined,
      socials: siteSocials.length ? siteSocials : undefined,
    }))}
  />
    <div class="bg-[#0F172A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#14B8A6]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[#14B8A6] bg-[#14B8A6]/15 border border-[#14B8A6]/25">Contact</span>
        <h1 class="text-white font-extrabold text-[#E2E8F0]xl md:text-[#E2E8F0]xl tracking-tight mb-4">We're Here to Help</h1>
        <p class="text-[#E2E8F0] max-w-lg mx-auto text-xs leading-relaxed">
          Contact our expert support team. We typically respond within 2 hours.
        </p>
      </div>
    </div>

    <section class="py-20 bg-[#0F172A] border-t border-[#334155]">
      <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          {/* Contact Info */}
          <div class="space-y-6">
            <div>
              <h2 class="font-bold text-white text-xl mb-6">Contact Information</h2>
              <div class="space-y-4">
                {[
                  { icon: "Phone", label: "Phone", value: sitePhone, href: `tel:${sitePhone}` },
                  { icon: "Mail", label: "Email", value: siteEmail, href: `mailto:${siteEmail}` },
                  { icon: "LiveChat", label: "Live Chat", value: "Start Chatting Now", href: "#" },
                  { icon: "MapPin", label: "Address", value: siteAddress },
                  { icon: "Clock", label: "Hours", value: "Mon–Fri: 9AM–6PM PST\nWeekends: 10AM–4PM PST" },
                ].map((item) => (
                  <div class="flex items-start gap-4 p-4 bg-[#1E2937]/30 backdrop-blur rounded-xl border border-[#334155]">
                    <div class="w-10 h-10 rounded-xl bg-[#14B8A6]/10 flex items-center justify-center text-[#14B8A6] shrink-0 border border-[#14B8A6]/20">
                      {item.icon === "Phone" && <Phone size={18} />}
                      {item.icon === "Mail" && <Mail size={18} />}
                      {item.icon === "LiveChat" && <MessageSquare size={18} />}
                      {item.icon === "MapPin" && <MapPin size={18} />}
                      {item.icon === "Clock" && <Clock size={18} />}
                    </div>
                    <div>
                      <p class="text-[10px] font-semibold text-[#94A3B8] uppercase tracking-wide mb-1">{item.label}</p>
                      {item.icon === "LiveChat" ? (
                        <button onclick="if (typeof window.triggerTawkOpen === 'function') { window.triggerTawkOpen(); } else { console.log('Tawk trigger helper not registered yet'); } return false;" class="text-xs text-[#14B8A6] hover:text-[#0D9488] hover:underline font-bold text-left bg-transparent border-[#334155] p-0 cursor-pointer">{item.value}</button>
                      ) : item.href ? (
                        <a href={item.href} class="text-xs text-[#E2E8F0] hover:text-[#14B8A6] font-semibold transition-colors">{item.value}</a>
                      ) : (
                        <p class="text-xs text-[#E2E8F0] whitespace-pre-line leading-relaxed">{item.value}</p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Contact Form Island */}
          <div class="lg:col-span-2">
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
