---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FaqAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { FAQ_CATEGORY_LABELS, type FAQCategory } from "@/types/faq";
import { generateFAQSchema } from "@/lib/seo";
import SectionHeader from "@/components/common/SectionHeader";
import { parseMarkdownToHtml } from "@/lib/utils";
import { ChevronRight } from "lucide-react";

let faqsList = [];
let grouped: Record<string, typeof faqsList> = {};

try {
  faqsList = await FaqAPI.getAll();
  grouped = faqsList.reduce<Record<string, typeof faqsList>>((acc, faq) => {
    if (!acc[faq.category]) acc[faq.category] = [];
    acc[faq.category].push(faq);
    return acc;
  }, {});
} catch (e) {
  console.error("Error loading FAQs:", e);
}
---

<BaseLayout
  title={`Frequently Asked Questions — ${settings?.name || ""}`}
  description="Find answers to frequently asked questions about our software tools, licensing, payments, and technical support."
>
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQSchema(faqsList.map((f) => ({ question: f.question, answer: f.answer }))))} />

  <div class="hero-gradient py-14 text-center">
    <div class="container-custom">
      <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[#6366F1] bg-[#6366F1]/10 border border-[#6366F1]/20">FAQ</span>
      <h1 class="text-[#E2E8F0] font-bold mb-3">Frequently Asked Questions</h1>
      <p class="text-[#E2E8F0] max-w-lg mx-auto">
        Everything you need to know about our tools, licensing, and support.
      </p>
    </div>
  </div>

  <div class="container-custom py-14 max-w-4xl">
    {Object.entries(grouped).map(([category, items]) => (
      <div class="mb-12">
        <SectionHeader
          eyebrow="Category"
          title={FAQ_CATEGORY_LABELS[category as FAQCategory] || category}
          class="mb-6"
        />
        <div class="space-y-3">
          {items.map((faq) => (
            <details class="group bg-[#1E2937]/30 backdrop-blur rounded-2xl border border-[#334155] shadow-sm">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
                <span class="font-semibold text-white pr-4">{faq.question}</span>
                <ChevronRight size={18} class="text-stone-500 shrink-0 group-open:rotate-90 transition-transform" />
              </summary>
              <div class="px-6 pb-5">
                <div class="text-sm text-[#E2E8F0] leading-relaxed prose-faq" set:html={parseMarkdownToHtml(faq.answer || faq.answer)} />
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
