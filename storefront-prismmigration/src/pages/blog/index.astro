---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BlogAPI } from "@/services/api";
import { BLOG_CATEGORY_LABELS } from "@/types/blog";
import { formatDate } from "@/lib/utils";
import SectionHeader from "@/components/common/SectionHeader";
import { Clock, ArrowRight } from "lucide-react";
import { siteConfig } from "@/config/site";

let blogPostsList = [];
let featured = null;
let rest = [];

try {
  blogPostsList = await BlogAPI.getAll();
  if (blogPostsList.length > 0) {
    featured = blogPostsList[0];
    rest = blogPostsList.slice(1);
  }
} catch (e) {
  console.error("Error loading blog posts:", e);
}
---

<BaseLayout
  title={`Blog — Email Migration Guides & Tips | ${siteConfig.name}`}
  description="Expert guides, tutorials, and tips on email migration, backup, data recovery, and file conversion."
>
  <div class="min-h-screen bg-gray-50">
    {/* Header */}
    <div class="hero-gradient py-14 text-center">
      <div class="container-custom">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full text-blue-300 bg-white/10">Blog</span>
        <h1 class="text-white font-bold mb-3">Expert Guides & Tutorials</h1>
        <p class="text-gray-300 max-w-xl mx-auto">
          Learn email migration, backup strategies, and data management from our team of experts.
        </p>
      </div>
    </div>

    <div class="container-custom py-12">
      {/* Featured Post */}
      {featured && (
        <div class="mb-12">
          <a
            href={`/blog/${featured.slug}`}
            class="group bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden grid grid-cols-1 lg:grid-cols-2 card-hover block"
          >
            <div class="bg-gradient-to-br from-blue-500 to-blue-700 min-h-56 flex items-center justify-center p-12">
              <span class="text-white/20 text-8xl font-black">{featured.title.charAt(0)}</span>
            </div>
            <div class="p-8 flex flex-col justify-center">
              <span class="badge badge-blue mb-3 inline-block self-start">{BLOG_CATEGORY_LABELS[featured.category]}</span>
              <h2 class="font-bold text-gray-900 text-xl mb-3 group-hover:text-blue-600 transition-colors">{featured.title}</h2>
              <p class="text-gray-500 text-sm mb-5 line-clamp-3">{featured.excerpt}</p>
              <div class="flex items-center justify-between text-xs text-gray-400">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-xs">
                    {featured.author.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-medium text-gray-700">{featured.author.name}</p>
                    <p>{formatDate(featured.publishedAt)}</p>
                  </div>
                </div>
                <div class="flex items-center gap-1">
                  <Clock size={12} />
                  {featured.readTime} min read
                </div>
              </div>
              <div class="flex items-center gap-1 mt-5 text-blue-600 font-semibold text-sm group-hover:gap-2 transition-all">
                Read Article <ArrowRight size={14} />
              </div>
            </div>
          </a>
        </div>
      )}

      {/* All Posts Grid */}
      <SectionHeader eyebrow="All Articles" title="Latest Posts" class="mb-8" />
      
      {rest.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map((post) => (
            <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden card-hover block">
              <div class="bg-gradient-to-br from-gray-100 to-gray-200 h-40 flex items-center justify-center">
                <span class="text-gray-300 text-6xl font-black">{post.title.charAt(0)}</span>
              </div>
              <div class="p-5">
                <span class="badge badge-blue mb-2 inline-block">{BLOG_CATEGORY_LABELS[post.category]}</span>
                <h3 class="font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">{post.title}</h3>
                <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.excerpt}</p>
                <div class="flex items-center justify-between text-xs text-gray-400">
                  <span>{formatDate(post.publishedAt)}</span>
                  <span class="flex items-center gap-1"><Clock size={11} /> {post.readTime} min</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <p class="text-gray-400 text-lg">No articles found.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
