---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BlogAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { BLOG_CATEGORY_LABELS } from "@/types/blog";
import { formatDate } from "@/lib/utils";
import SectionHeader from "@/components/common/SectionHeader";
import { Clock, ArrowRight } from "lucide-react";

let blogPostsList = [];
let featured = null;
let rest = [];

try {
  blogPostsList = await BlogAPI.getAll();
  if (blogPostsList.length > 0) {
    featured = blogPostsList[0];
    rest = blogPostsList.slice(1);
  }
} catch (e) {
  console.error("Error loading blog posts:", e);
}
---

<BaseLayout
  title={`Blog — Email Migration Guides & Tips | ${settings?.name || ""}`}
  description="Expert guides, tutorials, and tips on email migration, backup, data recovery, and file conversion."
>
  <div class="min-h-screen bg-[#0F172A]">
    {/* Header */}
    <div class="bg-[#0F172A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#14B8A6]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[#14B8A6] bg-[#14B8A6]/15 border border-[#14B8A6]/25">Blog</span>
        <h1 class="text-white font-extrabold text-3xl md:text-3xl tracking-tight mb-4">Expert Guides & Tutorials</h1>
        <p class="text-[#E2E8F0] max-w-xl mx-auto text-xs leading-relaxed">
          Learn email migration, backup strategies, and data management from our team of experts.
        </p>
      </div>
    </div>

    <div class="container-custom py-20">
      {/* Featured Post */}
      {featured && (
        <div class="mb-16">
          <a
            href={`/blog/${featured.slug}`}
            class="group bg-[#1E2937]/30 backdrop-blur rounded-2xl border border-[#334155] overflow-hidden grid grid-cols-1 lg:grid-cols-2 block hover:border-[#14B8A6]/30 transition-all duration-300"
          >
            <div class="bg-[#0F172A] border-r border-[#334155] min-h-56 flex items-center justify-center p-12">
              <span class="text-stone-800 text-3xl font-black">{featured.title.charAt(0)}</span>
            </div>
            <div class="p-8 flex flex-col justify-center">
              <span class="px-2.5 py-0.5 rounded border border-[#14B8A6]/20 bg-[#14B8A6]/10 text-[#14B8A6] text-[9px] uppercase font-bold tracking-wider inline-block self-start mb-3">{BLOG_CATEGORY_LABELS[featured.category]}</span>
              <h2 class="font-bold text-white text-xl mb-3 group-hover:text-[#14B8A6] transition-colors text-sm">{featured.title}</h2>
              <p class="text-xs text-[#E2E8F0] mb-5 line-clamp-3 leading-relaxed">{featured.excerpt}</p>
              <div class="flex items-center justify-between text-xs text-[#94A3B8]">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-[#14B8A6]/10 border border-[#14B8A6]/20 text-[#14B8A6] flex items-center justify-center font-bold text-xs">
                    {featured.author.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-[#E2E8F0]">{featured.author.name}</p>
                    <p class="text-[10px] text-stone-500 font-mono mt-0.5">{formatDate(featured.publishedAt)}</p>
                  </div>
                </div>
                <div class="flex items-center gap-1 font-mono text-[10px]">
                  <Clock size={12} />
                  {featured.readTime} min read
                </div>
              </div>
              <div class="flex items-center gap-1 mt-5 text-[#14B8A6] font-bold text-xs group-hover:gap-2 transition-all">
                Read Article <ArrowRight size={14} />
              </div>
            </div>
          </a>
        </div>
      )}

      {/* All Posts Grid */}
      <SectionHeader eyebrow="All Articles" title="Latest Posts" class="mb-12" />
      
      {rest.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {rest.map((post) => (
            <a href={`/blog/${post.slug}`} class="group bg-[#1E2937]/30 backdrop-blur rounded-xl border border-[#334155] overflow-hidden block hover:border-[#14B8A6]/30 transition-all duration-300">
              <div class="bg-[#0F172A] border-b border-[#334155] h-40 flex items-center justify-center">
                <span class="text-stone-800 text-3xl font-black">{post.title.charAt(0)}</span>
              </div>
              <div class="p-5">
                <span class="px-2.5 py-0.5 rounded border border-[#14B8A6]/20 bg-[#14B8A6]/10 text-[#14B8A6] text-[9px] uppercase font-bold tracking-wider inline-block mb-2">{BLOG_CATEGORY_LABELS[post.category]}</span>
                <h3 class="font-bold text-white mb-2 group-hover:text-[#14B8A6] transition-colors line-clamp-2 text-sm">{post.title}</h3>
                <p class="text-xs text-[#E2E8F0] line-clamp-2 mb-4 leading-relaxed">{post.excerpt}</p>
                <div class="flex items-center justify-between text-[11px] text-[#94A3B8]">
                  <span class="font-mono">{formatDate(post.publishedAt)}</span>
                  <span class="flex items-center gap-1 font-mono"><Clock size={11} /> {post.readTime} min</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-[#1E2937]/30 backdrop-blur rounded-xl border border-[#334155] p-8 shadow-2xl">
          <p class="text-stone-500 text-lg">No articles found.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
