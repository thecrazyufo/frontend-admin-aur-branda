---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BlogAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { BLOG_CATEGORY_LABELS } from "@/types/blog";
import { formatDate } from "@/lib/utils";
import SectionHeader from "@/components/common/SectionHeader";
import { Clock, ArrowRight } from "lucide-react";

let blogPostsList = [];
let featured = null;
let rest = [];

try {
  blogPostsList = await BlogAPI.getAll();
  if (blogPostsList.length > 0) {
    featured = blogPostsList[0];
    rest = blogPostsList.slice(1);
  }
} catch (e) {
  console.error("Error loading blog posts:", e);
}

function getTechnicalBio(authorName: string): string {
  const bios: Record<string, string> = {
    "Alex Johnson": "12 years Windows Server admin · Written 47 migration guides",
    "Sarah Jenkins": "Lead Migration Engineer · Former Enterprise Exchange Architect",
    "Michael Torres": "Data Security Specialist · 15 years Unix/Mail Server Administrator",
  };
  return bios[authorName] || "Enterprise Migration Lead · Systems Engineer";
}
---

<BaseLayout
  title={`Blog — Email Migration Guides & Tips | ${settings?.name || ""}`}
  description="Expert guides, tutorials, and tips on email migration, backup, data recovery, and file conversion."
>
  <div class="min-h-screen bg-[#0B0F1A]">
    {/* Header */}
    <div class="bg-[#0B0F1A] py-20 text-center border-b border-[#334155] relative overflow-hidden">
      <!-- Ambient refraction glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[#6366F1]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full border" style="color: var(--signal-teal); background: rgba(0,200,160,0.08); border-color: rgba(0,200,160,0.25); font-family: var(--font-mono);">Blog</span>
        <h1 class="text-white font-extrabold text-3xl md:text-3xl tracking-tight mb-4" style="font-family: var(--font-display);">Expert Guides & Tutorials</h1>
        <p class="text-[#E2E8F0] max-w-xl mx-auto text-xs leading-relaxed" style="color: var(--type-muted);">
          Learn email migration, backup strategies, and data management from our team of experts.
        </p>
      </div>
    </div>

    <!-- Category style helper in Astro frontmatter is not required since we inline mappings directly -->
    <div class="container-custom py-20">
      {/* Featured Post */}
      {featured && (
        <div class="mb-16">
          <a
            href={`/blog/${featured.slug}`}
            class="group bg-[#1E2937]/30 backdrop-blur rounded-2xl border border-[#334155] overflow-hidden grid grid-cols-1 lg:grid-cols-2 block hover:border-[#6366F1]/30 transition-all duration-300"
          >
            <div class="bg-[#0B0F1A] border-r border-[#334155] min-h-56 flex items-center justify-center p-12">
              <span class="text-stone-800 text-3xl font-black">{featured.title.charAt(0)}</span>
            </div>
            <div class="p-8 flex flex-col justify-center">
              {featured.category === 'email-migration' && (
                <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block self-start mb-3" style="border: 1px solid rgba(0, 200, 160, 0.35); background: rgba(0, 200, 160, 0.08); color: var(--signal-teal); font-family: var(--font-mono);">EMAIL-MIGRATION</span>
              )}
              {featured.category === 'backup' && (
                <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block self-start mb-3" style="border: 1px solid rgba(177, 159, 251, 0.35); background: rgba(177, 159, 251, 0.08); color: #B19FFB; font-family: var(--font-mono);">BACKUP-STRATEGY</span>
              )}
              {featured.category !== 'email-migration' && featured.category !== 'backup' && (
                <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block self-start mb-3" style="border: 1px solid rgba(245, 158, 11, 0.35); background: rgba(245, 158, 11, 0.08); color: var(--amber-alert); font-family: var(--font-mono);">{featured.category.toUpperCase()}</span>
              )}
              <h2 class="font-bold text-white text-xl mb-3 group-hover:text-[#6366F1] transition-colors text-sm" style="font-family: var(--font-body);">{featured.title}</h2>
              <p class="text-xs text-[#E2E8F0] mb-5 line-clamp-3 leading-relaxed">{featured.excerpt}</p>
              <div class="flex items-center justify-between text-xs text-[#94A3B8]">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-[#6366F1]/10 border border-[#6366F1]/20 text-[#6366F1] flex items-center justify-center font-bold text-xs">
                    {featured.author.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-[#E2E8F0]">{featured.author.name}</p>
                    <p class="text-[9px] text-zinc-550 dark:text-zinc-500 font-mono mt-0.5 leading-tight">{getTechnicalBio(featured.author.name)}</p>
                    <p class="text-[9px] text-stone-500 font-mono mt-1">{formatDate(featured.publishedAt)}</p>
                  </div>
                </div>
                <div class="flex items-center gap-1 font-mono text-[10px]">
                  <Clock size={12} />
                  {featured.readTime} min read
                </div>
              </div>
              <div class="flex items-center gap-1 mt-5 text-[#6366F1] font-bold text-xs group-hover:gap-2 transition-all">
                Read Article <ArrowRight size={14} />
              </div>
            </div>
          </a>
        </div>
      )}

      {/* All Posts Grid */}
      <SectionHeader eyebrow="All Articles" title="Latest Posts" class="mb-12" />
      
      {rest.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {rest.map((post) => (
            <a href={`/blog/${post.slug}`} class="group bg-[#1E2937]/30 backdrop-blur rounded-xl border border-[#334155] overflow-hidden block hover:border-[#6366F1]/30 transition-all duration-300">
              <div class="bg-[#0B0F1A] border-b border-[#334155] h-40 flex items-center justify-center">
                <span class="text-stone-800 text-3xl font-black">{post.title.charAt(0)}</span>
              </div>
              <div class="p-5">
                {post.category === 'email-migration' && (
                  <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-2" style="border: 1px solid rgba(0, 200, 160, 0.35); background: rgba(0, 200, 160, 0.08); color: var(--signal-teal); font-family: var(--font-mono);">EMAIL-MIGRATION</span>
                )}
                {post.category === 'backup' && (
                  <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-2" style="border: 1px solid rgba(177, 159, 251, 0.35); background: rgba(177, 159, 251, 0.08); color: #B19FFB; font-family: var(--font-mono);">BACKUP-STRATEGY</span>
                )}
                {post.category !== 'email-migration' && post.category !== 'backup' && (
                  <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-2" style="border: 1px solid rgba(245, 158, 11, 0.35); background: rgba(245, 158, 11, 0.08); color: var(--amber-alert); font-family: var(--font-mono);">{post.category.toUpperCase()}</span>
                )}
                <h3 class="font-bold text-white mb-2 group-hover:text-[#6366F1] transition-colors line-clamp-2 text-sm">{post.title}</h3>
                <p class="text-xs text-[#E2E8F0] line-clamp-2 mb-4 leading-relaxed">{post.excerpt}</p>
                <div class="flex items-center justify-between text-[11px] text-[#94A3B8]">
                  <span class="font-mono">{formatDate(post.publishedAt)}</span>
                  <span class="flex items-center gap-1 font-mono"><Clock size={11} /> {post.readTime} min</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-[#1E2937]/30 backdrop-blur rounded-xl border border-[#334155] p-8 shadow-2xl">
          <p class="text-stone-500 text-lg">No articles found.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
