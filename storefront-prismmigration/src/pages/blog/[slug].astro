---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BlogAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { formatDate, parseMarkdownToHtml } from "@/lib/utils";
import { generateArticleSchema, generateBreadcrumbSchema } from "@/lib/seo";
import Breadcrumb from "@/components/layout/Breadcrumb";
import { Clock, ArrowLeft } from "lucide-react";

const { slug } = Astro.params;

let post = null;

try {
  if (slug) {
    post = await BlogAPI.getBySlug(slug);
  }
} catch (e) {
  console.error("Error loading blog post:", e);
}

if (!post) {
  return new Response("Blog Post Not Found", { status: 404 });
}

const siteUrl = (settings?.url || "").replace(/\/$/, "");
const articleUrl = `${siteUrl}/blog/${post.slug}`;

function getTechnicalBio(authorName: string): string {
  const bios: Record<string, string> = {
    "Alex Johnson": "12 years Windows Server admin · Written 47 migration guides",
    "Sarah Jenkins": "Lead Migration Engineer · Former Enterprise Exchange Architect",
    "Michael Torres": "Data Security Specialist · 15 years Unix/Mail Server Administrator",
  };
  return bios[authorName] || "Enterprise Migration Lead · Systems Engineer";
}
---

<BaseLayout
  title={`${post.seo.title} — ${settings?.name || ""}`}
  description={post.seo.description}
  ogType="article"
  author={post.author.name}
>
  <script type="application/ld+json"
    set:html={JSON.stringify(generateArticleSchema({
      title: post.seo.title,
      description: post.seo.description,
      authorName: post.author.name,
      publishedAt: post.publishedAt,
      url: articleUrl,
      siteName: settings?.name || ""
    }))}
  />
  <script type="application/ld+json"
    set:html={JSON.stringify(generateBreadcrumbSchema(
      [{ label: "Blog", href: "/blog" }, { label: post.title, href: `/blog/${post.slug}` }],
      siteUrl
    ))}
  />
  <Breadcrumb items={[{ label: "Blog", href: "/blog" }, { label: post.title }]} />
  <div class="bg-[#0B0F1A] min-h-screen">
    <article class="container-custom py-20 max-w-3xl">
      <a href="/blog" class="inline-flex items-center gap-2 text-xs text-[#6366F1] hover:underline mb-8 font-semibold">
        <ArrowLeft size={15} />
        Back to Blog
      </a>

      {/* Header */}
      <div class="mb-8">
        {post.category === 'email-migration' && (
          <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-3" style="border: 1px solid rgba(0, 200, 160, 0.35); background: rgba(0, 200, 160, 0.08); color: var(--signal-teal); font-family: var(--font-mono);">EMAIL-MIGRATION</span>
        )}
        {post.category === 'backup' && (
          <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-3" style="border: 1px solid rgba(177, 159, 251, 0.35); background: rgba(177, 159, 251, 0.08); color: #B19FFB; font-family: var(--font-mono);">BACKUP-STRATEGY</span>
        )}
        {post.category !== 'email-migration' && post.category !== 'backup' && (
          <span class="px-2.5 py-0.5 rounded text-[9px] uppercase font-bold tracking-wider inline-block mb-3" style="border: 1px solid rgba(245, 158, 11, 0.35); background: rgba(245, 158, 11, 0.08); color: var(--amber-alert); font-family: var(--font-mono);">{post.category.toUpperCase()}</span>
        )}
        <h1 class="font-extrabold text-white mb-4 text-3xl tracking-tight" style="font-family: var(--font-display);">{post.title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-xs text-[#E2E8F0]">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-[#6366F1]/10 border border-[#6366F1]/20 text-[#6366F1] flex items-center justify-center font-bold text-xs">
              {post.author.name.charAt(0)}
            </div>
            <div class="flex flex-col">
              <div class="flex items-center flex-wrap">
                <span class="font-semibold text-[#E2E8F0]">{post.author.name}</span>
                <span class="text-stone-500 text-[10px] ml-2 font-mono">({post.author.role})</span>
              </div>
              <div class="text-[10px] text-zinc-500 font-mono mt-0.5 leading-tight" style="letter-spacing: 0.02em;">
                {getTechnicalBio(post.author.name)}
              </div>
            </div>
          </div>
          <span>•</span>
          <span class="font-mono">{formatDate(post.publishedAt)}</span>
          <span>•</span>
          <span class="flex items-center gap-1 font-mono"><Clock size={13} /> {post.readTime} min read</span>
        </div>
      </div>

      {/* Content */}
      <div class="bg-[#1E2937]/30 backdrop-blur border border-[#334155] rounded-xl shadow-2xl p-8">
        <div class="prose prose-invert max-w-none">
          <p class="text-sm text-[#E2E8F0] mb-6 font-bold leading-relaxed">{post.excerpt}</p>
          <div class="text-stone-350 leading-relaxed text-xs space-y-4" set:html={parseMarkdownToHtml(post.content)} />
        </div>
      </div>

      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-2 py-2.5 px-5 border border-[#334155] text-[#E2E8F0] hover:text-white rounded-lg transition-colors text-xs font-bold">
          <ArrowLeft size={15} />
          Back to all articles
        </a>
      </div>
    </article>
  </div>
</BaseLayout>
