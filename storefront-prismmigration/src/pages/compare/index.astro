---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, SettingsAPI } from "@/services/api";
import SectionHeader from "@/components/common/SectionHeader";
import { Check, X, Star } from "lucide-react";
import { siteConfig } from "@/config/site";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || siteConfig.name;
const siteDescription = settings?.description || siteConfig.description;

let productsList = [];
let compareProducts = [];

try {
  productsList = await ProductAPI.getAll();
  compareProducts = productsList.slice(0, 4);
} catch (e) {
  console.error("Error loading products for compare:", e);
}

// Dynamically extract up to 10 unique features from the loaded products
const features = Array.from(
  new Set(
    compareProducts.flatMap((p) => p.features || [])
  )
).slice(0, 10);

const hasFeature = (product: any, feature: string): boolean => {
  return (product.features || []).includes(feature);
};
---

<BaseLayout
  title={`Compare Tools — ${siteName}`}
  description={siteDescription}
>
  <div>
    <div class="hero-gradient py-14 text-center">
      <div class="container-custom">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full text-blue-300 bg-white/10">Compare</span>
        <h1 class="text-white font-bold mb-3 font-bold">Compare Our Tools</h1>
        <p class="text-gray-300 max-w-lg mx-auto">Find the right tool for your needs with our side-by-side comparison.</p>
      </div>
    </div>

    <section class="section bg-gray-50">
      <div class="container-custom">
        <SectionHeader eyebrow="Comparison Table" title="Feature Comparison" centered class="mb-10" />
        <div class="overflow-x-auto">
          <table class="w-full bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden min-w-[700px]">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left p-5 font-semibold text-gray-700 w-48">Feature</th>
                {compareProducts.map((p) => (
                  <th class="p-5 text-center">
                    <a href={`/products/${p.slug}`} class="hover:text-blue-600 transition-colors">
                      <div class="font-bold text-gray-900 text-sm leading-snug mb-1">{p.name}</div>
                      <div class="flex items-center justify-center gap-1 text-amber-400 text-xs mb-2">
                        <Star size={11} fill="currentColor" />
                        <span class="text-gray-500">{p.rating}</span>
                      </div>
                      {p.badge && (
                        <span class="badge badge-blue text-xs inline-block capitalize">{p.badge}</span>
                      )}
                    </a>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {features.map((feature, i) => (
                <tr class={`border-b border-gray-55 ${i % 2 === 0 ? "bg-gray-50/40" : ""}`}>
                  <td class="p-5 text-sm font-medium text-gray-700">{feature}</td>
                  {compareProducts.map((p) => (
                    <td class="p-5 text-center">
                      {hasFeature(p, feature)
                        ? <Check size={18} class="text-green-500 mx-auto" />
                        : <X size={18} class="text-gray-200 mx-auto" />}
                    </td>
                  ))}
                </tr>
              ))}
              <tr class="border-t-2 border-gray-200 bg-gray-50/20">
                <td class="p-5 font-bold text-gray-700">Starting Price</td>
                {compareProducts.map((p) => {
                  const paid = p.pricing?.find((t) => t.price > 0);
                  return (
                    <td class="p-5 text-center">
                      <span class="font-bold text-gray-900 text-lg">${paid?.price || "0"}</span>
                      <span class="text-xs text-gray-400 ml-1">/{paid?.period || "lifetime"}</span>
                    </td>
                  );
                })}
              </tr>
              <tr>
                <td class="p-5" />
                {compareProducts.map((p) => (
                  <td class="p-5 text-center">
                    <a href={`/products/${p.slug}`} class="btn btn-primary text-sm py-2 px-4 inline-block">
                      View Details
                    </a>
                  </td>
                ))}
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
