---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SettingsAPI } from "@/services/api";

const { page } = Astro.params;

const validPages: Record<string, string> = {
  privacy: "Privacy Policy",
  terms: "Terms of Service",
  refund: "Refund Policy",
  license: "License Agreement",
};

if (!page || !validPages[page]) {
  return Astro.redirect("/404");
}

const settings = await SettingsAPI.get().catch(() => null);
const pageTitle = validPages[page];
const siteName = settings?.name || "";
const htmlContent = settings?.legalPages?.[page] || `<p>This page is currently being updated. Please check back later or <a href="/contact">contact us</a> for more information.</p>`;

export function getStaticPaths() {
  return [
    { params: { page: "privacy" } },
    { params: { page: "terms" } },
    { params: { page: "refund" } },
    { params: { page: "license" } },
  ];
}
---

<BaseLayout
  title={`${pageTitle} — ${siteName}`}
  description={`${pageTitle} for ${siteName}. Read our policies carefully.`}
>
  <section class="py-16 bg-[#F8FAFC]">
    <div class="container-custom max-w-4xl">
      <div class="mb-10 text-center">
        <h1 class="text-[#0F172A]xl md:text-[#0F172A]xl font-bold text-white mb-3">
          {pageTitle}
        </h1>
        <p class="text-[#475569] text-sm">
          Last updated: {new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </p>
      </div>

      <div
        class="bg-white/30 backdrop-blur rounded-2xl border border-[#E2E8F0] p-8 md:p-12 prose prose-invert prose-lg max-w-none
               prose-headings:text-white prose-p:text-[#0F172A] prose-a:text-[#F97316] prose-a:no-underline hover:prose-a:underline
               prose-li:text-[#0F172A] prose-strong:text-white"
        set:html={htmlContent}
      />

      <div class="mt-8 text-center">
        <p class="text-sm text-stone-500">
          If you have questions about this policy, please
          <a href="/contact" class="text-[#F97316] hover:underline ml-1">contact our support team</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
