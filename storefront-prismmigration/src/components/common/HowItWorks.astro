---
/**
 * HowItWorks — Dynamic numbered-step flow section
 * Data: Product.howItWorks[] → HowItWorksStep { step, title, description, icon }
 * Falls back to hardcoded defaults for Prism Migration if no product data.
 *
 * Icon handling:
 *  - If icon is a proper emoji (e.g. "📂") → render it
 *  - If icon is a Lucide name string (e.g. "arrow-right") → map to inline SVG
 *  - If icon is missing or unrecognised → render the step number
 */

interface HowItWorksStep {
  step: number;
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  steps?: HowItWorksStep[];
  title?: string;
  subtitle?: string;
}

const { steps, title = "How It Works", subtitle = "Start migrating in 3 simple steps — no technical expertise required." } = Astro.props;

const defaultSteps: HowItWorksStep[] = [
  {
    step: 1,
    title: "Select Your Source",
    description: "Choose your source file or mailbox format — PST, MBOX, OST, Gmail, Office 365, or any supported format. The tool auto-detects structure and metadata.",
    icon: "📂"
  },
  {
    step: 2,
    title: "Configure & Preview",
    description: "Pick your target format and fine-tune options: date filters, folder mapping, attachment handling. Preview a sample before committing to the full run.",
    icon: "⚙️"
  },
  {
    step: 3,
    title: "Migrate & Verify",
    description: "Run the conversion locally on your machine. Every item is double-checksum verified. Export a full report when done — zero data left behind.",
    icon: "✅"
  }
];

const displaySteps = (steps && steps.length > 0) ? steps : defaultSteps;

/**
 * Returns true if the string is a proper emoji character (not an ASCII/Lucide name).
 * Emojis have code points > 0x2600.
 */
function isEmoji(str: string): boolean {
  if (!str || str.length === 0) return false;
  const cp = str.codePointAt(0);
  return cp !== undefined && cp > 0x2600;
}

/**
 * Maps common Lucide icon names used in migration/software context → inline SVG paths.
 * Returns null if not found (caller falls back to step number).
 */
function getLucideSvgPath(name: string): string | null {
  const paths: Record<string, string> = {
    "download":       "M8 3v7m0 0-3-3m3 3 3-3M3 13h10",
    "upload":         "M8 13V6m0 0L5 9m3-3 3 3M3 3h10",
    "arrow-right":    "M3 12h18M15 6l6 6-6 6",
    "arrow-down":     "M8 3v10M4 9l4 4 4-4",
    "check":          "M3 8l4 4 6-6",
    "check-circle":   "M15 12A7 7 0 1 1 1 12a7 7 0 0 1 14 0zM5 12l3 3 5-5",
    "settings":       "M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM2 12h1M21 12h1M12 2v1M12 21v1M4.22 4.22l.71.71M19.07 4.22l-.71.71M4.22 19.78l.71-.71M19.07 19.78l-.71-.71",
    "folder":         "M2 6a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6z",
    "folder-open":    "M2 8a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8zM2 12h18",
    "file":           "M4 2h8l6 6v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zM12 2v6h6",
    "mail":           "M3 5h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zM2 6l8 6 8-6",
    "database":       "M12 2C7.03 2 3 3.79 3 6v12c0 2.21 4.03 4 9 4s9-1.79 9-4V6c0-2.21-4.03-4-9-4zM3 12c0 2.21 4.03 4 9 4s9-1.79 9-4M3 9c0 2.21 4.03 4 9 4s9-1.79 9-4",
    "shield":         "M12 2l7 4v6c0 4.41-3.13 8.5-7 10-3.87-1.5-7-5.59-7-10V6l7-4z",
    "shield-check":   "M12 2l7 4v6c0 4.41-3.13 8.5-7 10-3.87-1.5-7-5.59-7-10V6l7-4zM8 12l3 3 5-5",
    "lock":           "M7 11V7a5 5 0 0 1 10 0v4M3 11h14a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1z",
    "zap":            "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
    "cpu":            "M9 2H7a1 1 0 0 0-1 1v2H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h2v2a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-2h2a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-2V3a1 1 0 0 0-1-1H9zM9 9h6v6H9V9z",
    "monitor":        "M2 3h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zM7 17h6M10 14v3",
    "cloud":          "M17.5 19A4.5 4.5 0 0 0 22 14.5c0-2.49-2.01-4.5-4.5-4.5-.61 0-1.19.12-1.72.34C15.04 7.93 13.13 6 10.5 6 7.46 6 5 8.46 5 11.5c0 .17.01.34.02.5H5a4 4 0 0 0 0 8h12.5z",
    "play":           "M5 3l14 9-14 9V3z",
    "play-circle":    "M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zM10 8l6 4-6 4V8z",
    "refresh-cw":     "M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15",
    "repeat":         "M17 1l4 4-4 4M3 11V9a4 4 0 0 1 4-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3",
    "layers":         "M12 2l9 5-9 5-9-5 9-5zM3 12l9 5 9-5M3 17l9 5 9-5",
    "package":        "M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16zM3.27 6.96L12 12.01l8.73-5.05M12 22.08V12",
    "copy":           "M20 9h-9a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-9a2 2 0 0 0-2-2zM5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1",
    "terminal":       "M4 17l6-6-6-6M12 19h8",
    "code":           "M16 18l6-6-6-6M8 6l-6 6 6 6",
    "search":         "M11 5a6 6 0 1 0 0 12A6 6 0 0 0 11 5zM20 20l-4.35-4.35",
    "list":           "M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01",
    "user":           "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z",
    "users":          "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
    "key":            "M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4",
  };
  return paths[name] ?? null;
}
---

<section class="bg-[#0B0F1A] py-20 relative overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[200px] blur-[110px] rounded-full" style="background: rgba(0,200,160,0.04);"></div>
  </div>

  <div class="container-custom mx-auto px-4 relative z-10">
    <div class="text-center mb-16 animate-fade-up">
      <span class="inline-block text-[10px] font-bold uppercase tracking-widest border px-3 py-1 rounded mb-4" style="color: var(--signal-teal); background: rgba(0,200,160,0.08); border-color: rgba(0,200,160,0.25); font-family: var(--font-mono);">
        Simple Process
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-4 tracking-tight" style="font-family: var(--font-display);">{title}</h2>
      <p class="text-sm mt-3 max-w-lg mx-auto leading-relaxed" style="color: var(--type-muted);">{subtitle}</p>
    </div>

    <div class={`grid gap-6 md:gap-0 relative max-w-5xl mx-auto ${displaySteps.length === 3 ? 'grid-cols-1 md:grid-cols-3' : displaySteps.length === 4 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4' : 'grid-cols-1 md:grid-cols-2'}`}>
      <!-- Connector line between step circles (desktop only) -->
      {displaySteps.length <= 4 && (
        <div class="hidden md:block absolute top-[52px] left-[calc(16.67%+16px)] right-[calc(16.67%+16px)] h-px z-0" style="background: linear-gradient(90deg, rgba(0,200,160,0.0), rgba(0,200,160,0.3), rgba(0,200,160,0.3), rgba(0,200,160,0.0));" aria-hidden="true"></div>
      )}

      {displaySteps.map((step, idx) => {
        const iconStr = step.icon ?? "";
        const emoji = isEmoji(iconStr) ? iconStr : null;
        const svgPath = !emoji ? getLucideSvgPath(iconStr) : null;

        return (
          <div
            class={`relative z-10 flex flex-col items-center text-center px-6 pb-8 pt-2 ${idx < displaySteps.length - 1 ? 'md:border-r md:border-dashed' : ''}`}
            style="border-color: var(--circuit-line);"
          >
            <!-- Step circle -->
            <div class="relative mb-6">
              <div
                class="w-16 h-16 rounded-full flex items-center justify-center border-2 shadow-lg"
                style="background: var(--slate-surface); border-color: rgba(0,200,160,0.4); box-shadow: 0 0 20px rgba(0,200,160,0.12);"
              >
                {emoji ? (
                  <!-- Emoji icon -->
                  <span class="text-2xl leading-none select-none">{emoji}</span>
                ) : svgPath ? (
                  <!-- Lucide icon mapped to inline SVG -->
                  <svg
                    width="26"
                    height="26"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color: var(--signal-teal);"
                    aria-hidden="true"
                  >
                    <path d={svgPath} />
                  </svg>
                ) : (
                  <!-- Fallback: step number -->
                  <span class="text-2xl font-black" style="color: var(--signal-teal); font-family: var(--font-mono);">
                    {String(step.step).padStart(2, '0')}
                  </span>
                )}
              </div>
              <!-- Step number badge -->
              <span
                class="absolute -top-1 -right-1 w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-black border"
                style="background: var(--ink-void); color: var(--signal-teal); border-color: rgba(0,200,160,0.4); font-family: var(--font-mono);"
              >
                {step.step}
              </span>
            </div>

            <h3 class="text-sm font-bold text-white mb-2 tracking-tight" style="font-family: var(--font-display);">{step.title}</h3>
            <p class="text-[11px] leading-relaxed" style="color: var(--type-muted);">{step.description}</p>
          </div>
        );
      })}
    </div>

    <!-- CTA below steps -->
    <div class="text-center mt-12">
      <a
        href="/download"
        class="cta-pulse-wrap inline-flex items-center gap-2 text-xs font-bold py-3 px-8 rounded-lg transition-all duration-300 border"
        style="background: rgba(0,200,160,0.08); color: var(--signal-teal); border-color: rgba(0,200,160,0.3); font-family: var(--font-mono);"
        onmouseover="this.style.background='rgba(0,200,160,0.15)'; this.style.borderColor='rgba(0,200,160,0.5)';"
        onmouseout="this.style.background='rgba(0,200,160,0.08)'; this.style.borderColor='rgba(0,200,160,0.3)';"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v7m0 0-3-3m3 3 3-3M3 13h10"/></svg>
        Try Free — Download Installer
      </a>
    </div>
  </div>
</section>
