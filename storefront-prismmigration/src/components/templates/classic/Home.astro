---
import ProductCard from "@/components/common/ProductCard";
import SectionHeader from "@/components/common/SectionHeader";
import LogoStrip from "@/components/common/LogoStrip.astro";
import TestimonialCarousel from "@/components/common/TestimonialCarousel.astro";

const { products, categories, settings, featured, testimonials, clientLogos } = Astro.props;

const iconMap: Record<string, string> = {
  mail: "✉️", shield: "🛡️", "refresh-cw": "🔄", cloud: "☁️", "hard-drive": "💾", download: "⬇️",
};

const colorMap: Record<string, string> = {
  mail: "text-blue-600 bg-blue-500/10 border-blue-500/20", 
  shield: "text-emerald-600 bg-emerald-500/10 border-emerald-500/20", 
  "refresh-cw": "text-purple-600 bg-purple-500/10 border-purple-500/20", 
  cloud: "text-cyan-600 bg-cyan-500/10 border-cyan-500/20", 
  "hard-drive": "text-orange-600 bg-orange-500/10 border-orange-500/20", 
  download: "text-pink-600 bg-pink-500/10 border-pink-500/20",
};

const siteName = settings?.name || "";
const siteTagline = settings?.tagline || "";
const siteDescription = settings?.description || "";
const siteStats = settings?.stats || [];
const siteBadges = settings?.trustBadges || [];
---

  <!-- Hero Banner -->
  <section class="relative overflow-hidden pt-32 pb-24 md:pt-40 md:pb-32 border-b border-[--color-hairline]">
    <!-- Vercel-style Vibrant Hero Mesh Gradient -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-[800px] pointer-events-none z-0 flex justify-center opacity-50 mix-blend-multiply dark:mix-blend-screen dark:opacity-30">
      <div class="absolute top-[10%] left-[10%] w-[500px] h-[500px] bg-[--color-gradient-develop-start] rounded-full blur-[120px] opacity-80" style="animation: mesh-breathe 12s infinite alternate;"></div>
      <div class="absolute top-[5%] right-[10%] w-[400px] h-[400px] bg-[--color-gradient-preview-start] rounded-full blur-[100px] opacity-80" style="animation: mesh-breathe 14s infinite reverse;"></div>
      <div class="absolute top-[30%] left-[30%] w-[600px] h-[600px] bg-[--color-gradient-ship-end] rounded-full blur-[140px] opacity-60" style="animation: mesh-breathe 16s infinite alternate;"></div>
      <div class="absolute -top-[10%] left-[50%] w-[450px] h-[450px] bg-[--color-gradient-develop-end] rounded-full blur-[110px] opacity-70" style="animation: mesh-breathe 18s infinite reverse;"></div>
    </div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-5xl mx-auto text-center flex flex-col items-center">
        <div class="inline-flex items-center justify-center gap-2 text-[13px] font-semibold text-[--color-ink] mb-8 px-4 py-1.5 rounded-full border border-[--color-hairline] bg-[rgba(0,0,0,0.02)] shadow-sm backdrop-blur-sm hover:scale-105 transition-transform cursor-default">
          <span class="w-2 h-2 rounded-full bg-[--color-success] animate-pulse"></span>
          {settings?.hero?.badgeText || "Trusted by IT Professionals & Enterprises Worldwide"}
        </div>

        <h1 class="text-[--color-ink] mb-8 max-w-4xl mx-auto font-bold tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-[--color-ink] to-[--color-mute]">
          {settings?.hero?.headline || siteTagline}
        </h1>

        <p class="text-[18px] md:text-[20px] text-[--color-body] mb-12 max-w-2xl mx-auto leading-relaxed">
          {settings?.hero?.subheadline || siteDescription}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20 w-full sm:w-auto">
          <a href={settings?.hero?.ctaPrimaryHref || "/download"} class="btn btn-primary text-[15px] py-3.5 px-8 w-full sm:w-auto shadow-[0_0_20px_rgba(0,112,243,0.3)] hover:shadow-[0_0_30px_rgba(0,112,243,0.5)] transition-all border border-black group">
            {settings?.hero?.ctaPrimaryText || "Start Deploying"}
            <span class="group-hover:translate-x-1 transition-transform ml-1">→</span>
          </a>
          <a href={settings?.hero?.ctaSecondaryHref || "/products"} class="btn bg-[rgba(0,0,0,0.04)] text-[--color-ink] hover:bg-[rgba(0,0,0,0.08)] text-[15px] py-3.5 px-8 w-full sm:w-auto transition-colors border border-[--color-hairline]">
            {settings?.hero?.ctaSecondaryText || "Explore Products"}
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[--color-hairline] rounded-xl overflow-hidden shadow-sm max-w-3xl mx-auto w-full">
          {siteStats.map((stat) => (
            <div class="bg-[--color-canvas] p-6 text-center hover:bg-[--color-canvas-soft] transition-colors">
              <div class="text-[28px] font-bold text-[--color-ink] tracking-tight mb-1">{stat.value}</div>
              <div class="text-[13px] font-medium text-[--color-mute]">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Dynamic Logo Strip -->
  <LogoStrip logos={clientLogos} />

  <!-- Trust Badges -->
  <section class="py-12 bg-[--color-canvas-soft] border-b border-[--color-hairline]">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {siteBadges.map((badge) => (
          <div class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-[rgba(0,0,0,0.02)] transition-colors group">
            <div class="w-12 h-12 rounded-full bg-[--color-canvas] border border-[--color-hairline] shadow-sm flex items-center justify-center mb-4 group-hover:-translate-y-1 transition-transform text-xl">
              {badge.emoji}
            </div>
            <h4 class="text-[14px] font-semibold text-[--color-ink] mb-1 tracking-tight">{badge.title}</h4>
            <p class="text-[12px] text-[--color-mute] leading-relaxed">{badge.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section bg-[--color-canvas]">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <SectionHeader
          eyebrow="Top Products"
          title="Our Best-Selling Tools"
          subtitle="Trusted by IT professionals and enterprises across 150+ countries."
        />
        <a href="/products" class="btn bg-[rgba(0,0,0,0.03)] text-[--color-ink] border border-[--color-hairline] hover:bg-[rgba(0,0,0,0.06)] shrink-0 text-[14px] py-2 px-5 transition-colors">
          View All Products →
        </a>
      </div>

      {featured.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featured.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center text-center py-24 px-6 border border-dashed border-[--color-hairline] rounded-3xl bg-[--color-canvas-soft] max-w-2xl mx-auto my-6 relative overflow-hidden transition-all duration-300 group hover:border-[--color-hairline-strong] hover:shadow-xl hover:shadow-[rgba(0,0,0,0.2)]">
          {/* Subtle Backing Glow */}
          <div class="absolute -top-12 -left-12 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl pointer-events-none"></div>
          <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-purple-500/10 rounded-full blur-2xl pointer-events-none"></div>
          
          {/* Beautiful Cloud-with-Arrow or Database Disconnected Icon */}
          <div class="relative w-18 h-18 bg-[rgba(255,255,255,0.02)] border border-[--color-hairline] rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:scale-105 transition-transform duration-300">
            <svg class="w-8 h-8 text-[--color-mute] group-hover:text-blue-400 transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.5 19A3.5 3.5 0 0 0 21 15.5c0-2.79-2.54-4.5-5-4.5-.42 0-.83.04-1.24.12C14 7.74 11.46 5 8 5c-3.87 0-7 3.13-7 7 0 2.22 1.03 4.2 2.65 5.5"/>
              <path d="M12 11v6m0 0-3-3m3 3 3-3" class="animate-bounce" style="animation-duration: 2s;"/>
              <path d="M22 2 2 22" class="stroke-red-500/80" stroke-width="2"/>
            </svg>
            <div class="absolute -bottom-1.5 -right-1.5 w-5.5 h-5.5 bg-red-950/80 border border-red-500/30 rounded-full flex items-center justify-center text-[10px] shadow-sm select-none">
              ⚠️
            </div>
          </div>
          
          {/* Friendly Status Messages */}
          <h3 class="text-[18px] md:text-[20px] font-bold text-white mb-3 tracking-tight">Products Temporarily Unavailable</h3>
          <p class="text-[14px] text-[--color-body] max-w-md mb-8 leading-relaxed">
            Unable to load products right now. Our servers are taking a short break. Please verify that your system backend is online.
          </p>
          
          {/* Action Button */}
          <div class="flex items-center gap-3">
            <button 
              onclick="window.location.reload()" 
              class="btn-retry cursor-pointer select-none px-6 py-2.5 bg-white hover:bg-neutral-100 text-neutral-950 rounded-xl text-[13px] font-bold shadow-lg shadow-white/5 active:scale-[0.98] transition-all duration-150 border-[#E2E8F0] flex items-center gap-2"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                <path d="M16 3h5v5"/>
                <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                <path d="M8 21H3v-5"/>
              </svg>
              Retry Connection
            </button>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Category Section -->
  {categories.length > 0 && (
    <section class="section bg-[--color-canvas-soft] border-t border-[--color-hairline]">
      <div class="container-custom">
        <SectionHeader
          eyebrow="Categories"
          title="Browse by Solution"
          subtitle="Find the right tool for your specific data management needs."
          centered
          className="mb-12"
        />

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {categories.map((cat) => {
            return (
              <a
                href={`/products?category=${cat.id}`}
                class="group bg-[--color-canvas] rounded-xl border border-[--color-hairline] p-6 transition-all duration-300 hover:shadow-md hover:-translate-y-1"
              >
                <div class="flex items-start justify-between mb-6">
                  <div class={`w-12 h-12 rounded-lg border flex items-center justify-center group-hover:scale-110 transition-transform duration-300 text-xl shadow-sm ${colorMap[cat.icon] || 'bg-[rgba(0,0,0,0.03)] border-[--color-hairline] text-[--color-ink]'}`}>
                    {iconMap[cat.icon] || "📦"}
                  </div>
                  <span class="text-[12px] text-[--color-ink] font-medium bg-[rgba(0,0,0,0.04)] px-2.5 py-1 rounded-full border border-[--color-hairline]">
                    {cat.count} tools
                  </span>
                </div>
                <h3 class="font-semibold text-[--color-ink] text-[18px] tracking-tight mb-2 group-hover:text-[--color-accent] transition-colors">{cat.label}</h3>
                <p class="text-[14px] text-[--color-body] leading-relaxed line-clamp-2">{cat.description}</p>
                <div class="flex items-center gap-1 mt-6 text-[13px] font-semibold text-[--color-ink] group-hover:text-[--color-accent] transition-colors">
                  View Tools <span class="group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Testimonials -->
  <TestimonialCarousel testimonials={testimonials} />

      <!-- Overall Rating -->
      <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-8 py-10 bg-[--color-canvas-soft] rounded-2xl border border-[--color-hairline] shadow-sm max-w-4xl mx-auto">
        <div class="text-center w-40">
          <div class="text-[40px] font-bold text-[--color-ink] tracking-tighter leading-none mb-2">4.8</div>
          <div class="flex justify-center text-[--color-ink] text-[16px] mb-1">★★★★★</div>
          <div class="text-[12px] font-medium text-[--color-mute] uppercase tracking-wider">Average Rating</div>
        </div>
        <div class="w-px h-16 bg-[--color-hairline] hidden sm:block"></div>
        <div class="text-center w-40">
          <div class="text-[40px] font-bold text-[--color-ink] tracking-tighter leading-none mb-3">8.6k+</div>
          <div class="text-[12px] font-medium text-[--color-mute] uppercase tracking-wider">Verified Reviews</div>
        </div>
        <div class="w-px h-16 bg-[--color-hairline] hidden sm:block"></div>
        <div class="text-center w-40">
          <div class="text-[40px] font-bold text-[--color-ink] tracking-tighter leading-none mb-3">150+</div>
          <div class="text-[12px] font-medium text-[--color-mute] uppercase tracking-wider">Countries</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="py-24 bg-[--color-ink] border-t border-[--color-hairline] relative overflow-hidden">
    <!-- Subtle glow in the dark section -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-[--color-gradient-develop-start] opacity-[0.08] blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="container-custom text-center relative z-10">
      <h2 class="text-[--color-canvas] font-bold mb-6 text-[32px] md:text-[40px] tracking-tight">Ready to Deploy?</h2>
      <p class="text-[--color-mute] mb-10 max-w-xl mx-auto text-[16px] md:text-[18px]">
        Try any tool free. No credit card required. Migrate up to 50 items in trial mode.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/download" class="btn bg-[--color-canvas] text-[--color-ink] hover:scale-105 transition-transform text-[15px] py-3.5 px-8 rounded-md font-semibold shadow-lg">
          Deploy Free Trial
        </a>
        <a href="/products" class="btn bg-[rgba(255,255,255,0.05)] text-[--color-canvas] hover:bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.1)] text-[15px] py-3.5 px-8 rounded-md font-medium transition-colors">
          Browse All Products
        </a>
      </div>
    </div>
  </section>
