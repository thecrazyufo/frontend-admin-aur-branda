---
import type { Product } from "@/types/product";
import type { Category } from "@/services/api";
import ProductCard from "@/components/common/ProductCard";

interface Testimonial {
  authorName: string;
  authorTitle: string;
  company: string;
  rating: number;
  content: string;
}

const { categories, settings, featured, testimonials, clientLogos = [] } = Astro.props;

const logosList = clientLogos.length > 0 ? clientLogos.slice(0, 12) : [
  { companyName: "Google Workspace", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/google-workspace.svg" },
  { companyName: "Microsoft 365", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/microsoft-365.svg" },
  { companyName: "Salesforce", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/salesforce.svg" },
  { companyName: "Slack", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/slack-icon.svg" },
  { companyName: "AWS", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/aws.svg" },
  { companyName: "Dropbox", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/dropbox.svg" },
  { companyName: "Box", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/box.svg" },
  { companyName: "Zoom", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/zoom.svg" },
  { companyName: "MySQL", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/mysql-icon.svg" },
  { companyName: "PostgreSQL", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/postgresql.svg" },
  { companyName: "MongoDB", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/mongodb-icon.svg" },
  { companyName: "SAP", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/sap.svg" },
];

const siteName = settings?.name || "Prism Migration";
const siteTagline = settings?.tagline || "Enterprise Mailbox & Database Migrators. Built to Run Locally.";
const siteDescription = settings?.description || "Preserve folder structures, validate integrity with double checksums, and stream files at maximum connection speed. 100% private, on-premise execution.";
const siteStats = settings?.stats || [];

const iconMap: Record<string, string> = {
  mail: "✉️", shield: "🛡️", "refresh-cw": "🔄", cloud: "☁️", "hard-drive": "💾", download: "⬇️",
};

const categoryIconMap: Record<string, string> = {
  "email-migration": "✉️",
  "backup": "💾",
  "file-converter": "🔄",
  "cloud-migration": "☁️",
  "mailbox-recovery": "🛡️",
  "data-export": "📤",
};

const categoryColorMap: Record<string, { text: string; bg: string; border: string; glow: string }> = {
  "email-migration": { text: "text-[#6366F1]", bg: "bg-[#6366F1]/10", border: "border-[#6366F1]/20", glow: "shadow-[0_0_15px_rgba(99, 102, 241,0.15)]" },
  "backup": { text: "text-[#3b82f6]", bg: "bg-[#3b82f6]/10", border: "border-[#3b82f6]/20", glow: "shadow-[0_0_15px_rgba(59,130,246,0.15)]" },
  "file-converter": { text: "text-[#10b981]", bg: "bg-[#10b981]/10", border: "border-[#10b981]/20", glow: "shadow-[0_0_15px_rgba(99, 102, 241,0.15)]" },
  "cloud-migration": { text: "text-[#a855f7]", bg: "bg-[#a855f7]/10", border: "border-[#a855f7]/20", glow: "shadow-[0_0_15px_rgba(168,85,247,0.15)]" },
  "mailbox-recovery": { text: "text-[#ef4444]", bg: "bg-[#ef4444]/10", border: "border-[#ef4444]/20", glow: "shadow-[0_0_15px_rgba(239,68,68,0.15)]" },
};
---

<!-- Sleek SaaS Hero Section (Premium Dark Theme) -->
<section class="relative overflow-hidden bg-[#0B0F1A] pt-6 pb-10 md:pt-8 md:pb-12 tech-grid">
  <!-- Cinematic Glowing Lights & Mesh Gradients -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden z-0" aria-hidden="true">
    <!-- Center light source (warm coral/violet gradient blend) -->
    <div class="absolute top-[18%] left-1/2 -translate-x-1/2 w-[65%] h-[60%] rounded-full bg-gradient-to-br from-[#FB923C]/18 via-[#A855F7]/12 to-transparent blur-[140px] opacity-90"></div>
    <!-- Bottom light source -->
    <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-[#0B0F1A] to-transparent z-10"></div>
  </div>

  <!-- Giant Glass Prism & Refraction Rays SVG (Stretches from left to right corner) -->
  <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden flex items-center justify-center" aria-hidden="true">
    <svg class="w-[135%] h-[115%] md:w-[125%] md:h-[105%] opacity-[0.55] scale-100 md:scale-105" viewBox="0 0 1200 600" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <!-- Light Beam Gradients for Left-side Input Streams (low opacity — stay behind text) -->
        <linearGradient id="rayGmailSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#FB923C" stop-opacity="0" />
          <stop offset="100%" stop-color="#F472B6" stop-opacity="0.25" />
        </linearGradient>
        <linearGradient id="rayOutlookSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6366F1" stop-opacity="0" />
          <stop offset="100%" stop-color="#6366F1" stop-opacity="0.25" />
        </linearGradient>
        <linearGradient id="rayThunderbirdSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#FB923C" stop-opacity="0" />
          <stop offset="100%" stop-color="#FB923C" stop-opacity="0.25" />
        </linearGradient>
        <linearGradient id="rayFileSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#F472B6" stop-opacity="0" />
          <stop offset="100%" stop-color="#FB923C" stop-opacity="0.25" />
        </linearGradient>
        <linearGradient id="rayCloudSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6366F1" stop-opacity="0" />
          <stop offset="100%" stop-color="#6366F1" stop-opacity="0.25" />
        </linearGradient>

        <!-- Right-side Refracted Output Rays: 2 saturated (indigo + coral), 2 desaturated texture -->
        <!-- SATURATED #1: Indigo anchor -->
        <linearGradient id="rayGold" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6C5CE7" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#6C5CE7" stop-opacity="0" />
        </linearGradient>
        <!-- DESATURATED texture — near-neutral gray-violet -->
        <linearGradient id="rayCyan" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6B7280" stop-opacity="0.25" />
          <stop offset="100%" stop-color="#6B7280" stop-opacity="0" />
        </linearGradient>
        <!-- SATURATED #2: Coral-amber anchor -->
        <linearGradient id="rayPurple" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#FB923C" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#F472B6" stop-opacity="0" />
        </linearGradient>
        <!-- DESATURATED texture — near-neutral gray-violet -->
        <linearGradient id="rayBlue" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6B7280" stop-opacity="0.20" />
          <stop offset="100%" stop-color="#6B7280" stop-opacity="0" />
        </linearGradient>

        <!-- Glass Prism 3D Gradient -->
        <linearGradient id="prismFaceLeft" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#6366F1" stop-opacity="0.35" />
          <stop offset="100%" stop-color="#312E81" stop-opacity="0.05" />
        </linearGradient>
        <linearGradient id="prismFaceRight" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0.2" />
          <stop offset="100%" stop-color="#6366F1" stop-opacity="0.02" />
        </linearGradient>

        <!-- Radial glow behind pyramid/headline -->
        <radialGradient id="coralVioletGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#FB923C" stop-opacity="0.18" />
          <stop offset="60%" stop-color="#A855F7" stop-opacity="0.12" />
          <stop offset="100%" stop-color="#A855F7" stop-opacity="0" />
        </radialGradient>
        
        <!-- Glow Filter — generic soft -->
        <filter id="cinematicGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="8" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        <filter id="softGlow" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="20" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        <!-- Per-icon vivid glow filters -->
        <filter id="glowRose" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#FB7185" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowBlue" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#60A5FA" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowIndigo" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#818CF8" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowTeal" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#2DD4BF" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowAmber" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#FCD34D" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowViolet" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#C084FC" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glowOrange" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="6" result="b" />
          <feFlood flood-color="#FB923C" flood-opacity="0.8" result="c" />
          <feComposite in="c" in2="b" operator="in" result="g" />
          <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>

        <!-- PDF Document Icon — vivid rose fill -->
        <g id="pdfIcon">
          <rect x="-11" y="-14" width="22" height="28" rx="4" fill="#FB7185" />
          <rect x="-11" y="-14" width="22" height="28" rx="4" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <path d="M 3 -14 L 11 -7 L 3 -7 Z" fill="#ffffff" fill-opacity="0.5" />
          <text x="0" y="9" fill="#ffffff" font-size="8" font-family="monospace" text-anchor="middle" font-weight="900">PDF</text>
        </g>

        <!-- DOCX Document Icon — vivid sky blue fill -->
        <g id="docxIcon">
          <rect x="-11" y="-14" width="22" height="28" rx="4" fill="#3B82F6" />
          <rect x="-11" y="-14" width="22" height="28" rx="4" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <path d="M 3 -14 L 11 -7 L 3 -7 Z" fill="#ffffff" fill-opacity="0.5" />
          <text x="0" y="9" fill="#ffffff" font-size="7" font-family="monospace" text-anchor="middle" font-weight="900">DOCX</text>
        </g>

        <!-- Email Envelope Icon — vivid indigo fill -->
        <g id="emailIcon">
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="#6C5CE7" />
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <path d="M -12 -9 L 0 2 L 12 -9" stroke="#ffffff" stroke-width="1.8" fill="none" stroke-linejoin="round" />
        </g>

        <!-- Cloud Storage Icon — vivid sky fill -->
        <g id="cloudIcon">
          <path d="M -8 4 C -11 4, -13 2, -13 -1.5 C -13 -5, -10.5 -7.5, -7 -7.5 C -6 -10.5, -3 -12, 1 -12 C 5.5 -12, 8 -9, 8 -6.5 C 10.5 -6.5, 13 -4.5, 13 -1.5 C 13 2, 10 4, 6.5 4 Z" fill="#60A5FA" />
          <path d="M -8 4 C -11 4, -13 2, -13 -1.5 C -13 -5, -10.5 -7.5, -7 -7.5 C -6 -10.5, -3 -12, 1 -12 C 5.5 -12, 8 -9, 8 -6.5 C 10.5 -6.5, 13 -4.5, 13 -1.5 C 13 2, 10 4, 6.5 4 Z" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
        </g>

        <!-- Folder Directory Icon — vivid violet fill -->
        <g id="folderIcon">
          <path d="M -12 7 L -12 -9 L -4 -9 L -1 -5 L 10 -5 L 10 7 Z" fill="#A855F7" />
          <path d="M -12 7 L -12 -9 L -4 -9 L -1 -5 L 10 -5 L 10 7 Z" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" stroke-linejoin="round" />
        </g>

        <!-- Outlook Icon — authentic Microsoft Outlook (blue + O circle) -->
        <g id="outlookIcon">
          <!-- Microsoft blue card -->
          <rect x="-13" y="-12" width="26" height="24" rx="4" fill="#0078D4"/>
          <!-- White document shape (behind the O) -->
          <rect x="0" y="-9" width="12" height="18" rx="2" fill="white" opacity="0.92"/>
          <!-- Subtle document lines -->
          <line x1="2" y1="-5" x2="10" y2="-5" stroke="#0078D4" stroke-width="1.2" opacity="0.4"/>
          <line x1="2" y1="-1" x2="10" y2="-1" stroke="#0078D4" stroke-width="1.2" opacity="0.4"/>
          <line x1="2" y1="3" x2="10" y2="3" stroke="#0078D4" stroke-width="1.2" opacity="0.4"/>
          <line x1="2" y1="7" x2="10" y2="7" stroke="#0078D4" stroke-width="1.2" opacity="0.4"/>
          <!-- Blue O circle overlapping document -->
          <circle cx="-3.5" cy="1" r="7.5" fill="#0078D4"/>
          <!-- White O ring (the letter O) -->
          <circle cx="-3.5" cy="1" r="4.5" fill="none" stroke="white" stroke-width="2.5"/>
        </g>

        <!-- Gmail Icon — authentic Google Gmail M envelope -->
        <g id="gmailIcon">
          <!-- White card background -->
          <rect x="-13" y="-12" width="26" height="24" rx="4" fill="#FFFFFF" stroke="#E5E7EB" stroke-width="0.5"/>
          <!-- Red envelope body -->
          <rect x="-11" y="-9" width="22" height="19" rx="1" fill="#EA4335"/>
          <!-- Fold shadow triangles (darker red) for depth -->
          <path d="M -11,-9 L 0,-1 L -11,-1 Z" fill="#C5221F" opacity="0.4"/>
          <path d="M 11,-9 L 0,-1 L 11,-1 Z" fill="#C5221F" opacity="0.4"/>
          <!-- White M crease line (the iconic Gmail M) -->
          <path d="M -11,-9 L 0,-1 L 11,-9" fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round"/>
        </g>

        <!-- Thunderbird Icon — vivid teal fill -->
        <g id="thunderbirdIcon">
          <rect x="-11" y="-11" width="22" height="22" rx="4" fill="#14B8A6" />
          <rect x="-11" y="-11" width="22" height="22" rx="4" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <text x="0" y="5.5" fill="#ffffff" font-size="13" font-family="sans-serif" font-weight="900" text-anchor="middle">T</text>
        </g>

        <!-- PST Tag — vivid amber fill -->
        <g id="pstIcon">
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="#F59E0B" />
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <text x="0" y="5" fill="#ffffff" font-size="8" font-family="monospace" text-anchor="middle" font-weight="900">PST</text>
        </g>

        <!-- EML Tag — vivid emerald fill -->
        <g id="emlIcon">
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="#10B981" />
          <rect x="-12" y="-9" width="24" height="18" rx="3" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <text x="0" y="5" fill="#ffffff" font-size="8" font-family="monospace" text-anchor="middle" font-weight="900">EML</text>
        </g>

        <!-- MBOX Tag — vivid orange fill -->
        <g id="mboxIcon">
          <rect x="-13" y="-9" width="26" height="18" rx="3" fill="#FB923C" />
          <rect x="-13" y="-9" width="26" height="18" rx="3" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <text x="0" y="5" fill="#ffffff" font-size="7.5" font-family="monospace" text-anchor="middle" font-weight="900">MBOX</text>
        </g>

        <!-- Google Icon — authentic multicolor Google G -->
        <g id="googleIcon">
          <!-- White circle background -->
          <circle cx="0" cy="0" r="12.5" fill="white" stroke="#E5E7EB" stroke-width="0.5"/>
          <!-- Google G: 4 colored arc segments going clockwise from lower gap (~4 o'clock) -->
          <!-- Yellow: 4 o'clock → 6 o'clock (60°) -->
          <path d="M 8.2,4.75 A 9.5,9.5 0 0 1 0,9.5" fill="none" stroke="#FBBC05" stroke-width="3.6" stroke-linecap="butt"/>
          <!-- Green: 6 o'clock → 9 o'clock (90°) -->
          <path d="M 0,9.5 A 9.5,9.5 0 0 1 -9.5,0" fill="none" stroke="#34A853" stroke-width="3.6" stroke-linecap="butt"/>
          <!-- Blue: 9 o'clock → 1 o'clock over top (120°) -->
          <path d="M -9.5,0 A 9.5,9.5 0 0 1 4.75,-8.2" fill="none" stroke="#4285F4" stroke-width="3.6" stroke-linecap="butt"/>
          <!-- Red: 1 o'clock → upper gap ~2 o'clock (30°) -->
          <path d="M 4.75,-8.2 A 9.5,9.5 0 0 1 8.2,-4.75" fill="none" stroke="#EA4335" stroke-width="3.6" stroke-linecap="butt"/>
          <!-- White inner circle (creates the G ring/donut hole) -->
          <circle cx="0" cy="0" r="6.2" fill="white"/>
          <!-- Blue horizontal arm of the G (fills the gap from center to outer ring) -->
          <rect x="0" y="-1.8" width="10.5" height="3.6" fill="#4285F4"/>
        </g>

        <!-- Microsoft Icon — authentic Windows/Microsoft 4-colored squares logo -->
        <g id="microsoftIcon">
          <!-- White card background -->
          <rect x="-13" y="-12" width="26" height="24" rx="4" fill="white" stroke="#E5E7EB" stroke-width="0.5"/>
          <!-- Red square: top-left -->
          <rect x="-11.5" y="-10.5" width="10.5" height="10" fill="#F25022"/>
          <!-- Green square: top-right -->
          <rect x="1" y="-10.5" width="10.5" height="10" fill="#7FBA00"/>
          <!-- Blue square: bottom-left -->
          <rect x="-11.5" y="1" width="10.5" height="9" fill="#00A4EF"/>
          <!-- Yellow square: bottom-right -->
          <rect x="1" y="1" width="10.5" height="9" fill="#FFB900"/>
        </g>

        <!-- Server Cabinet Icon — vivid slate-violet fill -->
        <g id="serverIcon">
          <rect x="-12" y="-14" width="24" height="28" rx="3" fill="#6C5CE7" />
          <rect x="-12" y="-14" width="24" height="28" rx="3" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6" />
          <line x1="-12" y1="-5" x2="12" y2="-5" stroke="#ffffff" stroke-width="1" stroke-opacity="0.5" />
          <line x1="-12" y1="4" x2="12" y2="4" stroke="#ffffff" stroke-width="1" stroke-opacity="0.5" />
          <circle cx="-5" cy="-9.5" r="2" fill="#34D399" />
          <circle cx="-5" cy="-0.5" r="2" fill="#FCD34D" />
          <circle cx="-5" cy="8" r="2" fill="#FB7185" />
        </g>
      </defs>

      <!-- Background Grid Pattern -->
      <g opacity="0.2">
        <path d="M 0 100 L 1200 100 M 0 200 L 1200 200 M 0 300 L 1200 300 M 0 400 L 1200 400 M 0 500 L 1200 500" stroke="#6366F1" stroke-width="0.5" />
        <path d="M 100 0 L 100 600 M 200 0 L 200 600 M 300 0 L 300 600 M 400 0 L 400 600 M 500 0 L 500 600 M 600 0 L 600 600 M 700 0 L 700 600 M 800 0 L 800 600 M 900 0 L 900 600 M 1000 0 L 1000 600 M 1100 0 L 1100 600" stroke="#6366F1" stroke-width="0.5" />
      </g>

      <!-- Faint Tech Circuit Lines -->
      <g stroke="#6366F1" stroke-width="0.8" opacity="0.12" fill="none">
        <path d="M 50 150 L 180 150 L 240 210 M 240 210 L 240 380" />
        <circle cx="240" cy="380" r="3" fill="#6366F1" />
        <path d="M 1150 450 L 1020 450 L 960 390 M 960 390 L 960 220" />
        <circle cx="960" cy="220" r="3" fill="#6366F1" />
      </g>

      <!-- ================= LEFT SIDE INPUT PATH FLOWS ================= -->
      <!-- Opacity 0.45 — visible streaks that fade before reaching the central text zone -->
      <!-- Gmail Input path -->
      <path d="M 0 140 Q 210 180, 425 290" stroke="url(#rayGmailSource)" stroke-width="3" opacity="0.45" />
      <!-- Outlook Input path -->
      <path d="M 0 230 Q 210 250, 411 310" stroke="url(#rayOutlookSource)" stroke-width="3.5" opacity="0.45" />
      <!-- Thunderbird Input path -->
      <path d="M 0 320 L 403 320" stroke="url(#rayThunderbirdSource)" stroke-width="3" opacity="0.45" />
      <!-- Files Input path -->
      <path d="M 0 410 Q 210 390, 396 330" stroke="url(#rayFileSource)" stroke-width="4" opacity="0.45" />
      <!-- Cloud Input path -->
      <path d="M 0 500 Q 210 450, 381 350" stroke="url(#rayCloudSource)" stroke-width="3" opacity="0.45" />
      <!-- MBOX Input path -->
      <path d="M 0 500 Q 210 450, 381 350" stroke="url(#rayCloudSource)" stroke-width="3" opacity="0.45" />

      <!-- Moving Input Icons — vivid fills, large scale, per-icon glow, pulsing -->
      <!-- Gmail Icon —  rose glow -->
      <g>
