---
import type { Product } from "@/types/product";
import type { Category } from "@/services/api";

interface Testimonial {
  authorName: string;
  authorTitle: string;
  company: string;
  rating: number;
  content: string;
}

const { categories, settings, featured, testimonials, clientLogos = [] } = Astro.props;

const logosList = clientLogos.length > 0 ? clientLogos.slice(0, 12) : [
  { companyName: "Google Workspace", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/google-workspace.svg" },
  { companyName: "Microsoft 365", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/microsoft-365.svg" },
  { companyName: "Salesforce", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/salesforce.svg" },
  { companyName: "Slack", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/slack-icon.svg" },
  { companyName: "AWS", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/aws.svg" },
  { companyName: "Dropbox", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/dropbox.svg" },
  { companyName: "Box", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/box.svg" },
  { companyName: "Zoom", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/zoom.svg" },
  { companyName: "MySQL", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/mysql-icon.svg" },
  { companyName: "PostgreSQL", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/postgresql.svg" },
  { companyName: "MongoDB", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/mongodb-icon.svg" },
  { companyName: "SAP", logoUrl: "https://raw.githubusercontent.com/gilbarbara/logos/master/logos/sap.svg" },
];

const siteName = settings?.name || "Prism Migration";
const siteTagline = settings?.tagline || "Enterprise Mailbox & Database Migrators. Built to Run Locally.";
const siteDescription = settings?.description || "Preserve folder structures, validate integrity with double checksums, and stream files at maximum connection speed. 100% private, on-premise execution.";
const siteStats = settings?.stats || [];

const iconMap: Record<string, string> = {
  mail: "✉️", shield: "🛡️", "refresh-cw": "🔄", cloud: "☁️", "hard-drive": "💾", download: "⬇️",
};

const categoryIconMap: Record<string, string> = {
  "email-migration": "✉️",
  "backup": "💾",
  "file-converter": "🔄",
  "cloud-migration": "☁️",
  "mailbox-recovery": "🛡️",
  "data-export": "📤",
};

const categoryColorMap: Record<string, { text: string; bg: string; border: string; glow: string }> = {
  "email-migration": { text: "text-[#14B8A6]", bg: "bg-[#14B8A6]/10", border: "border-[#14B8A6]/20", glow: "shadow-[0_0_15px_rgba(20, 184, 166,0.15)]" },
  "backup": { text: "text-[#3b82f6]", bg: "bg-[#3b82f6]/10", border: "border-[#3b82f6]/20", glow: "shadow-[0_0_15px_rgba(59,130,246,0.15)]" },
  "file-converter": { text: "text-[#10b981]", bg: "bg-[#10b981]/10", border: "border-[#10b981]/20", glow: "shadow-[0_0_15px_rgba(20, 184, 166,0.15)]" },
  "cloud-migration": { text: "text-[#a855f7]", bg: "bg-[#a855f7]/10", border: "border-[#a855f7]/20", glow: "shadow-[0_0_15px_rgba(168,85,247,0.15)]" },
  "mailbox-recovery": { text: "text-[#ef4444]", bg: "bg-[#ef4444]/10", border: "border-[#ef4444]/20", glow: "shadow-[0_0_15px_rgba(239,68,68,0.15)]" },
};
---

<!-- Sleek SaaS Hero Section (Premium Dark Theme) -->
<section class="relative overflow-hidden bg-[#0F172A] pt-6 pb-10 md:pt-8 md:pb-12 border-b border-[#334155] tech-grid">
  <!-- Cinematic Glowing Lights & Mesh Gradients -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden z-0" aria-hidden="true">
    <!-- Center light source -->
    <div class="absolute top-[20%] left-1/2 -translate-x-1/2 w-[60%] h-[60%] rounded-full bg-gradient-to-br from-[#14B8A6]/10 to-indigo-900/10 blur-[140px] opacity-60"></div>
    <!-- Bottom light source -->
    <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-stone-950 to-transparent z-10"></div>
  </div>

  <!-- Giant Glass Prism & Refraction Rays SVG (Stretches from left to right corner) -->
  <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden flex items-center justify-center" aria-hidden="true">
    <svg class="w-[135%] h-[115%] md:w-[125%] md:h-[105%] opacity-[0.55] scale-100 md:scale-105" viewBox="0 0 1200 600" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <!-- Light Beam Gradients for Left-side Input Streams -->
        <linearGradient id="rayGmailSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#ef4444" stop-opacity="0" />
          <stop offset="100%" stop-color="#ef4444" stop-opacity="0.65" />
        </linearGradient>
        <linearGradient id="rayOutlookSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0" />
          <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.65" />
        </linearGradient>
        <linearGradient id="rayThunderbirdSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#F59E0B" stop-opacity="0" />
          <stop offset="100%" stop-color="#F59E0B" stop-opacity="0.65" />
        </linearGradient>
        <linearGradient id="rayFileSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#14B8A6" stop-opacity="0" />
          <stop offset="100%" stop-color="#14B8A6" stop-opacity="0.65" />
        </linearGradient>
        <linearGradient id="rayCloudSource" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#a855f7" stop-opacity="0" />
          <stop offset="100%" stop-color="#a855f7" stop-opacity="0.65" />
        </linearGradient>

        <!-- Rainbow Refracted Rays (Gold, Cyan, Purple, Blue) for Right-side Output -->
        <linearGradient id="rayGold" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#14B8A6" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#14B8A6" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="rayCyan" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#F59E0B" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#F59E0B" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="rayPurple" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#a855f7" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#a855f7" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="rayBlue" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.95" />
          <stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
        </linearGradient>

        <!-- Glass Prism 3D Gradient -->
        <linearGradient id="prismFaceLeft" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#14B8A6" stop-opacity="0.35" />
          <stop offset="100%" stop-color="#854d0e" stop-opacity="0.05" />
        </linearGradient>
        <linearGradient id="prismFaceRight" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0.2" />
          <stop offset="100%" stop-color="#14B8A6" stop-opacity="0.02" />
        </linearGradient>
        
        <!-- Glow Filter -->
        <filter id="cinematicGlow" x="-25%" y="-25%" width="150%" height="150%">
          <feGaussianBlur stdDeviation="11" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        <filter id="softGlow" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="20" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>

        <!-- PDF Document Icon -->
        <g id="pdfIcon">
          <rect x="-9" y="-12" width="18" height="24" rx="3" fill="#ffffff" stroke="#14B8A6" stroke-width="1.5" />
          <path d="M 3 -12 L 9 -6 L 3 -6 Z" fill="#14B8A6" />
          <text x="0" y="7" fill="#14B8A6" font-size="7" font-family="monospace" text-anchor="middle" font-weight="black">PDF</text>
        </g>

        <!-- DOCX Document Icon -->
        <g id="docxIcon">
          <rect x="-9" y="-12" width="18" height="24" rx="3" fill="#ffffff" stroke="#3b82f6" stroke-width="1.5" />
          <path d="M 3 -12 L 9 -6 L 3 -6 Z" fill="#3b82f6" />
          <text x="0" y="7" fill="#3b82f6" font-size="6" font-family="monospace" text-anchor="middle" font-weight="black">DOCX</text>
        </g>

        <!-- Email Envelope Icon -->
        <g id="emailIcon">
          <rect x="-10" y="-8" width="20" height="16" rx="2" fill="#ffffff" stroke="#F59E0B" stroke-width="1.5" />
          <path d="M -10 -8 L 0 0 L 10 -8" stroke="#F59E0B" stroke-width="1.5" fill="none" stroke-linejoin="round" />
        </g>

        <!-- Cloud Storage Icon -->
        <g id="cloudIcon">
          <path d="M -7 3 C -9.5 3, -11.5 1, -11.5 -1.5 C -11.5 -4, -9.5 -6, -7 -6 C -6.2 -9, -3.5 -10, 0 -10 C 4.5 -10, 6.5 -7, 6.5 -5.5 C 8.5 -5.5, 11 -4, 11 -1.5 C 11 1.5, 8.5 3, 5.5 3 Z" fill="#ffffff" stroke="#F59E0B" stroke-width="1.5" stroke-linejoin="round" />
        </g>

        <!-- Folder Directory Icon -->
        <g id="folderIcon">
          <path d="M -10 6 L -10 -8 L -4 -8 L -1 -5 L 8 -5 L 8 6 Z" fill="#ffffff" stroke="#a855f7" stroke-width="1.5" stroke-linejoin="round" />
        </g>

        <!-- Outlook Icon -->
        <g id="outlookIcon">
          <rect x="-9" y="-9" width="18" height="18" rx="3" fill="#ffffff" stroke="#2563eb" stroke-width="1.5" />
          <text x="0" y="4.5" fill="#2563eb" font-size="10" font-family="sans-serif" font-weight="black" text-anchor="middle">O</text>
        </g>

        <!-- Gmail Icon -->
        <g id="gmailIcon">
          <rect x="-9" y="-9" width="18" height="18" rx="3" fill="#ffffff" stroke="#ea4335" stroke-width="1.5" />
          <path d="M -9 -9 L 0 -1 L 9 -9" stroke="#ea4335" stroke-width="1.5" fill="none" stroke-linejoin="round" />
          <text x="0" y="6" fill="#ea4335" font-size="6.5" font-family="monospace" text-anchor="middle" font-weight="bold">M</text>
        </g>

        <!-- Thunderbird Icon -->
        <g id="thunderbirdIcon">
          <rect x="-9" y="-9" width="18" height="18" rx="3" fill="#ffffff" stroke="#00bcd4" stroke-width="1.5" />
          <text x="0" y="4.5" fill="#00bcd4" font-size="10" font-family="sans-serif" font-weight="black" text-anchor="middle">T</text>
        </g>

        <!-- PST Tag -->
        <g id="pstIcon">
          <rect x="-10" y="-8" width="20" height="16" rx="2" fill="#ffffff" stroke="#14B8A6" stroke-width="1.5" />
          <text x="0" y="4" fill="#14B8A6" font-size="7" font-family="monospace" text-anchor="middle" font-weight="black">PST</text>
        </g>

        <!-- EML Tag -->
        <g id="emlIcon">
          <rect x="-10" y="-8" width="20" height="16" rx="2" fill="#ffffff" stroke="#10b981" stroke-width="1.5" />
          <text x="0" y="4" fill="#10b981" font-size="7" font-family="monospace" text-anchor="middle" font-weight="black">EML</text>
        </g>

        <!-- MBOX Tag -->
        <g id="mboxIcon">
          <rect x="-11" y="-8" width="22" height="16" rx="2" fill="#ffffff" stroke="#8b5cf6" stroke-width="1.5" />
          <text x="0" y="4" fill="#8b5cf6" font-size="6.5" font-family="monospace" text-anchor="middle" font-weight="black">MBOX</text>
        </g>

        <!-- Server Cabinet Icon -->
        <g id="serverIcon">
          <rect x="-10" y="-12" width="20" height="24" rx="2" fill="#ffffff" stroke="#14B8A6" stroke-width="1.5" />
          <line x1="-10" y1="-4" x2="10" y2="-4" stroke="#14B8A6" stroke-width="1.2" />
          <line x1="-10" y1="4" x2="10" y2="4" stroke="#14B8A6" stroke-width="1.2" />
          <circle cx="-5" cy="-8" r="1.5" fill="#10b981" />
          <circle cx="-5" cy="0" r="1.5" fill="#10b981" />
          <circle cx="-5" cy="8" r="1.5" fill="#10b981" />
        </g>
      </defs>

      <!-- Background Grid Pattern -->
      <g opacity="0.2">
        <path d="M 0 100 L 1200 100 M 0 200 L 1200 200 M 0 300 L 1200 300 M 0 400 L 1200 400 M 0 500 L 1200 500" stroke="#14B8A6" stroke-width="0.5" />
        <path d="M 100 0 L 100 600 M 200 0 L 200 600 M 300 0 L 300 600 M 400 0 L 400 600 M 500 0 L 500 600 M 600 0 L 600 600 M 700 0 L 700 600 M 800 0 L 800 600 M 900 0 L 900 600 M 1000 0 L 1000 600 M 1100 0 L 1100 600" stroke="#14B8A6" stroke-width="0.5" />
      </g>

      <!-- Faint Tech Circuit Lines -->
      <g stroke="#14B8A6" stroke-width="0.8" opacity="0.12" fill="none">
        <path d="M 50 150 L 180 150 L 240 210 M 240 210 L 240 380" />
        <circle cx="240" cy="380" r="3" fill="#14B8A6" />
        <path d="M 1150 450 L 1020 450 L 960 390 M 960 390 L 960 220" />
        <circle cx="960" cy="220" r="3" fill="#14B8A6" />
      </g>

      <!-- ================= LEFT SIDE INPUT PATH FLOWS ================= -->
      <!-- Gmail Input path -->
      <path d="M 0 140 Q 210 180, 425 290" stroke="url(#rayGmailSource)" stroke-width="3" opacity="0.7" />
      <!-- Outlook Input path -->
      <path d="M 0 230 Q 210 250, 411 310" stroke="url(#rayOutlookSource)" stroke-width="3.5" opacity="0.7" />
      <!-- Thunderbird Input path -->
      <path d="M 0 320 L 403 320" stroke="url(#rayThunderbirdSource)" stroke-width="3" opacity="0.7" />
      <!-- Files Input path -->
      <path d="M 0 410 Q 210 390, 396 330" stroke="url(#rayFileSource)" stroke-width="4" opacity="0.7" />
      <!-- Cloud Input path -->
      <path d="M 0 500 Q 210 450, 381 350" stroke="url(#rayCloudSource)" stroke-width="3" opacity="0.7" />
      <!-- MBOX Input path -->
      <path d="M 0 500 Q 210 450, 381 350" stroke="url(#rayCloudSource)" stroke-width="3" opacity="0.7" />

      <!-- Moving Input Icons (flowing smoothly into the left interface of the prism) -->
      <!-- Gmail Icon -->
      <g>
        <animateMotion dur="6s" repeatCount="indefinite" path="M 0 140 Q 210 180, 425 290" />
        <animate attributeName="opacity" values="1;1;0" dur="6s" repeatCount="indefinite" />
        <use href="#gmailIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Outlook Icon -->
      <g>
        <animateMotion dur="5s" repeatCount="indefinite" path="M 0 230 Q 210 250, 411 310" />
        <animate attributeName="opacity" values="1;1;0" dur="5s" repeatCount="indefinite" />
        <use href="#outlookIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Thunderbird Icon -->
      <g>
        <animateMotion dur="7s" repeatCount="indefinite" path="M 0 320 L 403 320" />
        <animate attributeName="opacity" values="1;1;0" dur="7s" repeatCount="indefinite" />
        <use href="#thunderbirdIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- PST File Icon -->
      <g>
        <animateMotion dur="5.5s" repeatCount="indefinite" path="M 0 410 Q 210 390, 396 330" />
        <animate attributeName="opacity" values="1;1;0" dur="5.5s" repeatCount="indefinite" />
        <use href="#pstIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- EML File Icon -->
      <g>
        <animateMotion dur="8s" repeatCount="indefinite" path="M 0 410 Q 210 390, 396 330" keyTimes="0;0.5;1" keyPoints="0;0.5;1" />
        <animate attributeName="opacity" values="1;1;0" dur="8s" repeatCount="indefinite" />
        <use href="#emlIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Cloud Source Icon -->
      <g>
        <animateMotion dur="6.5s" repeatCount="indefinite" path="M 0 500 Q 210 450, 381 350" />
        <animate attributeName="opacity" values="1;1;0" dur="6.5s" repeatCount="indefinite" />
        <use href="#cloudIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- MBOX Source Icon -->
      <g>
        <animateMotion dur="7.2s" repeatCount="indefinite" path="M 0 500 Q 210 450, 381 350" keyTimes="0;0.5;1" keyPoints="0;0.5;1" />
        <animate attributeName="opacity" values="1;1;0" dur="7.2s" repeatCount="indefinite" />
        <use href="#mboxIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- ================= 2. CENTRAL 3D GLASS PRISM ================= -->
      <!-- Prism Shadow backdrop glow -->
      <polygon points="600,50 938,509 262,509" fill="#ffffff" opacity="0.35" filter="url(#softGlow)" />
      <!-- Left glass facet -->
      <polygon points="600,50 600,509 262,509" fill="url(#prismFaceLeft)" stroke="#14B8A6" stroke-width="1.8" />
      <!-- Right glass facet -->
      <polygon points="600,50 938,509 600,509" fill="url(#prismFaceRight)" stroke="#ffffff" stroke-width="1" opacity="0.8" />
      <!-- Prism Base highlight -->
      <line x1="262" y1="509" x2="938" y2="509" stroke="#14B8A6" stroke-width="2.5" filter="url(#cinematicGlow)" />

      <!-- Transformation Zone inside the Prism -->
      <circle cx="600" cy="320" r="22" fill="#14B8A6" opacity="0.3" filter="url(#softGlow)">
        <animate attributeName="r" values="12;28;12" dur="3s" repeatCount="indefinite" />
      </circle>
      <circle cx="600" cy="320" r="12" fill="#ffffff" opacity="0.6" filter="url(#cinematicGlow)">
        <animate attributeName="opacity" values="0.3;0.8;0.3" dur="2s" repeatCount="indefinite" />
      </circle>

      <!-- ================= 3. RIGHT SIDE REFRACTED OUTPUT PATHS ================= -->
      <!-- Gold Ray (Top-Right) -->
      <path d="M 600 320 C 720 280, 880 200, 1200 120" stroke="url(#rayGold)" stroke-width="12" filter="url(#cinematicGlow)" />
      <!-- Cyan Ray (Mid-Right) -->
      <path d="M 600 320 C 720 300, 880 270, 1200 230" stroke="url(#rayCyan)" stroke-width="14" filter="url(#cinematicGlow)" />
      <!-- Purple Ray (Low-Right) -->
      <path d="M 600 320 C 720 340, 880 370, 1200 340" stroke="url(#rayPurple)" stroke-width="13" filter="url(#cinematicGlow)" />
      <!-- Blue Ray (Bottom-Right) -->
      <path d="M 600 320 C 720 380, 880 440, 1200 450" stroke="url(#rayBlue)" stroke-width="15" filter="url(#cinematicGlow)" />

      <!-- Moving Output Icons (scattering outwards showing successful migration) -->
      <!-- PDF Document on Gold Ray -->
      <g>
        <animateMotion dur="5.5s" repeatCount="indefinite" path="M 600 320 C 720 280, 880 200, 1200 120" />
        <animate attributeName="opacity" values="0;1;1;0" dur="5.5s" repeatCount="indefinite" />
        <use href="#pdfIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Office 365 / Outlook on Gold Ray -->
      <g>
        <animateMotion dur="7.2s" repeatCount="indefinite" path="M 600 320 C 720 280, 880 200, 1200 120" keyTimes="0;0.5;1" keyPoints="0;0.5;1" />
        <animate attributeName="opacity" values="0;1;1;0" dur="7.2s" repeatCount="indefinite" />
        <use href="#outlookIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- Email Envelope on Cyan Ray -->
      <g>
        <animateMotion dur="6.8s" repeatCount="indefinite" path="M 600 320 C 720 300, 880 270, 1200 230" />
        <animate attributeName="opacity" values="0;1;1;0" dur="6.8s" repeatCount="indefinite" />
        <use href="#emailIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Gmail Destination on Cyan Ray -->
      <g>
        <animateMotion dur="8.5s" repeatCount="indefinite" path="M 600 320 C 720 300, 880 270, 1200 230" keyTimes="0;0.4;1" keyPoints="0;0.4;1" />
        <animate attributeName="opacity" values="0;1;1;0" dur="8.5s" repeatCount="indefinite" />
        <use href="#gmailIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- Cloud Storage on Purple Ray -->
      <g>
        <animateMotion dur="8.2s" repeatCount="indefinite" path="M 600 320 C 720 340, 880 370, 1200 340" />
        <animate attributeName="opacity" values="0;1;1;0" dur="8.2s" repeatCount="indefinite" />
        <use href="#cloudIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- Folder Directory on Blue Ray -->
      <g>
        <animateMotion dur="7.4s" repeatCount="indefinite" path="M 600 320 C 720 380, 880 440, 1200 450" />
        <animate attributeName="opacity" values="0;1;1;0" dur="7.4s" repeatCount="indefinite" />
        <use href="#folderIcon" filter="url(#cinematicGlow)" />
      </g>
      <!-- Server Cabinet Destination on Blue Ray -->
      <g>
        <animateMotion dur="9.2s" repeatCount="indefinite" path="M 600 320 C 720 380, 880 440, 1200 450" keyTimes="0;0.5;1" keyPoints="0;0.5;1" />
        <animate attributeName="opacity" values="0;1;1;0" dur="9.2s" repeatCount="indefinite" />
        <use href="#serverIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- DOCX Document on Gold/Cyan Ray -->
      <g>
        <animateMotion dur="9s" repeatCount="indefinite" path="M 600 320 C 720 260, 920 180, 1200 150" />
        <animate attributeName="opacity" values="0;1;1;0" dur="9s" repeatCount="indefinite" />
        <use href="#docxIcon" filter="url(#cinematicGlow)" />
      </g>

      <!-- ================= 5. BINARY & PHOTON PARTICLES ================= -->
      <g>
        <animateMotion dur="4s" repeatCount="indefinite" path="M 600 320 C 700 290, 900 240, 1200 200" />
        <text fill="#ffffff" font-family="monospace" font-size="14" font-weight="black" opacity="0.9">0</text>
      </g>
      <g>
        <animateMotion dur="5.2s" repeatCount="indefinite" path="M 600 320 C 700 330, 900 390, 1200 420" />
        <text fill="#14B8A6" font-family="monospace" font-size="14" font-weight="black" opacity="0.9">1</text>
      </g>
      <g>
        <animateMotion dur="3.8s" repeatCount="indefinite" path="M 600 320 C 750 310, 950 320, 1200 310" />
        <text fill="#F59E0B" font-family="monospace" font-size="13" font-weight="black" opacity="0.9">1</text>
      </g>
      <g>
        <animateMotion dur="6s" repeatCount="indefinite" path="M 600 320 C 750 350, 950 420, 1200 470" />
        <text fill="#a855f7" font-family="monospace" font-size="13" font-weight="black" opacity="0.9">0</text>
      </g>

      <!-- Transforming Data Packets (Pulsing circles on left-to-prism paths) -->
      <g>
        <animateMotion dur="3.5s" repeatCount="indefinite" path="M 0 320 L 403 320" />
