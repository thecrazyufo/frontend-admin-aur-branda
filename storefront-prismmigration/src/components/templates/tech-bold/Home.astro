---
import ProductCard from "@/components/common/ProductCard";

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName = settings?.name || "TechBold";
const siteTagline = settings?.tagline || "The Future of Software";
const siteDescription = settings?.description || "Next-generation tools for developers and engineers.";
---
<div class="bg-[#0F172A] text-zinc-300 font-sans min-h-screen selection:bg-cyan-500/30">
  <!-- Glowing Hero -->
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-cyan-600/20 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-950/50 border border-cyan-800/50 text-cyan-400 text-xs font-mono mb-8 backdrop-blur-md">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
          SYSTEM v2.0 ONLINE
        </div>
        <h1 class="text-4xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-br from-white via-zinc-200 to-zinc-600 tracking-tight mb-6">
          {siteTagline}
        </h1>
        <p class="text-xl text-zinc-400 max-w-2xl mx-auto mb-10 font-medium">
          {siteDescription}
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/products" class="bg-cyan-500 hover:bg-cyan-400 text-black font-bold py-4 px-8 rounded-lg shadow-[0_0_30px_rgba(245, 158, 11,0.3)] hover:shadow-[0_0_40px_rgba(245, 158, 11,0.5)] transition-all">
            INITIALIZE PLATFORM
          </a>
          <a href="/docs" class="bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 text-[#E2E8F0] font-bold py-4 px-8 rounded-lg transition-all">
            VIEW DOCS
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cyber Grid Products -->
  <section class="py-24 relative border-t border-zinc-900">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50 pointer-events-none"></div>
    <div class="container-custom relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl font-bold text-white mb-2 font-mono"><span class="text-cyan-500">&gt;</span> ACTIVE_MODULES</h2>
          <p class="text-zinc-500">Deploy high-performance tools instantly.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((product) => (
          <div class="bg-zinc-900/50 backdrop-blur-xl border border-zinc-800 p-6 rounded-2xl hover:border-cyan-500/50 hover:bg-zinc-900 transition-all group">
            <div class="w-14 h-14 bg-black border border-zinc-800 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-inner group-hover:shadow-[0_0_20px_rgba(245, 158, 11,0.2)]">
              {product.icon || "⚡"}
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{product.name}</h3>
            <p class="text-zinc-400 text-sm mb-6 line-clamp-2">{product.description}</p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-cyan-400 font-mono font-bold">${product.price}</span>
              <a href={`/products/${product.id}`} class="text-xs font-bold bg-zinc-800 hover:bg-cyan-500 hover:text-black px-4 py-2 rounded transition-colors uppercase tracking-wider">Deploy</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</div>
