---
import "../styles/globals.css";
import Navbar from "../components/layout/Navbar";
import Footer from "../components/layout/Footer";
import { SettingsAPI, BrandAPI, ProductAPI } from "../services/api";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  author?: string;
  noindex?: boolean;
  keywords?: string;
  settings?: any;
  brandConfig?: any;
  products?: any[];
}

let settings = Astro.props.settings;
let brandConfig = Astro.props.brandConfig;
let products = Astro.props.products;

// Fetch in parallel if any are missing
if (!settings || !brandConfig || !products) {
  const [fetchedSettings, fetchedBrandConfig, fetchedProducts] = await Promise.all([
    settings ? Promise.resolve(settings) : SettingsAPI.get().catch(() => null),
    brandConfig ? Promise.resolve(brandConfig) : BrandAPI.getCurrentBrand().catch(() => null),
    products ? Promise.resolve(products) : ProductAPI.getAll().catch(() => [])
  ]);
  settings = fetchedSettings;
  brandConfig = fetchedBrandConfig;
  products = fetchedProducts;
}

const layoutTemplate = brandConfig?.layoutTemplate || "classic";

const siteName = settings?.name || "";
const siteTagline = settings?.tagline || "";
const siteDescription = settings?.description || "";

// Theme config from API — used for dynamic CSS custom properties
const themeConfig = settings?.theme || {};
const fontFamily = themeConfig.fontFamily || "Inter";
const primaryColor = themeConfig.primaryColor || "#2563eb";
const accentColor = themeConfig.accentColor || "#f59e0b";
const faviconUrl = themeConfig.faviconUrl || "/favicon.ico";
const logoUrl = themeConfig.logoUrl || "";

// Navigation from API — falls back to empty (Navbar has its own defaults)
const mainNavigation = settings?.mainNavigation || [];

// Footer config from API
const footerConfig = settings?.footerConfig || undefined;

// SEO defaults from API
const seoDefaults = settings?.seoDefaults || {};
const titleTemplate = seoDefaults.titleTemplate || "{page} — {siteName}";
const defaultOgImage = seoDefaults.defaultOgImage || "";

const twitterHandle = (() => {
  const tw = settings?.socials?.twitter || "";
  if (!tw) return "";
  const handle = tw
    .replace(/.*twitter\.com\//, "")
    .replace(/.*x\.com\//, "")
    .replace(/^@/, "")
    .trim();
  return handle ? `@${handle}` : "";
})();

const {
  title = `${siteName} — ${siteTagline}`,
  description = siteDescription,
  canonical = Astro.props.canonical ||
    new URL(Astro.url.pathname, Astro.site || Astro.url.origin).toString(),
  ogImage = defaultOgImage || "/og-default.png",
  ogType = "website",
  author,
  noindex = false,
  keywords = Astro.props.keywords,
} = Astro.props;

// Google Fonts URL — dynamically load the font selected in admin
const fontUrl = `https://fonts.googleapis.com/css2?family=${fontFamily.replace(/ /g, "+")}:wght@300;400;500;600;700;800;900&display=swap`;
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {author && <meta name="author" content={author} />}

    <!-- Google Verification -->
    {seoDefaults.googleVerification && (
      <meta name="google-site-verification" content={seoDefaults.googleVerification} />
    )}

    <!-- Favicon (dynamic from admin panel) -->
    <link rel="icon" href={faviconUrl} />

    <!-- Fonts (dynamic from admin panel) — non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontUrl} /></noscript>

    <!-- Dynamic Theme CSS Custom Properties -->
    <style define:vars={{ primaryColor, accentColor, fontFamily }}>
      :root {
        --brand-primary: var(--primaryColor);
        --brand-accent: var(--accentColor);
        --brand-font: var(--fontFamily), system-ui, sans-serif;

        /* Force dark theme values globally for the entire storefront */
        --background: #0B0F1A;
        --foreground: #ffffff;
        --muted: #111827;
        --muted-foreground: #D1D5DB;
        --border: #1F2937;
        --card: #111827;

        --color-foreground: #ffffff;
        --color-muted: #9CA3AF;
        --color-surface: #111827;
        --color-canvas: #0B0F1A;
        --color-canvas-soft: #111827;
        --color-canvas-soft-2: #18181b;
        --color-ink: #ffffff;
        --color-body: #D1D5DB;
        --color-mute: #9CA3AF;
        --color-hairline: #1F2937;
        --color-hairline-strong: #3f3f46;
      }
    </style>
  </head>
  <body class={`min-h-screen flex flex-col antialiased layout-${layoutTemplate} bg-canvas text-ink relative`} style={`font-family: '${fontFamily}', system-ui, sans-serif;`}>
    <!-- Accessibility Skip Link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-[#6366F1] focus:text-white focus:font-extrabold focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-[#6366F1] focus:ring-offset-2 focus:ring-offset-black transition-all">
      Skip to main content
    </a>

    <!-- Vercel-style Decorative Mesh Gradient (Fixed Background) -->
    <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-[#6366F1] opacity-[0.03] blur-[120px]"></div>
      <div class="absolute top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-[#8B5CF6] opacity-[0.03] blur-[120px]"></div>
    </div>

    <!-- Announcement Bar (if enabled) -->
    {settings?.announcement?.enabled && settings.announcement.text && (
      <div style={`background: ${settings.announcement.bgColor || '#171717'}; color: ${settings.announcement.textColor || '#fff'}; text-align: center; padding: 8px 16px; font-size: 13px; font-weight: 500;`}>
        {settings.announcement.link ? (
          <a href={settings.announcement.link} style="color: inherit; text-decoration: underline;">
            {settings.announcement.text}
          </a>
        ) : (
          settings.announcement.text
        )}
      </div>
    )}

    <Navbar
      client:load
      siteName={siteName}
      phone={settings?.phone}
      navigation={mainNavigation}
      logoUrl={logoUrl}
      products={products}
    />
    <main id="main-content" class="flex-1 relative outline-none" tabindex="-1">
      <slot />
    </main>
    <Footer
      siteName={siteName}
      description={siteDescription}
      phone={settings?.phone}
      email={settings?.email}
      address={settings?.address}
      socials={settings?.socials}
      footerConfig={footerConfig}
    />

    <!-- Custom Floating Live Chat Button -->
    <button
      id="tawk-custom-chat-button"
      class="group active:scale-95 transition-all duration-300"
      style="position:fixed !important;bottom:28px !important;right:28px !important;z-index:2147483640 !important;display:flex !important;width:58px !important;height:58px !important;align-items:center !important;justify-content:center !important;border-radius:9999px !important;background:linear-gradient(135deg,#6366F1 0%,#4F46E5 100%) !important;color:#ffffff !important;border:none !important;cursor:pointer !important;box-shadow:0 8px 32px rgba(99, 102, 241,0.45),0 2px 8px rgba(0,0,0,0.25) !important;outline:none !important;visibility:visible !important;opacity:1 !important;overflow:visible !important;"
      aria-label="Open live chat support"
    >
      <!-- Chat icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; display:block;">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>

      <!-- Online Status Pulse Dot -->
      <span style="position:absolute !important;top:3px !important;right:3px !important;width:14px !important;height:14px !important;display:flex !important;align-items:center !important;justify-content:center !important;">
        <span style="position:absolute !important;width:100% !important;height:100% !important;border-radius:9999px !important;background:#34d399 !important;opacity:0.75 !important;animation:tawk-ping 1.5s cubic-bezier(0,0,0.2,1) infinite !important;"></span>
        <span style="position:relative !important;display:inline-block !important;width:10px !important;height:10px !important;border-radius:9999px !important;background:#34d399 !important;border:2px solid white !important;"></span>
      </span>

      <!-- Tooltip -->
      <span style="position:absolute !important;right:calc(100% + 12px) !important;top:50% !important;transform:translateY(-50%) !important;background:#18181b !important;color:#fff !important;font-size:12px !important;font-weight:600 !important;padding:6px 12px !important;border-radius:8px !important;white-space:nowrap !important;box-shadow:0 4px 16px rgba(0,0,0,0.4) !important;border:1px solid rgba(255,255,255,0.1) !important;pointer-events:none !important;opacity:0 !important;transition:opacity 0.2s ease !important;display:block !important;" id="tawk-chat-tooltip">Chat with us</span>
    </button>

    <!-- Chat button animations and hover effects -->
    <style is:inline>
      @keyframes tawk-ping {
        75%, 100% { transform: scale(2); opacity: 0; }
      }
      #tawk-custom-chat-button:hover #tawk-chat-tooltip { opacity: 1 !important; }
      #tawk-custom-chat-button:hover {
        transform: scale(1.08) !important;
        box-shadow: 0 12px 40px rgba(99, 102, 241,0.6), 0 4px 12px rgba(0,0,0,0.3) !important;
      }
    </style>

    <!-- Tawk.to Live Chat Integration -->
    <script is:inline>
      var Tawk_API = Tawk_API || {};
      var Tawk_LoadStart = new Date();

      // Hide Tawk built-in bubble — we use our custom button instead
      function hideTawkBuiltinBubble() {
        if (typeof Tawk_API !== 'undefined' && typeof Tawk_API.hideWidget === 'function') {
          Tawk_API.hideWidget();
        }
      }
      Tawk_API.onLoad = function() { hideTawkBuiltinBubble(); };
      Tawk_API.onChatMinimized = function() { hideTawkBuiltinBubble(); };
      Tawk_API.onMinimize = function() { hideTawkBuiltinBubble(); };

      // Load Tawk.to script asynchronously
      (function() {
        var s1 = document.createElement('script');
        var s0 = document.getElementsByTagName('script')[0];
        s1.async = true;
        s1.src = 'https://embed.tawk.to/6a39aeb5351d6e1d43433240/1jrol4u8n';
        s1.charset = 'UTF-8';
        s1.setAttribute('crossorigin', '*');
        s0.parentNode.insertBefore(s1, s0);
      })();

      // Open Tawk chat panel inline when our custom button is clicked
      window.triggerTawkOpen = function() {
        var attempts = 0;
        function tryOpen() {
          if (typeof Tawk_API !== 'undefined' && typeof Tawk_API.maximize === 'function') {
            if (typeof Tawk_API.showWidget === 'function') { Tawk_API.showWidget(); }
            Tawk_API.maximize();
          } else if (attempts < 40) {
            attempts++;
            setTimeout(tryOpen, 150);
          }
          // No fallback — chat only opens inline as a widget
        }
        tryOpen();
      };

      // Delegate click on custom button
      document.addEventListener('click', function(e) {
        if (e.target.closest('#tawk-custom-chat-button')) {
          window.triggerTawkOpen();
        }
      });
    </script>
  </body>
</html>
