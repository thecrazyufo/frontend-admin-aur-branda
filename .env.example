# ─────────────────────────────────────────────────────────────────────────────
# Multi-Tenant Software Selling Platform - Production Env Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Domain mapping for Caddy reverse proxy
DOMAIN=yourdomain.com

# ☕ Spring Boot Backend Configuration
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=7a3f8c2d1e6b9a4f0e5c8b2d7a1e4f9c3b6a0d8e2f5c9b4a7e1d6c3f0b8a5e2 # Replace with a cryptographically secure 64-char hex

# PostgreSQL Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123 # Replace with a strong production password
POSTGRES_DB=software_platform
SPRING_DATASOURCE_URL=jdbc:postgresql://db-postgres:5432/software_platform
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin123 # Must match POSTGRES_PASSWORD

# 🌐 API URLs for Frontends
PUBLIC_API_URL=https://api.yourdomain.com/api

# 🪙 Payment Gateways (Stripe & PayPal)
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
PAYPAL_CLIENT_ID=paypal_client_id_here
PAYPAL_CLIENT_SECRET=paypal_client_secret_here
PAYPAL_MODE=live # sandbox or live

# 📧 Mail Server Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
