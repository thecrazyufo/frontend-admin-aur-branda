---
import ProductCard from "@/components/common/ProductCard";

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName = settings?.name || "Playful Software";
const siteTagline = settings?.tagline || "Work made fun!";
const siteDescription = settings?.description || "Tools so easy to use, they feel like toys.";
---
<div class="bg-[#FFF9F0] text-zinc-800 font-sans min-h-screen">
  <!-- Bubbly Hero -->
  <section class="py-20 md:py-32 px-4 relative overflow-hidden">
    <!-- Decorative shapes -->
    <div class="absolute top-10 left-10 w-32 h-32 bg-pink-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute top-10 right-20 w-32 h-32 bg-yellow-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-1/2 w-40 h-40 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <span class="inline-block py-2 px-6 rounded-full bg-white border-2 border-zinc-900 font-black tracking-widest text-sm mb-6 shadow-[4px_4px_0px_0px_rgba(24,24,27,1)] rotate-[-2deg]">
        👋 {siteName}
      </span>
      <h1 class="text-6xl md:text-8xl font-black text-zinc-900 tracking-tight mb-8 leading-[1.1] drop-shadow-sm">
        {siteTagline}
      </h1>
      <p class="text-xl md:text-2xl text-zinc-600 max-w-2xl mx-auto mb-12 font-medium">
        {siteDescription}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/products" class="bg-indigo-500 text-white font-black text-lg py-4 px-10 rounded-2xl border-4 border-zinc-900 shadow-[6px_6px_0px_0px_rgba(24,24,27,1)] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(24,24,27,1)] transition-all">
          Start Playing
        </a>
        <a href="/about" class="bg-white text-zinc-900 font-black text-lg py-4 px-10 rounded-2xl border-4 border-zinc-900 shadow-[6px_6px_0px_0px_rgba(24,24,27,1)] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(24,24,27,1)] transition-all">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Asymmetrical Grid Products -->
  <section class="py-24 px-4 bg-white border-y-4 border-zinc-900">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-16 text-center">Magical Tools ✨</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featured.map((product, i) => (
          <div class={`bg-white border-4 border-zinc-900 rounded-[2rem] p-8 shadow-[8px_8px_0px_0px_rgba(24,24,27,1)] hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_rgba(24,24,27,1)] transition-all flex flex-col ${i % 2 === 0 ? 'rotate-1 hover:rotate-2' : '-rotate-1 hover:-rotate-2'}`}>
            <div class={`w-20 h-20 rounded-full flex items-center justify-center text-4xl mb-6 border-4 border-zinc-900 ${['bg-pink-300', 'bg-yellow-300', 'bg-purple-300', 'bg-green-300'][i % 4]}`}>
              {product.icon || "🚀"}
            </div>
            <h3 class="text-2xl font-black text-zinc-900 mb-3">{product.name}</h3>
            <p class="text-zinc-600 font-medium mb-8 flex-grow">{product.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-black text-zinc-900">${product.price}</span>
              <a href={`/products/${product.slug}`} class="bg-zinc-900 text-white font-bold py-3 px-6 rounded-xl hover:bg-zinc-700 transition-colors">Get It!</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</div>
