---
import ProductCard from "@/components/common/ProductCard";

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName = settings?.name || "Luxury Brand";
const siteTagline = settings?.tagline || "Elegance in Software";
const siteDescription = settings?.description || "Curated tools for the modern professional.";
---
<div class="font-serif bg-zinc-50 text-zinc-900 min-h-screen">
  <!-- Cinematic Hero -->
  <section class="min-h-[80vh] flex flex-col justify-center items-center text-center px-4 relative overflow-hidden bg-zinc-100 border-b border-zinc-200">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-zinc-50/90 pointer-events-none z-10"></div>
    <div class="z-20 max-w-3xl mx-auto">
      <span class="tracking-[0.3em] uppercase text-xs text-zinc-500 mb-8 block">{siteName}</span>
      <h1 class="text-5xl md:text-7xl font-light tracking-tight text-zinc-800 mb-8 leading-tight">
        {siteTagline}
      </h1>
      <p class="text-lg md:text-xl text-zinc-500 max-w-2xl mx-auto mb-12 font-light leading-relaxed">
        {siteDescription}
      </p>
      <a href="/products" class="inline-block border border-zinc-800 text-zinc-800 px-10 py-4 uppercase tracking-widest text-xs hover:bg-zinc-800 hover:text-white transition-colors duration-500">
        Discover Collection
      </a>
    </div>
  </section>

  <!-- Elegant Featured Grid -->
  <section class="py-32 px-4 md:px-12 max-w-7xl mx-auto">
    <div class="text-center mb-24">
      <h2 class="text-3xl font-light text-zinc-800 mb-4">Curated Selection</h2>
      <div class="w-12 h-px bg-zinc-300 mx-auto"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {featured.map((product) => (
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] bg-zinc-100 mb-6 overflow-hidden flex items-center justify-center border border-zinc-200 transition-all duration-700 group-hover:border-zinc-400">
            <span class="text-6xl group-hover:scale-110 transition-transform duration-700">{product.icon || "✨"}</span>
          </div>
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-lg text-zinc-800 mb-1">{product.name}</h3>
              <p class="text-sm text-zinc-500 font-sans">${product.price || "99"}</p>
            </div>
            <a href={`/products/${product.slug}`} class="text-xs tracking-widest uppercase text-zinc-400 group-hover:text-zinc-800 transition-colors">View</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Minimalist Reviews -->
  <section class="py-32 bg-zinc-800 text-zinc-100 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <span class="tracking-[0.2em] uppercase text-xs text-zinc-400 mb-12 block">Clientele</span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        {testimonials.slice(0, 2).map((t) => (
          <div class="text-left">
            <p class="text-xl md:text-2xl font-light italic text-zinc-300 mb-6 leading-relaxed">"{t.content}"</p>
            <div class="text-sm tracking-widest uppercase text-zinc-400">{t.author}</div>
            <div class="text-xs text-zinc-500 font-sans mt-1">{t.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</div>
