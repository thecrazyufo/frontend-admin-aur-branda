---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI } from "@/services/api";
import ProductCard from "@/components/common/ProductCard";
import SectionHeader from "@/components/common/SectionHeader";

import type { Product } from "@/types/product";
import type { Category } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

// Get query parameters from URL
const category = Astro.url.searchParams.get("category") || undefined;
const q = Astro.url.searchParams.get("q") || undefined;

let products: Product[] = [];
let categoriesList: Category[] = [];
let allProducts: Product[] = [];

try {
  const [ps, cs, aps] = await Promise.all([
    ProductAPI.getAll(category, q),
    CategoryAPI.getAll(),
    ProductAPI.getAll(),
  ]);
  products = ps.filter(p => p.enabled !== false);
  categoriesList = cs;
  allProducts = aps.filter(p => p.enabled !== false);
} catch (e) {
  console.error("Error loading products:", e);
}

const activeCategory = categoriesList.find((c) => c.id === category);
const filteredCount = products.length;
---

<BaseLayout
  title={activeCategory ? `${activeCategory.label} Tools — ${settings?.name || ""}` : `All Software Products — ${settings?.name || ""}`}
  description={activeCategory ? activeCategory.description : "Browse our complete collection of email migration, backup, file converter, and cloud migration tools."}
>
  <div class="min-h-screen bg-gray-50">
    {/* Header */}
    <div class="bg-white border-b border-gray-100 py-10">
      <div class="container-custom">
        <SectionHeader
          eyebrow="Products"
          title={activeCategory ? activeCategory.label : "All Software Tools"}
          subtitle={activeCategory ? activeCategory.description : "Find the right tool for your data management needs."}
        />
      </div>
    </div>

    <div class="container-custom py-10">
      <div class="flex flex-col lg:flex-row gap-8">
        {/* Sidebar Filters */}
        <aside class="w-full lg:w-64 shrink-0">
          <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm sticky top-20">
            <h3 class="font-bold text-gray-900 text-sm mb-4">Categories</h3>
            <ul class="space-y-1">
              <li>
                <a
                  href="/products"
                  class={`flex items-center justify-between px-3 py-2.5 rounded-lg text-sm transition-colors ${
                    !category ? "bg-blue-50 text-blue-700 font-semibold" : "text-gray-600 hover:bg-gray-50"
                  }`}
                >
                  All Products
                  <span class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded-full">
                    {allProducts.length}
                  </span>
                </a>
              </li>
              {categoriesList.map((cat) => (
                <li>
                  <a
                    href={`/products?category=${cat.id}`}
                    class={`flex items-center justify-between px-3 py-2.5 rounded-lg text-sm transition-colors ${
                      category === cat.id ? "bg-blue-50 text-blue-700 font-semibold" : "text-gray-600 hover:bg-gray-50"
                    }`}
                  >
                    {cat.label}
                    <span class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded-full">
                      {cat.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        {/* Product Grid */}
        <div class="flex-1">
          <div class="flex items-center justify-between mb-6">
            <p class="text-sm text-gray-500">
              {filteredCount} product{filteredCount !== 1 ? "s" : ""} found
            </p>
          </div>

          {filteredCount > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          ) : (
            <div class="text-center py-20 bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
              <p class="text-gray-400 text-lg">No products found.</p>
              <a href="/products" class="btn btn-primary mt-4 inline-block">Clear Filters</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
