---
// Migration Uncle — Home Template
// Warm Green, Soft Orange, Clean White: friendly, reliable, approachable

const { products, categories, settings, featured, testimonials } = Astro.props;
const siteName    = settings?.name        || "Migration Uncle";
const siteTagline = settings?.tagline     || "Your Friendly Uncle for Data Migration";
const siteDesc    = settings?.description || "Simple, safe, and stress-free migration of emails, files, and cloud data. No data loss guaranteed.";

const whyChooseUs = [
  { icon: "🛡️", title: "100% Safe & Secure", desc: "Your data never leaves your device unless you want it to. Total privacy guaranteed." },
  { icon: "⚡", title: "Fast as Lightning", desc: "Migrate gigabytes of data in minutes, not hours, with our optimized software." },
  { icon: "😊", title: "Stress-Free Setup", desc: "No tech skills needed. If you can click a mouse, you can use our tools." },
];

const faqs = [
  { q: "Is it really that easy?", a: "Yes! We designed our tools so anyone can use them without calling IT." },
  { q: "Will I lose any files?", a: "Never. We use a non-destructive copy method, meaning your original files stay exactly where they are." },
  { q: "Do you offer support?", a: "Absolutely. Our friendly support team is ready to help you out if you get stuck." },
];
---

<div class="bg-[var(--color-surface-2)] text-[var(--color-text-primary)] font-sans antialiased overflow-x-hidden">

  <!-- ===================== HERO SECTION ===================== -->
  <section class="relative pt-24 pb-32 lg:pt-36 lg:pb-40 overflow-hidden">
    <!-- Friendly Uncle Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#ecfdf5] to-[#fffbeb] opacity-70"></div>
      <div class="absolute inset-0" style="background-image: radial-gradient(#10B981 1px, transparent 1px); background-size: 40px 40px; opacity: 0.1;"></div>
    </div>

    <div class="container-custom relative z-10 grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Hero Content -->
      <div class="max-w-2xl animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-[#10B981]/30 text-[#047857] text-sm font-medium mb-6 shadow-sm">
          <span class="flex h-2 w-2 rounded-full bg-[#F59E0B] animate-pulse"></span>
          Trusted by 50,000+ happy users
        </div>
        
        <h1 class="text-4xl lg:text-6xl font-bold font-serif text-[#064e3b] leading-tight mb-6">
          Your Friendly Uncle for <span class="text-[#10B981]">Data Migration</span>
        </h1>
        
        <p class="text-lg text-gray-600 mb-8 max-w-xl">
          {siteDesc}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 mt-8">
          <a href="/download" class="btn btn-primary text-lg px-8 py-4 bg-[#10B981] hover:bg-[#059669] text-white border-transparent shadow-[0_4px_14px_0_rgba(16,185,129,0.39)] w-full sm:w-auto flex flex-col items-center leading-tight transition-transform hover:-translate-y-1">
            <span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 5.5v11L12 22l10-5.5v-11L12 2zm0 2.24l7.9 2.76-7.9 2.76-7.9-2.76L12 4.24zm-8.89 4.34l7.89 2.76v8.46l-7.89-4.34V8.58zm17.78 0v4.12l-7.89 4.34v-8.46l7.89-2.76z"/></svg> Free Download</span>
            <span class="text-[10px] font-normal text-white/80 mt-1">For Windows 11/10/8/7 & macOS</span>
          </a>
          <a href="#products" class="btn text-lg px-8 py-4 bg-white text-[#064e3b] border border-gray-200 hover:border-[#10B981] hover:text-[#10B981] w-full sm:w-auto shadow-sm transition-colors">
            See Pricing
          </a>
        </div>
        
        <div class="mt-6 flex items-center gap-3 text-sm text-gray-600 font-medium">
          <div class="flex items-center text-[#F59E0B]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="mr-0.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="mr-0.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="mr-0.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="mr-0.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <span><strong>4.8/5</strong> on Trustpilot (12,000+ reviews)</span>
        </div>
      </div>

      <!-- Hero Visual (Data Flow Animation) -->
      <div class="relative h-[400px] w-full hidden md:block animate-fade-in-up" style="animation-delay: 0.2s;">
        <!-- Base structure -->
        <div class="absolute inset-0 bg-white/60 backdrop-blur-3xl rounded-3xl border border-white shadow-xl flex items-center justify-between px-10">
          
          <!-- Local Folder (Source) -->
          <div class="z-10 flex flex-col items-center animate-bounce-gentle">
            <div class="w-20 h-20 bg-white rounded-2xl shadow-lg border border-gray-100 flex items-center justify-center text-[#F59E0B]">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-1.22-1.8A2 2 0 0 0 7.53 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            </div>
            <span class="mt-3 font-semibold text-[#064e3b]">Old Computer</span>
          </div>

          <!-- Connecting Path -->
          <div class="absolute left-[120px] right-[120px] h-0.5 border-t-2 border-dashed border-[#34d399] top-1/2 -translate-y-1/2 opacity-50"></div>

          <!-- Animated Moving Files -->
          <div class="absolute left-[120px] right-[120px] h-20 top-1/2 -translate-y-1/2 pointer-events-none overflow-hidden">
            <!-- File 1: Email -->
            <div class="absolute top-1/2 -translate-y-1/2 animate-slide-flow" style="animation-delay: 0s;">
              <div class="w-12 h-12 bg-white rounded-xl shadow-md border border-gray-50 flex items-center justify-center text-[#10B981]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
            </div>
            <!-- File 2: Database -->
            <div class="absolute top-1/2 -translate-y-1/2 animate-slide-flow" style="animation-delay: 1.5s;">
              <div class="w-12 h-12 bg-white rounded-xl shadow-md border border-gray-50 flex items-center justify-center text-[#F59E0B]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
              </div>
            </div>
            <!-- File 3: Document -->
            <div class="absolute top-1/2 -translate-y-1/2 animate-slide-flow" style="animation-delay: 3s;">
              <div class="w-12 h-12 bg-white rounded-xl shadow-md border border-gray-50 flex items-center justify-center text-[#0ea5e9]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
            </div>
          </div>

          <!-- Cloud (Destination) -->
          <div class="z-10 flex flex-col items-center animate-bounce-gentle" style="animation-delay: 1.5s;">
            <div class="w-24 h-24 bg-[#10B981] rounded-2xl shadow-[0_10px_30px_-10px_rgba(16,185,129,0.5)] flex items-center justify-center text-white relative">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
              
              <!-- Pop-in Checkmarks (simulating successful transfer) -->
              <div class="absolute -top-2 -right-2 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-lg animate-pop-in" style="animation-delay: 2s; animation-iteration-count: infinite; animation-duration: 4s;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
            </div>
            <span class="mt-3 font-semibold text-[#064e3b]">New Cloud Storage</span>
          </div>

        </div>
      </div>
    </div>
  </section>

    <!-- ===================== MEDIA TRUST BAR ===================== -->
  <section class="py-8 bg-white border-y border-gray-100">
    <div class="container-custom text-center">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">Recommended by top tech publications</p>
      <div class="flex flex-wrap justify-center gap-12 lg:gap-24 opacity-50 grayscale">
        <div class="flex items-center gap-2 font-bold text-2xl text-gray-800"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2z"/></svg> TechRadar</div>
        <div class="flex items-center gap-2 font-black text-2xl text-gray-800 tracking-tighter"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><rect width="18" height="18" x="3" y="3" rx="4"/></svg> CNET</div>
        <div class="flex items-center gap-2 font-bold text-2xl text-gray-800 italic"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/></svg> PCMag</div>
        <div class="flex items-center gap-2 font-bold text-2xl text-gray-800"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21h18v-2H3v2zm6-4h12v-2H9v2zm-6-4h18v-2H3v2zm6-4h12V7H9v2zM3 3v2h18V3H3z"/></svg> TechAdvisor</div>
      </div>
    </div>
  </section>

  <!-- ===================== FLAGSHIP PRODUCT SHOWCASE ===================== -->
  <section class="py-24 bg-[#F8F5F0]">
    <div class="container-custom">
      <div class="bg-white rounded-[2rem] shadow-xl shadow-[#10B981]/5 border border-[#10B981]/10 overflow-hidden relative p-8 lg:p-12 animate-fade-in-up">
        <!-- Background Accent -->
        <div class="absolute top-0 right-0 p-8 opacity-[0.03] pointer-events-none">
           <svg xmlns="http://www.w3.org/2000/svg" width="300" height="300" viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-12 items-center relative z-10">
          <div>
            <div class="inline-block px-3 py-1 bg-[#10B981]/10 text-[#10B981] font-bold text-xs uppercase tracking-widest rounded-full mb-6">Our Flagship Solution</div>
            <h2 class="text-3xl lg:text-4xl font-serif font-bold text-[#064e3b] mb-4">Migration Uncle Pro Suite</h2>
            <p class="text-lg text-gray-600 mb-8">The all-in-one toolkit to transfer your emails, contacts, calendars, and files between any platforms safely. Trusted by thousands of businesses and individuals.</p>
            
            <ul class="space-y-5 mb-10">
              <li class="flex items-start gap-3">
                <div class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-[#10B981]/20 text-[#10B981] flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                <div><strong class="text-[#064e3b] block">100% Data Integrity</strong><span class="text-gray-500 text-sm">Maintains original folder structure and metadata perfectly.</span></div>
              </li>
              <li class="flex items-start gap-3">
                <div class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-[#10B981]/20 text-[#10B981] flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                <div><strong class="text-[#064e3b] block">Supports 80+ Formats</strong><span class="text-gray-500 text-sm">From PST and OST to Google Workspace and Office 365.</span></div>
              </li>
              <li class="flex items-start gap-3">
                <div class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-[#10B981]/20 text-[#10B981] flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                <div><strong class="text-[#064e3b] block">Advanced Filtering</strong><span class="text-gray-500 text-sm">Selectively migrate data by date, folder, or file type.</span></div>
              </li>
            </ul>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/products/pro-suite" class="btn btn-primary text-lg px-8 py-3 bg-[#F59E0B] hover:bg-[#d97706] text-white border-transparent shadow-lg hover:-translate-y-1 w-full sm:w-auto">
                Download Free Trial
              </a>
              <div class="flex items-center justify-center sm:justify-start text-sm text-gray-500 gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> 100% Secure
              </div>
            </div>
          </div>
          
          <!-- Realistic UI Mockup -->
          <div class="relative rounded-xl overflow-hidden shadow-2xl border border-gray-200 bg-white group">
            <!-- Window Header -->
            <div class="bg-gray-50 px-4 py-3 border-b border-gray-200 flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="ml-3 text-xs font-semibold text-gray-500 flex-1 text-center pr-8">Migration Uncle Pro - Transfer Wizard</div>
            </div>
            <!-- Window Body -->
            <div class="p-6 h-[320px] flex flex-col bg-white">
              <!-- Steps Bar -->
              <div class="flex justify-between items-center mb-6 pb-4 border-b border-gray-100">
                 <div class="flex flex-col items-center gap-1"><div class="w-6 h-6 rounded-full bg-[#10B981] text-white text-xs flex items-center justify-center font-bold">1</div><span class="text-[10px] text-gray-400 font-semibold uppercase">Source</span></div>
                 <div class="h-px flex-1 bg-gray-200 mx-2"></div>
                 <div class="flex flex-col items-center gap-1"><div class="w-6 h-6 rounded-full bg-[#10B981] text-white text-xs flex items-center justify-center font-bold">2</div><span class="text-[10px] text-[#10B981] font-semibold uppercase">Destination</span></div>
                 <div class="h-px flex-1 bg-gray-200 mx-2"></div>
                 <div class="flex flex-col items-center gap-1"><div class="w-6 h-6 rounded-full bg-gray-200 text-gray-500 text-xs flex items-center justify-center font-bold">3</div><span class="text-[10px] text-gray-400 font-semibold uppercase">Migrate</span></div>
              </div>
              
              <!-- Content -->
              <div class="flex gap-6 h-full">
                <!-- Sidebar -->
                <div class="w-1/3 border border-gray-100 rounded-lg p-3 bg-gray-50 flex flex-col gap-3">
                  <div class="h-3 w-1/2 bg-gray-200 rounded"></div>
                  <div class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" class="text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-1.22-1.8A2 2 0 0 0 7.53 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg><div class="h-2 w-3/4 bg-gray-300 rounded"></div></div>
                  <div class="flex items-center gap-2 pl-4"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" class="text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-1.22-1.8A2 2 0 0 0 7.53 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg><div class="h-2 w-1/2 bg-gray-300 rounded"></div></div>
                  <div class="flex items-center gap-2 pl-4"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" class="text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-1.22-1.8A2 2 0 0 0 7.53 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg><div class="h-2 w-2/3 bg-gray-300 rounded"></div></div>
                </div>
                
                <!-- Main Area -->
                <div class="w-2/3 flex flex-col justify-between">
                  <div>
                    <h3 class="text-sm font-bold text-gray-700 mb-4">Select Output Format</h3>
                    <div class="grid grid-cols-2 gap-3">
                      <div class="border-2 border-[#10B981] bg-[#10B981]/5 rounded-lg p-3 flex items-center gap-2 cursor-pointer transition-transform hover:-translate-y-0.5">
                        <input type="radio" checked class="w-3 h-3 text-[#10B981]"> <span class="text-xs font-semibold">PST File</span>
                      </div>
                      <div class="border border-gray-200 rounded-lg p-3 flex items-center gap-2 cursor-pointer hover:border-gray-300 transition-transform hover:-translate-y-0.5">
                        <input type="radio" class="w-3 h-3"> <span class="text-xs font-medium">Office 365</span>
                      </div>
                      <div class="border border-gray-200 rounded-lg p-3 flex items-center gap-2 cursor-pointer hover:border-gray-300 transition-transform hover:-translate-y-0.5">
                        <input type="radio" class="w-3 h-3"> <span class="text-xs font-medium">Gmail</span>
                      </div>
                      <div class="border border-gray-200 rounded-lg p-3 flex items-center gap-2 cursor-pointer hover:border-gray-300 transition-transform hover:-translate-y-0.5">
                        <input type="radio" class="w-3 h-3"> <span class="text-xs font-medium">MBOX</span>
                      </div>
                    </div>
                  </div>
                  <div class="flex justify-end gap-2 mt-4">
                    <div class="h-8 w-20 bg-gray-100 rounded"></div>
                    <div class="h-8 w-24 bg-[#10B981] rounded shadow-sm"></div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Hover overlay simulating interactivity -->
            <div class="absolute inset-0 bg-[#064e3b]/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== WHY CHOOSE US ===================== -->
  <section class="py-20 bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-fade-in-up">
        <h2 class="text-3xl font-serif text-[#064e3b] mb-4">Why Choose Migration Uncle?</h2>
        <p class="text-lg text-gray-500">We take the headache out of data migration so you can get back to what matters.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {whyChooseUs.map((feature, i) => (
          <div class="p-8 rounded-3xl bg-[#F8F5F0] border border-gray-100 hover:shadow-md transition-shadow animate-fade-in-up" style={`animation-delay: ${i * 0.1 + 0.1}s;`}>
            <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-3xl shadow-sm mb-6">
              {feature.icon}
            </div>
            <h3 class="text-xl font-bold text-[#064e3b] mb-3">{feature.title}</h3>
            <p class="text-gray-600">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== POPULAR PRODUCTS GRID ===================== -->
  <section id="products" class="py-24 bg-[#F8F5F0]">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 animate-fade-in-up">
        <div>
          <h2 class="text-3xl lg:text-4xl font-serif font-bold text-[#064e3b] mb-4">Popular Migration Tools</h2>
          <p class="text-lg text-gray-600 max-w-2xl">From emails to databases, we have the right tool for your specific needs.</p>
        </div>
        <a href="/products" class="btn bg-white text-[#064e3b] border border-gray-200 hover:border-[#10B981] hover:text-[#10B981]">View All Products</a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products && products.slice(0, 6).map((product, i) => (
          <a href={`/products/${product.slug}`} class="group block bg-white rounded-3xl p-6 shadow-sm hover:shadow-xl border border-gray-100 transition-all duration-300 animate-fade-in-up hover:-translate-y-1" style={`animation-delay: ${i * 0.1}s;`}>
            <div class="flex items-start justify-between mb-6">
              <div class="w-16 h-16 rounded-2xl bg-[#ecfdf5] flex items-center justify-center text-[#10B981] group-hover:bg-[#10B981] group-hover:text-white transition-colors duration-300">
                <!-- Fallback icon if none provided -->
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
              </div>
              {product.badge && (
                <span class="px-3 py-1 bg-[#fffbeb] text-[#d97706] text-xs font-bold uppercase tracking-wider rounded-full">{product.badge}</span>
              )}
            </div>
            
            <h3 class="text-xl font-bold text-[#064e3b] mb-2 group-hover:text-[#10B981] transition-colors">{product.name}</h3>
            <p class="text-gray-500 mb-6 line-clamp-2">{product.shortDescription || product.description}</p>
            
            <div class="flex items-center text-[#10B981] font-semibold">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
        {(!products || products.length === 0) && (
          <div class="col-span-full py-12 text-center text-gray-500 bg-white rounded-3xl border border-gray-100 border-dashed">
            No products available in this catalog yet.
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ===================== FAQ TEASER ===================== -->
  <section class="py-24 bg-white">
    <div class="container-custom max-w-4xl mx-auto text-center animate-fade-in-up">
      <h2 class="text-3xl font-serif text-[#064e3b] mb-12">Common Questions</h2>
      
      <div class="space-y-4 text-left">
        {faqs.map((faq) => (
          <div class="bg-[#F8F5F0] rounded-2xl p-6">
            <h4 class="font-bold text-[#064e3b] text-lg mb-2">{faq.q}</h4>
            <p class="text-gray-600">{faq.a}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-10">
        <a href="/faq" class="font-semibold text-[#F59E0B] hover:text-[#d97706] inline-flex items-center">
          Read more FAQs
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#064e3b]">
      <!-- Pattern overlay -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 32px 32px;"></div>
    </div>
    
    <div class="container-custom relative z-10 text-center animate-fade-in-up">
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-white mb-6">Ready to move your data?</h2>
      <p class="text-xl text-[#d1fae5] mb-10 max-w-2xl mx-auto">Let Uncle handle it. Join thousands of users who migrated safely without losing a single file.</p>
      
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="/products" class="btn bg-[#F59E0B] hover:bg-[#d97706] text-white text-lg px-10 py-4 shadow-lg border-transparent">
          Explore All Tools
        </a>
        <a href="/contact" class="btn bg-white/10 text-white border border-white/20 hover:bg-white/20 text-lg px-10 py-4">
          Talk to Support
        </a>
      </div>
    </div>
  </section>

</div>
