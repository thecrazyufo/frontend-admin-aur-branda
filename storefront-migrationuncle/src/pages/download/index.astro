---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, SettingsAPI } from "@/services/api";
import SectionHeader from "@/components/common/SectionHeader";
import { Download, Monitor, CheckCircle, RefreshCw, X } from "lucide-react";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "";

let productsList = [];

try {
  productsList = await ProductAPI.getAll();
} catch (e) {
  console.error("Error loading products for downloads:", e);
}

// Check for auto-download parameters
const url = new URL(Astro.request.url);
const targetSlug = url.searchParams.get("product");
const autoProduct = targetSlug ? productsList.find(p => p.slug === targetSlug) : null;
---

<BaseLayout
  title={`Download Center — Free Trial Downloads | ${siteName}`}
  description={`Download free trials of all ${siteName} tools. No credit card required. Try before you buy.`}
  noindex={true}
>
  <div>
    <section class="hero-gradient py-16 text-center">
      <div class="container-custom">
        <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full text-blue-300 bg-white/10">Download Center</span>
        <h1 class="text-white font-bold mb-4 font-bold">Download Free Trials</h1>
        <p class="text-gray-300 max-w-xl mx-auto leading-relaxed">
          Try any tool free. No credit card required. Migrate/convert up to 50 items in trial mode to verify it works for you.
        </p>
        <div class="flex items-center justify-center gap-6 mt-6 text-sm text-gray-400 flex-wrap">
          {["No Credit Card", "Instant Download", "100% Safe & Secure", "Windows Compatible"].map((t) => (
            <div class="flex items-center gap-1.5">
              <CheckCircle size={13} class="text-green-400" />
              {t}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Auto Download Modal overlay */}
    {autoProduct && (
      <div id="download-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl relative border border-gray-100 text-center animate-in fade-in zoom-in duration-200">
          <button 
            onclick="document.getElementById('download-overlay').style.display='none'"
            class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 p-2 hover:bg-gray-50 rounded-full"
            aria-label="Close modal"
          >
            <X size={18} />
          </button>
          
          <div id="modal-initial-state">
            <div class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-4 text-blue-600">
              <Download size={32} />
            </div>
            
            <h2 class="text-xl font-bold text-gray-900 mb-2">Download Free Trial</h2>
            <p class="text-sm text-gray-500 mb-6">
              Enter your email to download your free trial of <strong class="text-gray-800">{autoProduct.name}</strong>.
            </p>
            
            <form id="lead-form" class="space-y-4">
              <div class="text-left">
                <label for="lead-email" class="block text-xs font-semibold text-gray-500 mb-1.5 uppercase tracking-wider font-medium">Business Email Address</label>
                <input 
                  type="email" 
                  id="lead-email" 
                  required 
                  placeholder="name@company.com" 
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-gray-800 bg-gray-50/50"
                />
              </div>
              
              <button 
                type="submit" 
                id="submit-btn" 
                class="btn btn-primary w-full justify-center text-sm py-3 font-semibold shadow-lg shadow-blue-500/20"
              >
                Request Download
              </button>
            </form>
            
            <div id="error-message" class="text-red-500 text-xs mt-3 hidden"></div>
          </div>

          <div id="modal-success-state" class="hidden">
            <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-4 text-green-600">
              <CheckCircle size={32} />
            </div>
            
            <h2 class="text-xl font-bold text-gray-900 mb-2">Starting Your Download...</h2>
            <p class="text-sm text-gray-500 mb-6">
              Downloading the setup package for <strong class="text-gray-800">{autoProduct.name}</strong>.
            </p>
            
            <div class="bg-gray-50 rounded-2xl p-4 text-xs text-gray-500 text-left space-y-2 mb-6">
              <p class="font-semibold text-gray-700">Next Steps:</p>
              <ol class="list-decimal list-inside space-y-1">
                <li>Open the downloaded installer file.</li>
                <li>Follow the instructions on the screen to install.</li>
                <li>Run the application in free trial mode or enter your license key to activate the full version.</li>
              </ol>
            </div>

            <a 
              id="manual-download-link"
              href="#" 
              class="btn btn-primary w-full justify-center text-sm py-2.5"
            >
              Click here if download doesn't start
            </a>
          </div>
        </div>

        <script is:inline define:vars={{ productSlug: autoProduct.slug, publicApiUrl: import.meta.env.PUBLIC_API_URL || "http://localhost:8080/api" }}>
          const form = document.getElementById("lead-form");
          const emailInput = document.getElementById("lead-email");
          const submitBtn = document.getElementById("submit-btn");
          const errorMsg = document.getElementById("error-message");
          const initialState = document.getElementById("modal-initial-state");
          const successState = document.getElementById("modal-success-state");
          const manualLink = document.getElementById("manual-download-link");

          form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const email = emailInput?.value;
            if (!email) return;

            submitBtn.disabled = true;
            submitBtn.textContent = "Processing...";
            errorMsg.classList.add("hidden");

            try {
              const res = await fetch(`${publicApiUrl}/download/trial`, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json"
                },
                body: JSON.stringify({ email, productSlug })
              });

              if (res.ok) {
                const data = await res.json();
                
                // Show success state
                initialState.classList.add("hidden");
                successState.classList.remove("hidden");
                manualLink.href = data.downloadUrl;

                // Trigger download
                const link = document.createElement("a");
                link.href = data.downloadUrl;
                link.download = "";
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
              } else {
                const errData = await res.json().catch(() => ({}));
                errorMsg.textContent = errData.message || "Failed to initiate download. Please check your email and try again.";
                errorMsg.classList.remove("hidden");
                submitBtn.disabled = false;
                submitBtn.textContent = "Request Download";
              }
            } catch (err) {
              console.error("Error submitting lead:", err);
              errorMsg.textContent = "Network error. Please try again later.";
              errorMsg.classList.remove("hidden");
              submitBtn.disabled = false;
              submitBtn.textContent = "Request Download";
            }
          });
        </script>
      </div>
    )}

    <section class="section bg-gray-50">
      <div class="container-custom">
        <SectionHeader eyebrow="Downloads" title="All Available Tools" class="mb-10" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {productsList.map((product) => (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex items-start justify-between gap-6 card-hover">
              <div class="flex items-start gap-4 flex-1">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-md shrink-0">
                  <Download size={20} class="text-white" />
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-1">{product.name}</h3>
                  <p class="text-sm text-gray-500 mb-3 line-clamp-2 leading-relaxed">{product.shortDescription}</p>
                  <div class="flex items-center gap-3 text-xs text-gray-400 flex-wrap">
                    <span class="flex items-center gap-1"><Monitor size={11} /> Windows</span>
                    <span>v{product.version}</span>
                    <span>{product.downloads} downloads</span>
                  </div>
                </div>
              </div>
              <div class="flex flex-col gap-2 shrink-0">
                <a
                  href={`/download?product=${product.slug}`}
                  class="btn btn-primary text-sm py-2 px-4 whitespace-nowrap flex items-center gap-1"
                >
                  <Download size={14} />
                  Download
                </a>
                <a href={`/products/${product.slug}`} class="text-xs text-center text-blue-500 hover:text-blue-700">
                  Learn more →
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
