---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/common/SectionHeader";
import { Briefcase, MapPin, Clock, DollarSign, CheckCircle2, Send, Heart, Globe, BookOpen } from "lucide-react";
import { SettingsAPI, JobsAPI } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);
const siteName = settings?.name || "Prism Migration";

// Load dynamic careers configurations
const careers = settings?.careersPage || {
  heroTitle: "Join Our Team",
  heroDescription: "Help us build the future of software selling and data migration.",
  companyCultureTitle: "Our Company Culture",
  companyCultureDesc: "We value autonomy, craft, and balanced lives. We believe in doing great work without sacrificing sanity.",
  benefits: [
    { title: "Remote First", description: "Work from anywhere in the world.", icon: "Globe" },
    { title: "Health & Wellness", description: "Comprehensive premium health coverage.", icon: "Heart" },
    { title: "Learning & Growth", description: "Annual education budget for courses/books.", icon: "BookOpen" }
  ],
  openPositions: [],
  metaTitle: "Careers at Prism Migration | Join Our Team",
  metaDescription: "Explore career opportunities at Prism Migration. We are looking for talented engineers, designers, and marketers.",
  metaKeywords: "careers, jobs, engineering jobs, remote jobs"
};

const activePositions = await JobsAPI.getAll("OPEN").catch(() => []);

// Generate JobPosting Structured Data
const schemas = activePositions.map((pos: any) => ({
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": pos.title,
  "description": `${pos.description}\n\nRequirements:\n${pos.requirements}`,
  "datePosted": "2026-07-06",
  "validThrough": "2027-07-06",
  "employmentType": pos.type?.toLowerCase().includes("part") ? "PART_TIME" : "FULL_TIME",
  "hiringOrganization": {
    "@type": "Organization",
    "name": siteName,
    "sameAs": settings?.url || "https://prismmigration.com"
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": pos.location?.includes(",") ? pos.location.split(",")[0].trim() : pos.location || "Remote",
      "addressRegion": pos.location?.includes(",") ? pos.location.split(",")[1].trim() : "US",
      "addressCountry": "US"
    }
  }
}));
---

<BaseLayout
  title={careers.metaTitle || `Careers — ${siteName}`}
  description={careers.metaDescription || `Explore open positions at ${siteName} and join our remote-first team.`}
  keywords={careers.metaKeywords}
>
  <!-- Job Schema JSON-LD -->
  {schemas.map((schema: any) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <div class="bg-white min-h-screen text-zinc-100 font-sans">
    {/* Hero Section */}
    <section class="relative py-24 text-center border-b border-[var(--color-border)] overflow-hidden">
      <!-- Ambient reflection glow background -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[150px] bg-[var(--color-apex-600)]/5 blur-[90px] rounded-full"></div>
      </div>

      <div class="container-custom relative z-10 max-w-4xl mx-auto px-4">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full text-[var(--color-apex-600)] bg-[var(--color-apex-600)]/15 border border-[var(--color-apex-600)]/25">
          We Are Hiring
        </span>
        <h1 class="text-[var(--color-text-primary)] font-extrabold text-4xl md:text-6xl tracking-tight mb-6 leading-tight">
          {careers.heroTitle}
        </h1>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
          {careers.heroDescription}
        </p>
      </div>
    </section>

    {/* Benefits Section */}
    <section class="py-20 border-b border-[var(--color-border)] bg-[var(--color-apex-50)]/20">
      <div class="container-custom max-w-5xl mx-auto px-4">
        <SectionHeader eyebrow="Perks" title="Why You'll Love Working Here" centered class="mb-12" />
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {(careers.benefits || []).map((b: any) => (
            <div class="bg-[var(--color-surface-2)]/35 border border-[var(--color-border)]/80 backdrop-blur rounded-2xl p-6 transition-all duration-300 hover:border-[var(--color-border)]">
              <div class="w-12 h-12 rounded-xl bg-[var(--color-apex-600)]/10 flex items-center justify-center text-[var(--color-apex-600)] mb-4 border border-[var(--color-apex-600)]/20">
                {b.icon === "Globe" && <Globe size={22} />}
                {b.icon === "Heart" && <Heart size={22} />}
                {b.icon === "BookOpen" && <BookOpen size={22} />}
                {!["Globe", "Heart", "BookOpen"].includes(b.icon) && <Briefcase size={22} />}
              </div>
              <h3 class="text-[var(--color-text-primary)] font-bold text-lg mb-2">{b.title}</h3>
              <p class="text-[var(--color-text-secondary)] text-xs leading-relaxed">{b.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Culture Section */}
    <section class="py-20 border-b border-[var(--color-border)]">
      <div class="container-custom max-w-3xl mx-auto px-4 text-center">
        <SectionHeader eyebrow="Culture" title={careers.companyCultureTitle} centered class="mb-6" />
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed whitespace-pre-line">
          {careers.companyCultureDesc}
        </p>
      </div>
    </section>

    {/* Open Positions Section */}
    <section class="py-20 border-b border-[var(--color-border)] bg-[var(--color-apex-50)]/20" id="positions">
      <div class="container-custom max-w-4xl mx-auto px-4">
        <SectionHeader eyebrow="Opportunities" title="Open Positions" centered class="mb-12" />

        {activePositions.length === 0 ? (
          <div class="text-center py-12 bg-[var(--color-surface-2)]/20 rounded-2xl border border-[var(--color-border)]">
            <Briefcase size={36} class="text-stone-500 mx-auto mb-3" />
            <p class="text-[var(--color-text-secondary)] text-sm">No open positions currently. Check back later or send a general application below!</p>
          </div>
        ) : (
          <div class="space-y-4">
            {activePositions.map((pos: any) => (
              <div class="bg-[var(--color-surface-2)]/35 border border-[var(--color-border)]/80 rounded-2xl p-6 transition-all duration-300 hover:border-[var(--color-apex-600)]/30 group">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
                  <div>
                    <span class="inline-block text-[10px] font-bold text-[var(--color-apex-600)] uppercase tracking-wider bg-[var(--color-apex-600)]/10 border border-[var(--color-apex-600)]/20 px-2 py-0.5 rounded mb-2">
                      {pos.department}
                    </span>
                    <h3 class="text-[var(--color-text-primary)] text-lg font-bold group-hover:text-[var(--color-apex-600)] transition-colors">
                      {pos.title}
                    </h3>
                  </div>
                  
                  <a
                    href="#apply-form"
                    onclick={`document.getElementById('job-title-input').value = '${pos.title}'; document.getElementById('apply-form').scrollIntoView({behavior: 'smooth'});`}
                    class="inline-flex h-9 items-center justify-center rounded-lg bg-[var(--color-apex-600)] px-4 text-xs font-bold text-stone-950 transition-transform duration-200 hover:scale-105 active:scale-95 shadow-lg"
                  >
                    Apply Now
                  </a>
                </div>

                <div class="flex flex-wrap items-center gap-y-2 gap-x-4 text-xs text-[var(--color-text-secondary)] font-medium mb-4">
                  <span class="flex items-center gap-1.5">
                    <MapPin size={14} class="text-stone-500" />
                    {pos.location}
                  </span>
                  <span class="flex items-center gap-1.5">
                    <Clock size={14} class="text-stone-500" />
                    {pos.type}
                  </span>
                  {pos.salaryRange && (
                    <span class="flex items-center gap-1.5">
                      <DollarSign size={14} class="text-stone-500" />
                      {pos.salaryRange}
                    </span>
                  )}
                  {pos.experience && (
                    <span class="flex items-center gap-1.5">
                      <Briefcase size={14} class="text-stone-500" />
                      {pos.experience}
                    </span>
                  )}
                </div>

                <p class="text-[var(--color-text-muted)] text-xs leading-relaxed mb-4">
                  {pos.description}
                </p>

                {pos.requirements && (
                  <div class="border-t border-[var(--color-border)]/60 pt-4 mt-4">
                    <h4 class="text-[var(--color-text-primary)] text-xs font-bold mb-2">Requirements:</h4>
                    <p class="text-[var(--color-text-secondary)] text-xs font-mono leading-relaxed whitespace-pre-line">
                      {pos.requirements}
                    </p>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    {/* Application Form Section */}
    <section class="py-20" id="apply-form">
      <div class="container-custom max-w-xl mx-auto px-4">
        <div class="bg-[var(--color-surface-2)]/30 border border-[var(--color-border)] rounded-3xl p-8 backdrop-blur">
          <h2 class="text-[var(--color-text-primary)] text-2xl font-bold text-center mb-2">Apply for a Position</h2>
          <p class="text-[var(--color-text-secondary)] text-xs text-center mb-8">Submit your resume and details. Our HR team will reach out within 3 business days.</p>

          <form id="career-form" class="space-y-4">
            <div class="space-y-1.5">
              <label class="text-[11px] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider" for="full-name">Full Name</label>
              <input 
                id="full-name" 
                type="text" 
                required 
                placeholder="John Doe" 
                class="w-full bg-[#0E0E0E] border border-stone-800 rounded-xl px-4 py-3 text-sm text-[var(--color-text-primary)] outline-none focus:border-[var(--color-apex-600)] focus:ring-1 focus:ring-[#EAB308]/25 transition-all"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider" for="email">Email Address</label>
                <input 
                  id="email" 
                  type="email" 
                  required 
                  placeholder="john@example.com" 
                  class="w-full bg-[#0E0E0E] border border-stone-800 rounded-xl px-4 py-3 text-sm text-[var(--color-text-primary)] outline-none focus:border-[var(--color-apex-600)] focus:ring-1 focus:ring-[#EAB308]/25 transition-all"
                />
              </div>
              <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider" for="phone">Phone Number</label>
                <input 
                  id="phone" 
                  type="tel" 
                  required 
                  placeholder="+1 (555) 000-0000" 
                  class="w-full bg-[#0E0E0E] border border-stone-800 rounded-xl px-4 py-3 text-sm text-[var(--color-text-primary)] outline-none focus:border-[var(--color-apex-600)] focus:ring-1 focus:ring-[#EAB308]/25 transition-all"
                />
              </div>
            </div>

            <div class="space-y-1.5">
              <label class="text-[11px] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider" for="job-title-input">Target Position</label>
              <input 
                id="job-title-input" 
                type="text" 
                required 
                placeholder="e.g. Senior Full-Stack Engineer" 
                class="w-full bg-[#0E0E0E] border border-stone-800 rounded-xl px-4 py-3 text-sm text-[var(--color-text-primary)] outline-none focus:border-[var(--color-apex-600)] focus:ring-1 focus:ring-[#EAB308]/25 transition-all"
              />
            </div>

            <div class="space-y-1.5">
              <label class="text-[11px] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider" for="resume">Cover Letter & Resume URL</label>
              <textarea 
                id="resume" 
                required 
                rows={5} 
                placeholder="Tell us about yourself and share links to your LinkedIn, GitHub, or resume document..." 
                class="w-full bg-[#0E0E0E] border border-stone-800 rounded-xl px-4 py-3 text-sm text-[var(--color-text-primary)] outline-none focus:border-[var(--color-apex-600)] focus:ring-1 focus:ring-[#EAB308]/25 transition-all resize-none"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-[var(--color-apex-600)] px-6 text-sm font-bold text-stone-950 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] shadow-lg cursor-pointer"
            >
              <Send size={16} />
              Submit Application
            </button>
          </form>

          {/* Success Dialog */}
          <div id="success-message" class="hidden text-center py-6 space-y-3">
            <div class="w-12 h-12 bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 rounded-full flex items-center justify-center mx-auto">
              <CheckCircle2 size={24} />
            </div>
            <h3 class="text-[var(--color-text-primary)] font-bold text-lg">Application Submitted!</h3>
            <p class="text-[var(--color-text-secondary)] text-xs">Thank you for your interest. Our recruitment team has received your application and details.</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const form = document.getElementById('career-form');
    const successMsg = document.getElementById('success-message');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = document.getElementById('full-name').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      const position = document.getElementById('job-title-input').value;
      const resume = document.getElementById('resume').value;

      try {
        const res = await fetch('/api/support/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            name: name,
            email: email,
            subject: `Job Application: ${position}`,
            message: `Phone: ${phone}\n\nCover Letter / Resume details:\n${resume}`
          })
        });

        if (res.ok) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
        } else {
          alert('Failed to submit application. Please try again.');
        }
      } catch (err) {
        alert('Failed to submit application. Please try again.');
      }
    });
  </script>
</BaseLayout>
