---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FaqAPI , SettingsAPI } from "@/services/api";
const settings = await SettingsAPI.get().catch(() => null);
import { FAQ_CATEGORY_LABELS, type FAQCategory } from "@/types/faq";
import { generateFAQSchema } from "@/lib/seo";
import SectionHeader from "@/components/common/SectionHeader";
import { ChevronRight } from "lucide-react";

let faqsList = [];
let grouped: Record<string, typeof faqsList> = {};

try {
  faqsList = await FaqAPI.getAll();
  grouped = faqsList.reduce<Record<string, typeof faqsList>>((acc, faq) => {
    if (!acc[faq.category]) acc[faq.category] = [];
    acc[faq.category].push(faq);
    return acc;
  }, {});
} catch (e) {
  console.error("Error loading FAQs:", e);
}
---

<BaseLayout
  title={`Frequently Asked Questions — ${settings?.name || ""}`}
  description="Find answers to frequently asked questions about our software tools, licensing, payments, and technical support."
>
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQSchema(faqsList.map((f) => ({ question: f.question, answer: f.answer }))))} />

  <!-- Page Header (ApexByte: light blue-white style) -->
  <div class="bg-[var(--color-apex-800)] py-14 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="container-custom relative z-10">
      <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full bg-white/10 border border-white/20" style="color: var(--color-apex-200)">FAQ</span>
      <h1 class="font-extrabold mb-3" style="color: #ffffff">Frequently Asked Questions</h1>
      <p class="max-w-lg mx-auto" style="color: var(--color-apex-300)">
        Everything you need to know about our tools, licensing, and support.
      </p>
    </div>
  </div>

  <div class="container-custom py-14 max-w-4xl">
    {Object.entries(grouped).map(([category, items]) => (
      <div class="mb-12">
        <SectionHeader
          eyebrow="Category"
          title={FAQ_CATEGORY_LABELS[category as FAQCategory]}
          class="mb-6"
        />
        <div class="space-y-3">
          {items.map((faq) => (
            <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
                <span class="font-semibold text-gray-900 pr-4">{faq.question}</span>
                <ChevronRight size={18} class="text-gray-400 shrink-0 group-open:rotate-90 transition-transform" />
              </summary>
              <div class="px-6 pb-5">
                <p class="text-sm text-gray-600 leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
