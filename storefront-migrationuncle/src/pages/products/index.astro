---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProductAPI, CategoryAPI, SettingsAPI } from "@/services/api";
import ProductCard from "@/components/common/ProductCard";
import SectionHeader from "@/components/common/SectionHeader";

import type { Product } from "@/types/product";
import type { Category } from "@/services/api";

const settings = await SettingsAPI.get().catch(() => null);

const category = Astro.url.searchParams.get("category") || undefined;
const q        = Astro.url.searchParams.get("q")        || undefined;

let products:      Product[]   = [];
let categoriesList: Category[] = [];
let allProducts:   Product[]   = [];

try {
  const [ps, cs, aps] = await Promise.all([
    ProductAPI.getAll(category, q),
    CategoryAPI.getAll(),
    ProductAPI.getAll(),
  ]);
  products       = ps.filter((p) => p.enabled !== false);
  categoriesList = cs;
  allProducts    = aps.filter((p) => p.enabled !== false);
} catch (e) {
  console.error("Error loading products:", e);
}

const activeCategory = categoriesList.find((c) => c.id === category);
const filteredCount  = products.length;
const siteName       = settings?.name || "ApexByte Soft";
---

<BaseLayout
  title={activeCategory
    ? `${activeCategory.label} — ${siteName}`
    : `All Software Products — ${siteName}`}
  description={activeCategory
    ? activeCategory.description
    : "Browse our complete collection of enterprise migration, backup, and file management software."}
>
  <div class="min-h-screen" style="background: var(--color-surface-2)">

    <!-- Page Header -->
    <div class="bg-white border-b" style="border-color: var(--color-border)">
      <div class="container-custom py-10">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs mb-4" style="color: var(--color-text-faint)">
          <a href="/" class="hover:text-[var(--color-apex-600)] transition-colors font-medium">Home</a>
          <span>/</span>
          <span style="color: var(--color-text-muted)" class="font-medium">Products</span>
          {activeCategory && (
            <>
              <span>/</span>
              <span style="color: var(--color-text-primary)" class="font-semibold">{activeCategory.label}</span>
            </>
          )}
        </nav>

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
          <div>
            <h1 class="text-3xl font-extrabold tracking-tight mb-2" style="color: var(--color-text-primary)">
              {activeCategory ? activeCategory.label : "All Software Products"}
            </h1>
            <p style="color: var(--color-text-muted)" class="text-base max-w-2xl">
              {activeCategory
                ? activeCategory.description
                : "Professional-grade tools designed for IT departments, MSPs, and enterprise teams."}
            </p>
          </div>
          <a href="/search" class="btn btn-outline text-sm shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Search Products
          </a>
        </div>
      </div>
    </div>

    <div class="container-custom py-10">
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- Sidebar Filters -->
        <aside class="w-full lg:w-60 shrink-0">
          <div class="bg-white rounded-[var(--radius-lg)] border p-5 sticky top-[72px]" style="border-color: var(--color-border)">
            <h3 class="font-bold text-xs uppercase tracking-widest mb-4" style="color: var(--color-text-primary)">
              Filter by Category
            </h3>
            <ul class="space-y-1">
              <li>
                <a
                  href="/products"
                  class={`flex items-center justify-between px-3 py-2.5 rounded-[var(--radius-md)] text-sm font-semibold transition-colors ${
                    !category
                      ? "bg-[var(--color-apex-600)] text-white"
                      : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text-primary)]"
                  }`}
                >
                  All Products
                  <span class={`text-xs px-1.5 py-0.5 rounded-full font-bold ${!category ? "bg-white/20 text-white" : "bg-[var(--color-surface-2)] text-[var(--color-text-faint)]"}`}>
                    {allProducts.length}
                  </span>
                </a>
              </li>
              {categoriesList.map((cat) => (
                <li>
                  <a
                    href={`/products?category=${cat.id}`}
                    class={`flex items-center justify-between px-3 py-2.5 rounded-[var(--radius-md)] text-sm font-semibold transition-colors ${
                      category === cat.id
                        ? "bg-[var(--color-apex-600)] text-white"
                        : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text-primary)]"
                    }`}
                  >
                    {cat.label}
                    <span class={`text-xs px-1.5 py-0.5 rounded-full font-bold ${category === cat.id ? "bg-white/20 text-white" : "bg-[var(--color-surface-2)] text-[var(--color-text-faint)]"}`}>
                      {cat.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="flex-1">
          <div class="flex items-center justify-between mb-6">
            <p class="text-sm font-medium" style="color: var(--color-text-muted)">
              <span class="font-bold" style="color: var(--color-text-primary)">{filteredCount}</span>
              {" "}product{filteredCount !== 1 ? "s" : ""} found
              {activeCategory && <span> in <span class="font-semibold" style="color: var(--color-apex-600)">{activeCategory.label}</span></span>}
            </p>
          </div>

          {filteredCount > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          ) : (
            <div class="text-center py-20 bg-white rounded-[var(--radius-lg)] border p-8" style="border-color: var(--color-border)">
              <div class="w-16 h-16 mx-auto mb-4 rounded-[var(--radius-lg)] bg-[var(--color-apex-50)] border border-[var(--color-apex-100)] flex items-center justify-center text-3xl">
                📦
              </div>
              <h3 class="font-bold text-[var(--color-text-primary)] mb-2">No products found</h3>
              <p class="text-sm text-[var(--color-text-muted)] mb-5">
                Try a different category or remove your filters.
              </p>
              <a href="/products" class="btn btn-primary">Clear Filters</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
