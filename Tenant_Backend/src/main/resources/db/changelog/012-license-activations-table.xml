<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-license-activations-table" author="system">
        <createTable tableName="license_activations">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="license_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_license_activations_license" referencedTableName="licenses" referencedColumnNames="id"/>
            </column>
            <column name="machine_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="machine_name" type="VARCHAR(100)"/>
            <column name="os_name" type="VARCHAR(100)"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="activated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_checked_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint tableName="license_activations" columnNames="license_id,machine_id" constraintName="uq_license_activations_license_machine"/>
    </changeSet>

</databaseChangeLog>
