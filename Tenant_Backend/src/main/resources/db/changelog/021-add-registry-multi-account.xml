<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- 021: Add supports_multiple_accounts field to source and target formats -->

    <changeSet id="021-add-supports-multiple-accounts-source" author="platform">
        <addColumn tableName="source_formats">
            <column name="supports_multiple_accounts" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="021-add-supports-multiple-accounts-target" author="platform">
        <addColumn tableName="target_formats">
            <column name="supports_multiple_accounts" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
