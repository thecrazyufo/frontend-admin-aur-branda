<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-brand-templates" author="system">
        <addColumn tableName="brand_configs">
            <column name="layout_template" type="VARCHAR(255)"/>
        </addColumn>

        <!-- Seed distinct layouts for existing brands -->
        <update tableName="brand_configs">
            <column name="layout_template" value="luxury"/>
            <where>id = 'brandA'</where>
        </update>
        <update tableName="brand_configs">
            <column name="layout_template" value="tech-bold"/>
            <where>id = 'brandB'</where>
        </update>
        <update tableName="brand_configs">
            <column name="layout_template" value="playful"/>
            <where>id = 'brandC'</where>
        </update>
        <update tableName="brand_configs">
            <column name="layout_template" value="corporate"/>
            <where>id = 'brandD'</where>
        </update>
        <update tableName="brand_configs">
            <column name="layout_template" value="ecomm-dark"/>
            <where>id = 'brandE'</where>
        </update>
    </changeSet>

</databaseChangeLog>
