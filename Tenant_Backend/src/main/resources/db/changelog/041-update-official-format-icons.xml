<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- 041: Update format icons to official brand identifiers -->
    <changeSet id="041-update-official-format-icons" author="platform">
        <!-- Microsoft Outlook / PST / OST / MSG / OLM -->
        <update tableName="source_formats">
            <column name="icon" value="microsoft-outlook"/>
            <where>format_key IN ('pst', 'ost', 'msg', 'olm') AND site_id = 'brandA'</where>
        </update>
        <update tableName="target_formats">
            <column name="icon" value="microsoft-outlook"/>
            <where>format_key IN ('pst', 'ost', 'msg', 'olm') AND site_id = 'brandA'</where>
        </update>

        <!-- Gmail -->
        <update tableName="source_formats">
            <column name="icon" value="gmail"/>
            <where>format_key = 'gmail' AND site_id = 'brandA'</where>
        </update>
        <update tableName="target_formats">
            <column name="icon" value="gmail"/>
            <where>format_key = 'gmail' AND site_id = 'brandA'</where>
        </update>

        <!-- Google Workspace -->
        <update tableName="source_formats">
