<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="033-apexbyte-brand" author="system">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM brand_configs WHERE id = 'apexbyte'</sqlCheck>
        </preConditions>
        <insert tableName="brand_configs">
            <column name="id" value="apexbyte"/>
            <column name="name" value="ApexByte Soft"/>
            <column name="domain" value="apexbyte.local"/>
            <column name="theme_colors" value="{&quot;primary&quot;:&quot;#2563EB&quot;,&quot;accent&quot;:&quot;#0EA5E9&quot;}"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="dev_port" value="3002"/>
        </insert>
    </changeSet>

</databaseChangeLog>
