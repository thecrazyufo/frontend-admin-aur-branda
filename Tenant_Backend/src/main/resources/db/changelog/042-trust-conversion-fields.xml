<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd">

    <!-- Sprint: Trust & Conversion Gap Filling -->
    <!-- Adds review platform attribution, live chat embed, and press mentions to site_settings -->

    <changeSet id="042-trust-conversion-fields" author="system">

        <addColumn tableName="site_settings">
            <column name="review_platform_name" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="site_settings">
            <column name="review_platform_url" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="site_settings">
            <column name="review_platform_rating" type="NUMERIC(3,1)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="site_settings">
            <column name="review_platform_count" type="INTEGER">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="site_settings">
            <column name="live_chat_embed_code" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="site_settings">
            <column name="press_mentions" type="JSONB">
                <constraints nullable="true"/>
            </column>
        </addColumn>

    </changeSet>

</databaseChangeLog>
