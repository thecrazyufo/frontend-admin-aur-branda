            <column name="theme_colors" value="{&quot;primary&quot;:&quot;#06b6d4&quot;,&quot;accent&quot;:&quot;cyan&quot;}"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="brand_configs">
