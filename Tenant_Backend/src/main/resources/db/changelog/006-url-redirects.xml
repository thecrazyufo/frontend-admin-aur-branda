<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ═══════════════════════════════════════════════════════════════════════
         Changeset 006 — URL Redirects Table Schema for dynamic 301/302 SEO Redirects
         ═══════════════════════════════════════════════════════════════════════ -->

    <changeSet id="006-url-redirects-table" author="platform">
        <createTable tableName="url_redirects">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_path" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="target_path" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="redirect_type" type="INTEGER" defaultValueNumeric="301">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="site_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="url_redirects" indexName="idx_url_redirects_lookup">
            <column name="site_id"/>
            <column name="source_path"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
