<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="036-create-coupons-table" author="antigravity">
        <createTable tableName="coupons">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="discount_percentage" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="site_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- Unique constraint to prevent duplicate coupons per brand storefront -->
        <addUniqueConstraint tableName="coupons" columnNames="code, site_id" constraintName="uq_coupon_code_site"/>
    </changeSet>
</databaseChangeLog>
