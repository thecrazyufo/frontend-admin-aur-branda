<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Log Directories -->
    <property name="LOG_DIR" value="./logs" />
    <property name="LOG_FILE" value="${LOG_DIR}/backend.log" />

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [Trace: %X{traceId:-N/A}] [Tenant: %X{siteId:-N/A}] [User: %X{userId:-N/A}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover with path matching date, max size of 10MB per file, max history 7 days -->
            <fileNamePattern>${LOG_DIR}/backend-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [Trace: %X{traceId:-N/A}] [Tenant: %X{siteId:-N/A}] [User: %X{userId:-N/A}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Profile based Logging levels -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
        <!-- Verbose logging for our main app packages in dev -->
        <logger name="com.datamigratepro" level="DEBUG" />
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
        <logger name="com.datamigratepro" level="INFO" />
    </springProfile>

    <!-- Fallback if no profile is active -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
